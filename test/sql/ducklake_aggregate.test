# ==========================================
# Scalar aggregate subquery in HAVING
# ==========================================

statement ok
CREATE TABLE dl.hav_line (w INTEGER, o INTEGER, d INTEGER, amount DOUBLE);

statement ok
CREATE TABLE dl.hav_order (w INTEGER, o INTEGER, d INTEGER, c INTEGER);

statement ok
CREATE TABLE dl.hav_customer (w INTEGER, d INTEGER, c INTEGER, last_name VARCHAR);

statement ok
INSERT INTO dl.hav_line VALUES
    (1, 1, 1, 10), (1, 1, 1, 12),
    (1, 2, 1, 200), (1, 2, 1, 220),
    (2, 1, 1, 5);

statement ok
INSERT INTO dl.hav_order VALUES (1, 1, 1, 10), (1, 2, 1, 11), (2, 1, 1, 12);

statement ok
INSERT INTO dl.hav_customer VALUES (1, 1, 10, 'Able'), (1, 1, 11, 'Baker'), (2, 1, 12, 'Cross');

statement ok
CREATE MATERIALIZED VIEW dl.mv_hav_scalar AS
    WITH high_value AS (
        SELECT w, o, d
        FROM dl.hav_line
        GROUP BY w, o, d
        HAVING SUM(amount) > (SELECT AVG(amount) * 2 FROM dl.hav_line)
    )
    SELECT hv.w, hv.d, hv.o, c.last_name
    FROM high_value hv
    JOIN dl.hav_order o ON hv.w = o.w AND hv.d = o.d AND hv.o = o.o
    JOIN dl.hav_customer c ON o.w = c.w AND o.d = c.d AND o.c = c.c;

query I
SELECT type FROM openivm_views WHERE view_name = 'mv_hav_scalar';
----
6

statement ok
INSERT INTO dl.hav_line VALUES (1, 3, 1, 500);

statement ok
INSERT INTO dl.hav_order VALUES (1, 3, 1, 13);

statement ok
INSERT INTO dl.hav_customer VALUES (1, 1, 13, 'Delta');

statement ok
PRAGMA refresh('mv_hav_scalar');

query I
SELECT COUNT(*) FROM (
    SELECT w, d, o, last_name FROM dl.mv_hav_scalar
    EXCEPT ALL
    SELECT * FROM (WITH high_value AS (
        SELECT w, o, d
        FROM dl.hav_line
        GROUP BY w, o, d
        HAVING SUM(amount) > (SELECT AVG(amount) * 2 FROM dl.hav_line)
    )
    SELECT hv.w, hv.d, hv.o, c.last_name
    FROM high_value hv
    JOIN dl.hav_order o ON hv.w = o.w AND hv.d = o.d AND hv.o = o.o
    JOIN dl.hav_customer c ON o.w = c.w AND o.d = c.d AND o.c = c.c
    ) _q
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM (WITH high_value AS (
        SELECT w, o, d
        FROM dl.hav_line
        GROUP BY w, o, d
        HAVING SUM(amount) > (SELECT AVG(amount) * 2 FROM dl.hav_line)
    )
    SELECT hv.w, hv.d, hv.o, c.last_name
    FROM high_value hv
    JOIN dl.hav_order o ON hv.w = o.w AND hv.d = o.d AND hv.o = o.o
    JOIN dl.hav_customer c ON o.w = c.w AND o.d = c.d AND o.c = c.c
    ) _q
    EXCEPT ALL
    SELECT w, d, o, last_name FROM dl.mv_hav_scalar
);
