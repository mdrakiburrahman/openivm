# Nested HAVING stays inside the stored data query. A source update can make a
# previously invisible joined group satisfy HAVING without changing its GROUP BY key.
statement ok
CREATE TABLE dl.minmax_join_dim (
    grp VARCHAR,
    region_state VARCHAR,
    tax_band VARCHAR
);

statement ok
CREATE TABLE dl.minmax_join_orders (
    grp VARCHAR,
    order_amount DOUBLE
);

statement ok
CREATE TABLE dl.minmax_join_customer (
    id INTEGER,
    grp VARCHAR,
    credit VARCHAR,
    balance DOUBLE
);

statement ok
INSERT INTO dl.minmax_join_dim VALUES
    ('north', 'ST', 'mid'),
    ('west', 'ST', 'mid');

statement ok
INSERT INTO dl.minmax_join_orders VALUES ('north', 300.0);

statement ok
INSERT INTO dl.minmax_join_customer VALUES
    (1, 'north', 'GC', 10000.0),
    (2, 'west', 'GC', 10000.0);

statement ok
CREATE MATERIALIZED VIEW dl.mv_minmax_join_having AS
    WITH
    params AS (
        SELECT 100.0::DOUBLE AS cutoff, 0.0::DOUBLE AS zero_amount
    ),
    dim AS (
        SELECT d.grp, d.region_state, d.tax_band
        FROM dl.minmax_join_dim d
    ),
    orders AS (
        SELECT o.grp, SUM(o.order_amount) AS order_amount
        FROM dl.minmax_join_orders o
        GROUP BY o.grp
    ),
    base AS (
        SELECT
            c.grp,
            d.region_state,
            d.tax_band,
            COALESCE(c.credit, 'BC') AS credit_code,
            CAST(c.balance AS DOUBLE) AS balance_amount,
            COALESCE(o.order_amount, 0.0) AS order_amount,
            CASE
                WHEN o.order_amount IS NULL THEN 'closed'
                WHEN o.order_amount > 100 THEN 'large'
                ELSE 'open'
            END AS activity_bucket
        FROM dl.minmax_join_customer c
        JOIN dim d ON d.grp = c.grp
        LEFT JOIN orders o ON o.grp = c.grp
    ),
    rollup AS (
        SELECT
            grp,
            region_state,
            tax_band,
            credit_code,
            activity_bucket,
            COUNT(*) AS row_count,
            COUNT(*) FILTER (WHERE credit_code = 'GC') AS good_credit_rows,
            SUM(balance_amount) FILTER (WHERE balance_amount > (SELECT cutoff FROM params)) AS high_balance_sum,
            SUM(order_amount) FILTER (WHERE activity_bucket IN ('open', 'large')) AS active_order_sum,
            MIN(balance_amount) AS min_balance,
            MAX(balance_amount) AS max_balance
        FROM base
        GROUP BY grp, region_state, tax_band, credit_code, activity_bucket
        HAVING
            COUNT(*) FILTER (WHERE credit_code IS NOT NULL) > 0
            AND (
                SUM(order_amount) FILTER (WHERE activity_bucket IN ('open', 'large')) IS NOT NULL
                OR SUM(balance_amount) FILTER (WHERE balance_amount <= (SELECT cutoff FROM params)) IS NOT NULL
            )
    )
    SELECT
        grp,
        region_state,
        tax_band,
        credit_code,
        activity_bucket,
        row_count,
        good_credit_rows,
        COALESCE(high_balance_sum, (SELECT zero_amount FROM params)) AS high_balance_sum,
        COALESCE(active_order_sum, (SELECT zero_amount FROM params)) AS active_order_sum,
        min_balance,
        max_balance
    FROM rollup;

query I
SELECT type FROM openivm_views WHERE view_name = 'mv_minmax_join_having';
