# ==========================================
# Group recompute with repeated source table
# ==========================================

statement ok
CREATE TABLE dl.market (
    dm_date DATE,
    dm_s_symb VARCHAR,
    dm_close DOUBLE,
    dm_high DOUBLE,
    dm_low DOUBLE,
    dm_vol BIGINT
);

statement ok
INSERT INTO dl.market VALUES
    (DATE '2020-01-01', 'A', 10, 11, 9, 100),
    (DATE '2020-01-02', 'A', 12, 13, 8, 200),
    (DATE '2020-01-03', 'A', 11, 14, 10, 150);

statement ok
CREATE MATERIALIZED VIEW dl.market_rollup AS
    WITH s1 AS (
        SELECT
            a.dm_date,
            a.dm_s_symb,
            a.dm_close,
            a.dm_high,
            a.dm_low,
            a.dm_vol,
            MIN(b.dm_low) AS fifty_two_week_low,
            MAX(b.dm_high) AS fifty_two_week_high
        FROM dl.market a
        JOIN dl.market b
            ON a.dm_s_symb = b.dm_s_symb
            AND b.dm_date BETWEEN a.dm_date - INTERVAL '12' MONTH AND a.dm_date
        GROUP BY a.dm_date, a.dm_s_symb, a.dm_close, a.dm_high, a.dm_low, a.dm_vol
    )
    SELECT
        a.dm_date,
        a.dm_s_symb,
        a.dm_close,
        a.dm_high,
        a.dm_low,
        a.dm_vol,
        a.fifty_two_week_low,
        a.fifty_two_week_high,
        MIN(b.dm_date) AS fifty_two_week_low_date,
        MIN(c.dm_date) AS fifty_two_week_high_date
    FROM s1 a
    JOIN dl.market b
        ON a.dm_s_symb = b.dm_s_symb
        AND a.fifty_two_week_low = b.dm_low
        AND b.dm_date BETWEEN a.dm_date - INTERVAL '12' MONTH AND a.dm_date
    JOIN dl.market c
        ON a.dm_s_symb = c.dm_s_symb
        AND a.fifty_two_week_high = c.dm_high
        AND c.dm_date BETWEEN a.dm_date - INTERVAL '12' MONTH AND a.dm_date
    GROUP BY
        a.dm_date,
        a.dm_s_symb,
        a.dm_close,
        a.dm_high,
        a.dm_low,
        a.dm_vol,
        a.fifty_two_week_low,
        a.fifty_two_week_high;

statement ok
INSERT INTO dl.market VALUES (DATE '2019-12-31', 'A', 9, 21, 1, 50);

statement ok
PRAGMA refresh('market_rollup');

query I
WITH expected AS (
    WITH s1 AS (
        SELECT
            a.dm_date,
            a.dm_s_symb,
            a.dm_close,
            a.dm_high,
            a.dm_low,
            a.dm_vol,
            MIN(b.dm_low) AS fifty_two_week_low,
            MAX(b.dm_high) AS fifty_two_week_high
        FROM dl.market a
        JOIN dl.market b
            ON a.dm_s_symb = b.dm_s_symb
            AND b.dm_date BETWEEN a.dm_date - INTERVAL '12' MONTH AND a.dm_date
        GROUP BY a.dm_date, a.dm_s_symb, a.dm_close, a.dm_high, a.dm_low, a.dm_vol
    )
    SELECT
        a.dm_date,
        a.dm_s_symb,
        a.dm_close,
        a.dm_high,
        a.dm_low,
        a.dm_vol,
        a.fifty_two_week_low,
        a.fifty_two_week_high,
        MIN(b.dm_date) AS fifty_two_week_low_date,
        MIN(c.dm_date) AS fifty_two_week_high_date
    FROM s1 a
    JOIN dl.market b
        ON a.dm_s_symb = b.dm_s_symb
        AND a.fifty_two_week_low = b.dm_low
        AND b.dm_date BETWEEN a.dm_date - INTERVAL '12' MONTH AND a.dm_date
    JOIN dl.market c
        ON a.dm_s_symb = c.dm_s_symb
        AND a.fifty_two_week_high = c.dm_high
        AND c.dm_date BETWEEN a.dm_date - INTERVAL '12' MONTH AND a.dm_date
    GROUP BY
        a.dm_date,
        a.dm_s_symb,
        a.dm_close,
        a.dm_high,
        a.dm_low,
        a.dm_vol,
        a.fifty_two_week_low,
        a.fifty_two_week_high
)
SELECT count(*) FROM (
    SELECT * FROM dl.market_rollup
    EXCEPT ALL
    SELECT * FROM expected
    UNION ALL
    SELECT * FROM expected
    EXCEPT ALL
    SELECT * FROM dl.market_rollup
);
----
0

# ==========================================
# Group recompute with MIN/MAX plus computed output
# ==========================================

statement ok
CREATE TABLE dl.watch_events (
    customer_id INT,
    symbol VARCHAR,
    company_id INT,
    company_name VARCHAR,
    event_ts TIMESTAMP,
    action_type VARCHAR
);

statement ok
INSERT INTO dl.watch_events VALUES
    (1, 'AAA', NULL, NULL, TIMESTAMP '2026-01-01 10:00:00', 'Activate'),
    (2, 'BBB', 10, 'Beta', TIMESTAMP '2026-01-01 11:00:00', 'Activate');

statement ok
CREATE MATERIALIZED VIEW dl.watch_history AS
    SELECT customer_id, symbol, company_id, company_name, event_ts, action_type FROM dl.watch_events;

statement ok
CREATE MATERIALIZED VIEW dl.watch_state AS
    WITH s1 AS (
        SELECT
            customer_id,
            symbol,
            company_id,
            company_name,
            CASE action_type WHEN 'Activate' THEN event_ts ELSE NULL END AS placed_timestamp,
            CASE action_type WHEN 'Cancelled' THEN event_ts ELSE NULL END AS removed_timestamp
        FROM dl.watch_history
    )
    SELECT
        customer_id,
        symbol,
        company_id,
        company_name,
        MIN(placed_timestamp) AS placed_timestamp,
        MAX(removed_timestamp) AS removed_timestamp,
        CASE WHEN MAX(removed_timestamp) IS NULL THEN 'Active' ELSE 'Inactive' END AS watch_status
    FROM s1
    GROUP BY customer_id, symbol, company_id, company_name;

statement ok
INSERT INTO dl.watch_events VALUES
    (1, 'AAA', NULL, NULL, TIMESTAMP '2026-01-02 10:00:00', 'Cancelled'),
    (3, 'CCC', NULL, NULL, TIMESTAMP '2026-01-02 12:00:00', 'Activate');

statement ok
PRAGMA refresh('watch_history');

statement ok
PRAGMA refresh('watch_state');

query I
SELECT count(*) FROM (
    WITH s1 AS (
        SELECT
            customer_id,
            symbol,
            company_id,
            company_name,
            CASE action_type WHEN 'Activate' THEN event_ts ELSE NULL END AS placed_timestamp,
            CASE action_type WHEN 'Cancelled' THEN event_ts ELSE NULL END AS removed_timestamp
        FROM dl.watch_history
    )
    SELECT
        customer_id,
        symbol,
        company_id,
        company_name,
        MIN(placed_timestamp) AS placed_timestamp,
        MAX(removed_timestamp) AS removed_timestamp,
        CASE WHEN MAX(removed_timestamp) IS NULL THEN 'Active' ELSE 'Inactive' END AS watch_status
    FROM s1
    GROUP BY customer_id, symbol, company_id, company_name
    EXCEPT ALL
    SELECT customer_id, symbol, company_id, company_name, placed_timestamp, removed_timestamp, watch_status FROM dl.watch_state
);
----
0

query I
SELECT count(*) FROM (
    SELECT customer_id, symbol, company_id, company_name, placed_timestamp, removed_timestamp, watch_status FROM dl.watch_state
    EXCEPT ALL
    SELECT * FROM (
        WITH s1 AS (
            SELECT
                customer_id,
                symbol,
                company_id,
                company_name,
                CASE action_type WHEN 'Activate' THEN event_ts ELSE NULL END AS placed_timestamp,
                CASE action_type WHEN 'Cancelled' THEN event_ts ELSE NULL END AS removed_timestamp
            FROM dl.watch_history
        )
        SELECT
            customer_id,
            symbol,
            company_id,
            company_name,
            MIN(placed_timestamp) AS placed_timestamp,
            MAX(removed_timestamp) AS removed_timestamp,
            CASE WHEN MAX(removed_timestamp) IS NULL THEN 'Active' ELSE 'Inactive' END AS watch_status
        FROM s1
        GROUP BY customer_id, symbol, company_id, company_name
    )
);
----
0

# ==========================================
# Stress test: batch many conflicting DML ops
# before a single refresh
# ==========================================

statement ok
CREATE TABLE dl.stress (id INT, grp VARCHAR, val INT);

statement ok
INSERT INTO dl.stress VALUES
    (1, 'a', 10), (2, 'a', 20), (3, 'b', 30),
    (4, 'b', 40), (5, 'c', 50), (6, 'c', 60);

statement ok
CREATE MATERIALIZED VIEW dl.stress_agg AS
    SELECT grp, SUM(val) AS total, COUNT(*) AS cnt
    FROM dl.stress GROUP BY grp;

# Verify initial state
query I
SELECT count(*) FROM (
    SELECT grp, SUM(val) AS total, COUNT(*) AS cnt FROM dl.stress GROUP BY grp
    EXCEPT ALL SELECT grp, total, cnt FROM dl.stress_agg
);
----
0

