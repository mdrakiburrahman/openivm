# ==========================================
# COUNT(*) ungrouped (simple/scalar aggregate)
# ==========================================

statement ok
CREATE TABLE dl.counter (id INT, val INT);

statement ok
INSERT INTO dl.counter VALUES (1, 10), (2, 20), (3, 30);

statement ok
CREATE MATERIALIZED VIEW dl.mv_counter AS SELECT COUNT(*) as cnt FROM dl.counter;

query I
SELECT cnt FROM dl.mv_counter;
----
3

statement ok
INSERT INTO dl.counter VALUES (4, 40), (5, 50);

statement ok
PRAGMA refresh('mv_counter');

query I
SELECT cnt FROM dl.mv_counter;
----
5

# Cross-check
query I
SELECT count(*) FROM (SELECT COUNT(*) as cnt FROM dl.counter EXCEPT ALL SELECT cnt FROM dl.mv_counter);
----
0

# Delete some rows
statement ok
DELETE FROM dl.counter WHERE id <= 2;

statement ok
PRAGMA refresh('mv_counter');

query I
SELECT cnt FROM dl.mv_counter;
----
3

query I
SELECT count(*) FROM (SELECT COUNT(*) as cnt FROM dl.counter EXCEPT ALL SELECT cnt FROM dl.mv_counter);
----
0

# ==========================================
# Group recompute with repeated source table
# ==========================================

statement ok
CREATE TABLE dl.market (
    dm_date DATE,
    dm_s_symb VARCHAR,
    dm_close DOUBLE,
    dm_high DOUBLE,
    dm_low DOUBLE,
    dm_vol BIGINT
);

statement ok
INSERT INTO dl.market VALUES
    (DATE '2020-01-01', 'A', 10, 11, 9, 100),
    (DATE '2020-01-02', 'A', 12, 13, 8, 200),
    (DATE '2020-01-03', 'A', 11, 14, 10, 150);

statement ok
CREATE MATERIALIZED VIEW dl.market_rollup AS
    WITH s1 AS (
        SELECT
            a.dm_date,
            a.dm_s_symb,
            a.dm_close,
            a.dm_high,
            a.dm_low,
            a.dm_vol,
            MIN(b.dm_low) AS fifty_two_week_low,
            MAX(b.dm_high) AS fifty_two_week_high
        FROM dl.market a
        JOIN dl.market b
            ON a.dm_s_symb = b.dm_s_symb
            AND b.dm_date BETWEEN a.dm_date - INTERVAL '12' MONTH AND a.dm_date
        GROUP BY a.dm_date, a.dm_s_symb, a.dm_close, a.dm_high, a.dm_low, a.dm_vol
    )
    SELECT
        a.dm_date,
        a.dm_s_symb,
        a.dm_close,
        a.dm_high,
        a.dm_low,
        a.dm_vol,
        a.fifty_two_week_low,
        a.fifty_two_week_high,
        MIN(b.dm_date) AS fifty_two_week_low_date,
        MIN(c.dm_date) AS fifty_two_week_high_date
    FROM s1 a
    JOIN dl.market b
        ON a.dm_s_symb = b.dm_s_symb
        AND a.fifty_two_week_low = b.dm_low
        AND b.dm_date BETWEEN a.dm_date - INTERVAL '12' MONTH AND a.dm_date
    JOIN dl.market c
        ON a.dm_s_symb = c.dm_s_symb
        AND a.fifty_two_week_high = c.dm_high
        AND c.dm_date BETWEEN a.dm_date - INTERVAL '12' MONTH AND a.dm_date
    GROUP BY
        a.dm_date,
        a.dm_s_symb,
        a.dm_close,
        a.dm_high,
        a.dm_low,
        a.dm_vol,
        a.fifty_two_week_low,
        a.fifty_two_week_high;

statement ok
INSERT INTO dl.market VALUES (DATE '2019-12-31', 'A', 9, 21, 1, 50);

statement ok
PRAGMA refresh('market_rollup');

query I
WITH expected AS (
    WITH s1 AS (
        SELECT
            a.dm_date,
            a.dm_s_symb,
            a.dm_close,
            a.dm_high,
            a.dm_low,
            a.dm_vol,
            MIN(b.dm_low) AS fifty_two_week_low,
            MAX(b.dm_high) AS fifty_two_week_high
        FROM dl.market a
        JOIN dl.market b
            ON a.dm_s_symb = b.dm_s_symb
            AND b.dm_date BETWEEN a.dm_date - INTERVAL '12' MONTH AND a.dm_date
        GROUP BY a.dm_date, a.dm_s_symb, a.dm_close, a.dm_high, a.dm_low, a.dm_vol
    )
    SELECT
        a.dm_date,
        a.dm_s_symb,
        a.dm_close,
        a.dm_high,
        a.dm_low,
        a.dm_vol,
        a.fifty_two_week_low,
        a.fifty_two_week_high,
        MIN(b.dm_date) AS fifty_two_week_low_date,
        MIN(c.dm_date) AS fifty_two_week_high_date
    FROM s1 a
    JOIN dl.market b
        ON a.dm_s_symb = b.dm_s_symb
        AND a.fifty_two_week_low = b.dm_low
        AND b.dm_date BETWEEN a.dm_date - INTERVAL '12' MONTH AND a.dm_date
    JOIN dl.market c
        ON a.dm_s_symb = c.dm_s_symb
        AND a.fifty_two_week_high = c.dm_high
        AND c.dm_date BETWEEN a.dm_date - INTERVAL '12' MONTH AND a.dm_date
    GROUP BY
        a.dm_date,
        a.dm_s_symb,
        a.dm_close,
        a.dm_high,
        a.dm_low,
        a.dm_vol,
        a.fifty_two_week_low,
        a.fifty_two_week_high
)
SELECT count(*) FROM (
    SELECT * FROM dl.market_rollup
    EXCEPT ALL
    SELECT * FROM expected
    UNION ALL
    SELECT * FROM expected
    EXCEPT ALL
    SELECT * FROM dl.market_rollup
);
----
0

# ==========================================
# Group recompute with MIN/MAX plus computed output
# ==========================================

statement ok
CREATE TABLE dl.watch_events (
    customer_id INT,
    symbol VARCHAR,
    company_id INT,
    company_name VARCHAR,
    event_ts TIMESTAMP,
    action_type VARCHAR
);

statement ok
INSERT INTO dl.watch_events VALUES
    (1, 'AAA', NULL, NULL, TIMESTAMP '2026-01-01 10:00:00', 'Activate'),
    (2, 'BBB', 10, 'Beta', TIMESTAMP '2026-01-01 11:00:00', 'Activate');

statement ok
CREATE MATERIALIZED VIEW dl.watch_history AS
    SELECT customer_id, symbol, company_id, company_name, event_ts, action_type FROM dl.watch_events;

statement ok
CREATE MATERIALIZED VIEW dl.watch_state AS
    WITH s1 AS (
        SELECT
            customer_id,
            symbol,
            company_id,
            company_name,
            CASE action_type WHEN 'Activate' THEN event_ts ELSE NULL END AS placed_timestamp,
            CASE action_type WHEN 'Cancelled' THEN event_ts ELSE NULL END AS removed_timestamp
        FROM dl.watch_history
    )
    SELECT
        customer_id,
        symbol,
        company_id,
        company_name,
        MIN(placed_timestamp) AS placed_timestamp,
        MAX(removed_timestamp) AS removed_timestamp,
        CASE WHEN MAX(removed_timestamp) IS NULL THEN 'Active' ELSE 'Inactive' END AS watch_status
    FROM s1
    GROUP BY customer_id, symbol, company_id, company_name;

statement ok
INSERT INTO dl.watch_events VALUES
    (1, 'AAA', NULL, NULL, TIMESTAMP '2026-01-02 10:00:00', 'Cancelled'),
    (3, 'CCC', NULL, NULL, TIMESTAMP '2026-01-02 12:00:00', 'Activate');

statement ok
PRAGMA refresh('watch_history');

statement ok
PRAGMA refresh('watch_state');

query I
SELECT count(*) FROM (
    WITH s1 AS (
        SELECT
            customer_id,
            symbol,
            company_id,
            company_name,
            CASE action_type WHEN 'Activate' THEN event_ts ELSE NULL END AS placed_timestamp,
            CASE action_type WHEN 'Cancelled' THEN event_ts ELSE NULL END AS removed_timestamp
        FROM dl.watch_history
    )
    SELECT
        customer_id,
        symbol,
        company_id,
        company_name,
        MIN(placed_timestamp) AS placed_timestamp,
        MAX(removed_timestamp) AS removed_timestamp,
        CASE WHEN MAX(removed_timestamp) IS NULL THEN 'Active' ELSE 'Inactive' END AS watch_status
    FROM s1
    GROUP BY customer_id, symbol, company_id, company_name
    EXCEPT ALL
    SELECT customer_id, symbol, company_id, company_name, placed_timestamp, removed_timestamp, watch_status FROM dl.watch_state
);
----
0

query I
SELECT count(*) FROM (
    SELECT customer_id, symbol, company_id, company_name, placed_timestamp, removed_timestamp, watch_status FROM dl.watch_state
    EXCEPT ALL
    SELECT * FROM (
        WITH s1 AS (
            SELECT
                customer_id,
                symbol,
                company_id,
                company_name,
                CASE action_type WHEN 'Activate' THEN event_ts ELSE NULL END AS placed_timestamp,
                CASE action_type WHEN 'Cancelled' THEN event_ts ELSE NULL END AS removed_timestamp
            FROM dl.watch_history
        )
        SELECT
            customer_id,
            symbol,
            company_id,
            company_name,
            MIN(placed_timestamp) AS placed_timestamp,
            MAX(removed_timestamp) AS removed_timestamp,
            CASE WHEN MAX(removed_timestamp) IS NULL THEN 'Active' ELSE 'Inactive' END AS watch_status
        FROM s1
        GROUP BY customer_id, symbol, company_id, company_name
    )
);
----
0

# ==========================================
# Stress test: batch many conflicting DML ops
# before a single refresh
# ==========================================

statement ok
CREATE TABLE dl.stress (id INT, grp VARCHAR, val INT);

statement ok
INSERT INTO dl.stress VALUES
    (1, 'a', 10), (2, 'a', 20), (3, 'b', 30),
    (4, 'b', 40), (5, 'c', 50), (6, 'c', 60);

statement ok
CREATE MATERIALIZED VIEW dl.stress_agg AS
    SELECT grp, SUM(val) AS total, COUNT(*) AS cnt
    FROM dl.stress GROUP BY grp;

# Verify initial state
query I
SELECT count(*) FROM (
    SELECT grp, SUM(val) AS total, COUNT(*) AS cnt FROM dl.stress GROUP BY grp
    EXCEPT ALL SELECT grp, total, cnt FROM dl.stress_agg
);
----
0

# Batch conflicting ops: insert + delete + update on overlapping rows
# All before a single refresh
statement ok
INSERT INTO dl.stress VALUES (7, 'a', 100), (8, 'd', 200);

statement ok
DELETE FROM dl.stress WHERE id = 2;

statement ok
UPDATE dl.stress SET val = 999 WHERE id = 3;

statement ok
INSERT INTO dl.stress VALUES (9, 'b', 5), (10, 'b', 5);

statement ok
DELETE FROM dl.stress WHERE id = 5;

statement ok
UPDATE dl.stress SET grp = 'a' WHERE id = 4;

statement ok
INSERT INTO dl.stress VALUES (11, 'c', 1);

statement ok
DELETE FROM dl.stress WHERE id = 8;

# Single refresh after all the batched DML
statement ok
PRAGMA refresh('stress_agg');

query I
SELECT count(*) FROM (
    SELECT grp, SUM(val) AS total, COUNT(*) AS cnt FROM dl.stress GROUP BY grp
    EXCEPT ALL SELECT grp, total, cnt FROM dl.stress_agg
);
----
0

query I
SELECT count(*) FROM (
    SELECT grp, total, cnt FROM dl.stress_agg
    EXCEPT ALL SELECT grp, SUM(val) AS total, COUNT(*) AS cnt FROM dl.stress GROUP BY grp
);
----
0

# Second round of stress: more conflicting ops on the same table
statement ok
DELETE FROM dl.stress WHERE grp = 'b';

statement ok
INSERT INTO dl.stress VALUES (12, 'e', 500), (13, 'e', 500);

statement ok
UPDATE dl.stress SET val = 0 WHERE grp = 'a';

statement ok
INSERT INTO dl.stress VALUES (14, 'a', 1);

statement ok
DELETE FROM dl.stress WHERE id = 11;

# Single refresh
statement ok
PRAGMA refresh('stress_agg');

query I
SELECT count(*) FROM (
    SELECT grp, SUM(val) AS total, COUNT(*) AS cnt FROM dl.stress GROUP BY grp
    EXCEPT ALL SELECT grp, total, cnt FROM dl.stress_agg
);
----
0

query I
SELECT count(*) FROM (
    SELECT grp, total, cnt FROM dl.stress_agg
    EXCEPT ALL SELECT grp, SUM(val) AS total, COUNT(*) AS cnt FROM dl.stress GROUP BY grp
);
----
0

# ==========================================
# Aggregate top-k: GROUP BY + ORDER BY + LIMIT
# ==========================================

statement ok
CREATE TABLE dl.topk_sales (id INT, product VARCHAR, revenue INT);

statement ok
INSERT INTO dl.topk_sales VALUES
    (1,'apple',300),(2,'banana',150),(3,'cherry',500),
    (4,'date',80),(5,'elderberry',420);

statement ok
CREATE MATERIALIZED VIEW dl.topk_sales_mv AS
    SELECT product, SUM(revenue) AS total
    FROM dl.topk_sales GROUP BY product
    ORDER BY total DESC LIMIT 3;

statement ok
PRAGMA refresh('topk_sales_mv');

query I
SELECT COUNT(*) FROM (
    SELECT product, total FROM dl.topk_sales_mv
    EXCEPT ALL
    SELECT * FROM (SELECT product, SUM(revenue) AS total FROM dl.topk_sales GROUP BY product ORDER BY total DESC LIMIT 3) _q
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM (SELECT product, SUM(revenue) AS total FROM dl.topk_sales GROUP BY product ORDER BY total DESC LIMIT 3) _q
    EXCEPT ALL
    SELECT product, total FROM dl.topk_sales_mv
);
----
0

# ==========================================
# Scalar aggregate subquery in HAVING
# ==========================================

statement ok
CREATE TABLE dl.hav_line (w INTEGER, o INTEGER, d INTEGER, amount DOUBLE);

statement ok
CREATE TABLE dl.hav_order (w INTEGER, o INTEGER, d INTEGER, c INTEGER);

statement ok
CREATE TABLE dl.hav_customer (w INTEGER, d INTEGER, c INTEGER, last_name VARCHAR);

statement ok
INSERT INTO dl.hav_line VALUES
    (1, 1, 1, 10), (1, 1, 1, 12),
    (1, 2, 1, 200), (1, 2, 1, 220),
    (2, 1, 1, 5);

statement ok
INSERT INTO dl.hav_order VALUES (1, 1, 1, 10), (1, 2, 1, 11), (2, 1, 1, 12);

statement ok
INSERT INTO dl.hav_customer VALUES (1, 1, 10, 'Able'), (1, 1, 11, 'Baker'), (2, 1, 12, 'Cross');

statement ok
CREATE MATERIALIZED VIEW dl.mv_hav_scalar AS
    WITH high_value AS (
        SELECT w, o, d
        FROM dl.hav_line
        GROUP BY w, o, d
        HAVING SUM(amount) > (SELECT AVG(amount) * 2 FROM dl.hav_line)
    )
    SELECT hv.w, hv.d, hv.o, c.last_name
    FROM high_value hv
    JOIN dl.hav_order o ON hv.w = o.w AND hv.d = o.d AND hv.o = o.o
    JOIN dl.hav_customer c ON o.w = c.w AND o.d = c.d AND o.c = c.c;

query I
SELECT type FROM openivm_views WHERE view_name = 'mv_hav_scalar';
----
6

statement ok
INSERT INTO dl.hav_line VALUES (1, 3, 1, 500);

statement ok
INSERT INTO dl.hav_order VALUES (1, 3, 1, 13);

statement ok
INSERT INTO dl.hav_customer VALUES (1, 1, 13, 'Delta');

statement ok
PRAGMA refresh('mv_hav_scalar');

query I
SELECT COUNT(*) FROM (
    SELECT w, d, o, last_name FROM dl.mv_hav_scalar
    EXCEPT ALL
    SELECT * FROM (WITH high_value AS (
        SELECT w, o, d
        FROM dl.hav_line
        GROUP BY w, o, d
        HAVING SUM(amount) > (SELECT AVG(amount) * 2 FROM dl.hav_line)
    )
    SELECT hv.w, hv.d, hv.o, c.last_name
    FROM high_value hv
    JOIN dl.hav_order o ON hv.w = o.w AND hv.d = o.d AND hv.o = o.o
    JOIN dl.hav_customer c ON o.w = c.w AND o.d = c.d AND o.c = c.c
    ) _q
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM (WITH high_value AS (
        SELECT w, o, d
        FROM dl.hav_line
        GROUP BY w, o, d
        HAVING SUM(amount) > (SELECT AVG(amount) * 2 FROM dl.hav_line)
    )
    SELECT hv.w, hv.d, hv.o, c.last_name
    FROM high_value hv
    JOIN dl.hav_order o ON hv.w = o.w AND hv.d = o.d AND hv.o = o.o
    JOIN dl.hav_customer c ON o.w = c.w AND o.d = c.d AND o.c = c.c
    ) _q
    EXCEPT ALL
    SELECT w, d, o, last_name FROM dl.mv_hav_scalar
);
----
0

# ==========================================
# DuckLake GROUP_RECOMPUTE: COUNT(DISTINCT) over join
# ==========================================

statement ok
CREATE TABLE dl.gr_items (id INTEGER, category VARCHAR);

statement ok
CREATE TABLE dl.gr_sales (item_id INTEGER, qty INTEGER);

statement ok
INSERT INTO dl.gr_items VALUES (1, 'hardware'), (2, 'hardware'), (3, 'office');

statement ok
INSERT INTO dl.gr_sales VALUES (1, 5), (1, 7), (2, 10), (3, 4);

statement ok
CREATE MATERIALIZED VIEW dl.mv_gr_distinct AS
    SELECT i.category, COUNT(DISTINCT i.id) AS item_count, SUM(s.qty) AS total_qty
    FROM dl.gr_items i
    JOIN dl.gr_sales s ON i.id = s.item_id
    GROUP BY i.category;

query I
SELECT type FROM openivm_views WHERE view_name = 'mv_gr_distinct';
----
6

statement ok
INSERT INTO dl.gr_items VALUES (4, 'office');

statement ok
INSERT INTO dl.gr_sales VALUES (4, 20), (2, 1);

statement ok
DELETE FROM dl.gr_sales WHERE item_id = 1 AND qty = 5;

statement ok
SET openivm_files_path='__TEST_DIR__';

statement ok
PRAGMA refresh('mv_gr_distinct');

query I
SELECT contains(content, 'CREATE OR REPLACE TEMP TABLE openivm_affected_mv_gr_distinct')
FROM read_text('__TEST_DIR__/openivm_upsert_queries_mv_gr_distinct.sql');
----
true

query I
SELECT COUNT(*) FROM (
    SELECT category, item_count, total_qty FROM dl.mv_gr_distinct
    EXCEPT ALL
    SELECT i.category, COUNT(DISTINCT i.id), SUM(s.qty)
    FROM dl.gr_items i
    JOIN dl.gr_sales s ON i.id = s.item_id
    GROUP BY i.category
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT i.category, COUNT(DISTINCT i.id), SUM(s.qty)
    FROM dl.gr_items i
    JOIN dl.gr_sales s ON i.id = s.item_id
    GROUP BY i.category
    EXCEPT ALL
    SELECT category, item_count, total_qty FROM dl.mv_gr_distinct
);
----
0

