# SQLite-backed DuckLake metadata must not lock during OpenIVM refresh.
statement ok
ATTACH 'ducklake:sqlite:__TEST_DIR__/openivm_poc_meta.db' AS dlsql
  (DATA_PATH '__TEST_DIR__/openivm_poc_data');

statement ok
CREATE TABLE dlsql.lock_t(i INT);

statement ok
INSERT INTO dlsql.lock_t VALUES (1);

statement ok
CREATE MATERIALIZED VIEW dlsql.lock_mv AS
SELECT COUNT(*) AS c FROM dlsql.lock_t;

statement ok
INSERT INTO dlsql.lock_t VALUES (2), (3);

statement ok
PRAGMA refresh('lock_mv');

query I
SELECT COUNT(*) FROM (
    SELECT c FROM dlsql.lock_mv
    EXCEPT ALL
    SELECT COUNT(*) AS c FROM dlsql.lock_t
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT COUNT(*) AS c FROM dlsql.lock_t
    EXCEPT ALL
    SELECT c FROM dlsql.lock_mv
);
----
0
