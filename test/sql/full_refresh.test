# name: test/sql/full_refresh.test
# description: Test that unsupported operators correctly use full refresh
# group: [sql]

require openivm

statement ok
SET openivm_cascade_refresh = 'off';

# ============================================================
# Setup
# ============================================================

statement ok
CREATE TABLE t1 (a INT, b INT);

statement ok
CREATE TABLE t2 (a INT, c INT);

statement ok
INSERT INTO t1 VALUES (1, 10), (2, 20), (3, 30);

statement ok
INSERT INTO t2 VALUES (1, 100), (2, 200);

# ============================================================
# LEFT JOIN — full refresh
# ============================================================

statement ok
CREATE MATERIALIZED VIEW mv_left AS SELECT t1.a, t1.b, t2.c FROM t1 LEFT JOIN t2 ON t1.a = t2.a;

statement ok
INSERT INTO t1 VALUES (4, 40);

statement ok
INSERT INTO t2 VALUES (3, 300);

statement ok
PRAGMA refresh('mv_left');

query I
SELECT COUNT(*) FROM (
    SELECT t1.a, t1.b, t2.c FROM t1 LEFT JOIN t2 ON t1.a = t2.a
    EXCEPT ALL
    SELECT a, b, c FROM mv_left
);
----
0

# ============================================================
# Constant UNNEST values are maintained incrementally
# ============================================================

statement ok
CREATE MATERIALIZED VIEW mv_unnest_values AS
SELECT unnest(['BC', 'GC']) AS credit_type;

query I
SELECT type FROM openivm_views WHERE view_name = 'mv_unnest_values';
----
2

statement ok
PRAGMA refresh('mv_unnest_values');

query I
SELECT COUNT(*) FROM (
    SELECT unnest(['BC', 'GC']) AS credit_type
    EXCEPT ALL
    SELECT credit_type FROM mv_unnest_values
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT credit_type FROM mv_unnest_values
    EXCEPT ALL
    SELECT unnest(['BC', 'GC']) AS credit_type
);
----
0

statement ok
CREATE MATERIALIZED VIEW mv_except_all AS
SELECT t1.a, t2.c FROM t1 LEFT JOIN t2 ON t1.a = t2.a
EXCEPT ALL
SELECT a, b FROM t1;

query I
SELECT type FROM openivm_views WHERE view_name = 'mv_except_all';
----
3

statement ok
INSERT INTO t1 VALUES (99, 100);

statement ok
PRAGMA refresh('mv_except_all');

query I
SELECT COUNT(*) FROM (
    (SELECT t1.a, t2.c FROM t1 LEFT JOIN t2 ON t1.a = t2.a
     EXCEPT ALL
     SELECT a, b FROM t1)
    EXCEPT ALL
    SELECT * FROM mv_except_all
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM mv_except_all
    EXCEPT ALL
    (SELECT t1.a, t2.c FROM t1 LEFT JOIN t2 ON t1.a = t2.a
     EXCEPT ALL
     SELECT a, b FROM t1)
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT a, b, c FROM mv_left
    EXCEPT ALL
    SELECT t1.a, t1.b, t2.c FROM t1 LEFT JOIN t2 ON t1.a = t2.a
);
----
0

# ============================================================
# STDDEV — full refresh
# ============================================================

statement ok
CREATE MATERIALIZED VIEW mv_stddev AS SELECT a, STDDEV(b) AS sd FROM t1 GROUP BY a;

statement ok
INSERT INTO t1 VALUES (1, 15);

statement ok
PRAGMA refresh('mv_stddev');

query I
SELECT COUNT(*) FROM (
    SELECT a, STDDEV(b) AS sd FROM t1 GROUP BY a
    EXCEPT ALL
    SELECT a, sd FROM mv_stddev
);
----
0

# ============================================================
# STRING_AGG — full refresh
# ============================================================

statement ok
CREATE MATERIALIZED VIEW mv_string_agg AS SELECT STRING_AGG(a::VARCHAR, ',') AS all_a FROM t1;

statement ok
INSERT INTO t1 VALUES (5, 50);

statement ok
PRAGMA refresh('mv_string_agg');

query I
SELECT COUNT(*) FROM (
    SELECT STRING_AGG(a::VARCHAR, ',') AS all_a FROM t1
    EXCEPT ALL
    SELECT all_a FROM mv_string_agg
);
----
0

# ============================================================
# CAST — transparent (incremental, not full refresh)
# ============================================================

statement ok
CREATE TABLE t3 (x INT, y DECIMAL(10,2));

statement ok
INSERT INTO t3 VALUES (1, 10.5), (2, 20.3);

statement ok
CREATE MATERIALIZED VIEW mv_cast AS SELECT x::VARCHAR AS x_str, y::INT AS y_int FROM t3;

statement ok
INSERT INTO t3 VALUES (3, 30.7);

statement ok
PRAGMA refresh('mv_cast');

query I
SELECT COUNT(*) FROM (
    SELECT x::VARCHAR AS x_str, y::INT AS y_int FROM t3
    EXCEPT ALL
    SELECT x_str, y_int FROM mv_cast
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT x_str, y_int FROM mv_cast
    EXCEPT ALL
    SELECT x::VARCHAR AS x_str, y::INT AS y_int FROM t3
);
----
0

# ============================================================
# Explicit PIVOT — lowered by DuckDB to filtered aggregates
# ============================================================

statement ok
CREATE TABLE pivot_src(region VARCHAR, metric VARCHAR, amount INT);

statement ok
INSERT INTO pivot_src VALUES
    ('north', 'cost', 4), ('north', 'sales', 10),
    ('south', 'sales', 7);

statement ok
CREATE MATERIALIZED VIEW mv_pivot AS
    SELECT * FROM (PIVOT pivot_src ON metric IN ('cost', 'sales') USING SUM(amount) GROUP BY region);

query I
SELECT type FROM openivm_views WHERE view_name = 'mv_pivot';
----
0

statement ok
INSERT INTO pivot_src VALUES ('south', 'cost', 3), ('north', 'sales', 2);

statement ok
PRAGMA refresh('mv_pivot');

query I
SELECT COUNT(*) FROM (
    SELECT * FROM mv_pivot
    EXCEPT ALL
    SELECT * FROM (PIVOT pivot_src ON metric IN ('cost', 'sales') USING SUM(amount) GROUP BY region)
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM (PIVOT pivot_src ON metric IN ('cost', 'sales') USING SUM(amount) GROUP BY region)
    EXCEPT ALL
    SELECT * FROM mv_pivot
);
----
0

# PIVOT over LEFT JOIN needs the hidden match-count column for incremental
# maintenance; LPTS must carry it through DuckDB's post-pivot projection stack.
statement ok
CREATE TABLE pivot_lj_item(i_id INT, i_im_id INT);

statement ok
CREATE TABLE pivot_lj_stock(s_i_id INT, s_w_id INT, s_qty INT);

statement ok
INSERT INTO pivot_lj_item VALUES (1, 10), (2, 20), (3, 30);

statement ok
INSERT INTO pivot_lj_stock VALUES
    (1, 1, 5), (1, 2, 7), (2, 1, 11);

statement ok
CREATE MATERIALIZED VIEW mv_pivot_lj AS
    SELECT * FROM (
        PIVOT (
            SELECT i.i_im_id, s.s_w_id, COALESCE(s.s_qty, 0) AS qty
            FROM pivot_lj_item i LEFT JOIN pivot_lj_stock s ON i.i_id = s.s_i_id
        ) ON s_w_id IN (1, 2, 3) USING SUM(qty) GROUP BY i_im_id
    ) p;

statement ok
INSERT INTO pivot_lj_stock VALUES (3, 3, 9), (1, 1, 2);

statement ok
DELETE FROM pivot_lj_stock WHERE s_i_id = 2 AND s_w_id = 1;

statement ok
PRAGMA refresh('mv_pivot_lj');

query I
SELECT COUNT(*) FROM (
    SELECT * FROM mv_pivot_lj
    EXCEPT ALL
    SELECT * FROM (
        PIVOT (
            SELECT i.i_im_id, s.s_w_id, COALESCE(s.s_qty, 0) AS qty
            FROM pivot_lj_item i LEFT JOIN pivot_lj_stock s ON i.i_id = s.s_i_id
        ) ON s_w_id IN (1, 2, 3) USING SUM(qty) GROUP BY i_im_id
    )
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM (
        PIVOT (
            SELECT i.i_im_id, s.s_w_id, COALESCE(s.s_qty, 0) AS qty
            FROM pivot_lj_item i LEFT JOIN pivot_lj_stock s ON i.i_id = s.s_i_id
        ) ON s_w_id IN (1, 2, 3) USING SUM(qty) GROUP BY i_im_id
    )
    EXCEPT ALL
    SELECT * FROM mv_pivot_lj
);
----
0

# ============================================================
# DELETE + full refresh — still correct
# ============================================================

statement ok
DELETE FROM t1 WHERE a = 1;

statement ok
PRAGMA refresh('mv_left');

query I
SELECT COUNT(*) FROM (
    SELECT t1.a, t1.b, t2.c FROM t1 LEFT JOIN t2 ON t1.a = t2.a
    EXCEPT ALL
    SELECT a, b, c FROM mv_left
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT a, b, c FROM mv_left
    EXCEPT ALL
    SELECT t1.a, t1.b, t2.c FROM t1 LEFT JOIN t2 ON t1.a = t2.a
);
----
0

# ============================================================
# Multiple full refreshes — idempotent
# ============================================================

statement ok
PRAGMA refresh('mv_left');

statement ok
PRAGMA refresh('mv_left');

query I
SELECT COUNT(*) FROM (
    SELECT t1.a, t1.b, t2.c FROM t1 LEFT JOIN t2 ON t1.a = t2.a
    EXCEPT ALL
    SELECT a, b, c FROM mv_left
);
----
0
