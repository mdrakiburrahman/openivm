statement ok
SET openivm_cascade_refresh = 'downstream';

statement ok
CREATE TABLE dl.window_upstream_src (
    acct_id INT,
    event_ts INT,
    amount INT
);

statement ok
CREATE MATERIALIZED VIEW dl.window_upstream_base AS
SELECT
    acct_id,
    event_ts,
    amount
FROM dl.window_upstream_src;

statement ok
CREATE MATERIALIZED VIEW dl.mv_window_upstream AS
SELECT
    acct_id,
    event_ts,
    SUM(amount) OVER (
        PARTITION BY acct_id
        ORDER BY event_ts DESC
        ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW
    ) AS running_amount
FROM dl.window_upstream_base;

query I
SELECT group_columns FROM openivm_views WHERE view_name = 'mv_window_upstream';
----
acct_id=acct_id

