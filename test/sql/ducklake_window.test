CREATE TABLE dl.window_join_events (
    acct_id INT,
    event_ts INT,
    code INT,
    amount INT
);

statement ok
CREATE TABLE dl.window_join_codes (
    code INT,
    label VARCHAR
);

statement ok
CREATE MATERIALIZED VIEW dl.mv_window_join AS
SELECT
    e.acct_id,
    e.event_ts,
    c.label,
    SUM(e.amount) OVER (
        PARTITION BY e.acct_id
        ORDER BY e.event_ts
        ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW
    ) AS running_amount
FROM dl.window_join_events e
LEFT JOIN dl.window_join_codes c
    ON e.code = c.code;

query I
SELECT group_columns FROM openivm_views WHERE view_name = 'mv_window_join';
