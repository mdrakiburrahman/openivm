CREATE TABLE dl.accounts_crm_src (
    ca_id INT,
    action_ts TIMESTAMP,
    action_type VARCHAR,
    nat_tax_id INT,
    lcl_tax_id INT,
    balance INT
);

statement ok
CREATE TABLE dl.accounts_tax_src (
    tax_id INT,
    tax_rate DECIMAL(6, 4)
);

statement ok
CREATE MATERIALIZED VIEW dl.accounts_crm AS
SELECT
    ca_id,
    action_ts,
    action_type,
    nat_tax_id,
    lcl_tax_id,
    balance
FROM dl.accounts_crm_src;

statement ok
CREATE MATERIALIZED VIEW dl.accounts_tax AS
SELECT
    tax_id,
    tax_rate
FROM dl.accounts_tax_src;

statement ok
CREATE MATERIALIZED VIEW dl.mv_accounts_like AS
SELECT
    c.ca_id AS account_id,
    c.action_ts AS start_timestamp,
    COALESCE(
        LAG(c.action_ts) OVER (PARTITION BY c.ca_id ORDER BY c.action_ts DESC) - INTERVAL 1 MILLISECOND,
        TIMESTAMP '9999-12-31 23:59:59.999'
    ) AS end_timestamp,
    CASE
        WHEN ROW_NUMBER() OVER (PARTITION BY c.ca_id ORDER BY c.action_ts DESC) = 1 THEN TRUE
        ELSE FALSE
    END AS is_current,
    c.action_type,
    c.balance,
    ntx.tax_rate AS nat_tax_rate,
    ltx.tax_rate AS lcl_tax_rate
FROM "dl"."main"."accounts_crm" c
LEFT JOIN "dl"."main"."accounts_tax" ntx
    ON c.nat_tax_id = ntx.tax_id
LEFT JOIN "dl"."main"."accounts_tax" ltx
    ON c.lcl_tax_id = ltx.tax_id
WHERE c.ca_id IS NOT NULL;

query I
SELECT group_columns FROM openivm_views WHERE view_name = 'mv_accounts_like';
