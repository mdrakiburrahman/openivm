);

statement ok
CREATE TABLE dl.cascade_accounts_tax_src (
    tax_id INT,
    tax_rate DECIMAL(6, 4)
);

statement ok
CREATE MATERIALIZED VIEW dl.cascade_accounts_crm AS
SELECT
    ca_id,
    action_ts,
    nat_tax_id,
    lcl_tax_id
FROM dl.cascade_accounts_crm_src;

statement ok
CREATE MATERIALIZED VIEW dl.cascade_accounts_tax AS
SELECT
    tax_id,
    tax_rate
FROM dl.cascade_accounts_tax_src;

statement ok
CREATE MATERIALIZED VIEW dl.mv_cascade_accounts_like AS
SELECT
    c.ca_id AS account_id,
    c.action_ts AS start_timestamp,
    COALESCE(
        LAG(c.action_ts) OVER (PARTITION BY c.ca_id ORDER BY c.action_ts DESC) - INTERVAL 1 MILLISECOND,
        TIMESTAMP '9999-12-31 23:59:59.999'
    ) AS end_timestamp,
    ntx.tax_rate AS nat_tax_rate,
    ltx.tax_rate AS lcl_tax_rate
FROM "dl"."main"."cascade_accounts_crm" c
LEFT JOIN "dl"."main"."cascade_accounts_tax" ntx
    ON c.nat_tax_id = ntx.tax_id
LEFT JOIN "dl"."main"."cascade_accounts_tax" ltx
    ON c.lcl_tax_id = ltx.tax_id
WHERE c.ca_id IS NOT NULL;

statement ok
INSERT INTO dl.cascade_accounts_tax_src VALUES
    (1, 0.0500),
    (2, 0.0750);

statement ok
INSERT INTO dl.cascade_accounts_crm_src VALUES
    (10, '2026-01-01 09:00:00', 1, 2),
    (20, '2026-01-01 10:00:00', 2, 1);

# Refresh one upstream parent first. This cascades into the downstream window
# MV before the other upstream parent has been refreshed; the later parent
# refresh must still recover the downstream MV.
statement ok
PRAGMA refresh('cascade_accounts_tax');

query I
SELECT count(*) FROM dl.mv_cascade_accounts_like;
----
0

