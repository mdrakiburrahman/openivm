statement ok
CREATE TABLE dl.trade_like (
    t_id INT,
    t_dts TIMESTAMP,
    t_status INT,
    t_type INT,
    t_qty INT
);

statement ok
CREATE TABLE dl.trade_history_like (
    th_t_id INT,
    th_dts TIMESTAMP,
    th_status INT
);

statement ok
CREATE TABLE dl.trade_status_like (
    status_id INT,
    status_name VARCHAR
);

statement ok
CREATE TABLE dl.trade_type_like (
    type_id INT,
    type_name VARCHAR
);

statement ok
CREATE MATERIALIZED VIEW dl.mv_trades_history_like AS
SELECT
    t_id AS trade_id,
    t_dts AS trade_timestamp,
    ts.status_name AS trade_status,
    tt.type_name AS trade_type,
    us.status_name AS update_status,
    th_dts AS effective_timestamp,
    COALESCE(
        LAG(th_dts) OVER (
            PARTITION BY t_id
            ORDER BY th_dts DESC, t_dts DESC, th_status DESC
        ) - INTERVAL 1 MILLISECOND,
        TIMESTAMP '9999-12-31 23:59:59.999'
    ) AS end_timestamp,
    CASE
        WHEN ROW_NUMBER() OVER (
            PARTITION BY t_id
            ORDER BY th_dts DESC, t_dts DESC, th_status DESC
        ) = 1 THEN TRUE
        ELSE FALSE
    END AS is_current
FROM dl.trade_like
JOIN dl.trade_history_like
    ON t_id = th_t_id
JOIN dl.trade_type_like tt
    ON t_type = tt.type_id
JOIN dl.trade_status_like ts
    ON t_status = ts.status_id
JOIN dl.trade_status_like us
    ON th_status = us.status_id;

