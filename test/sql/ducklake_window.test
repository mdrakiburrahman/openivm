        c.action_ts AS start_timestamp,
        COALESCE(
            LAG(c.action_ts) OVER (PARTITION BY c.ca_id ORDER BY c.action_ts DESC) - INTERVAL 1 MILLISECOND,
            TIMESTAMP '9999-12-31 23:59:59.999'
        ) AS end_timestamp,
        ntx.tax_rate AS nat_tax_rate,
        ltx.tax_rate AS lcl_tax_rate
    FROM dl.cascade_accounts_crm c
    LEFT JOIN dl.cascade_accounts_tax ntx
        ON c.nat_tax_id = ntx.tax_id
    LEFT JOIN dl.cascade_accounts_tax ltx
        ON c.lcl_tax_id = ltx.tax_id
    WHERE c.ca_id IS NOT NULL
);
