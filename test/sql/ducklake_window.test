query I
SELECT count(*) FROM (
    SELECT * FROM dl.mv_window_join
    EXCEPT ALL
    SELECT
        e.acct_id,
        e.event_ts,
        c.label,
        SUM(e.amount) OVER (
            PARTITION BY e.acct_id
            ORDER BY e.event_ts
            ROWS BETWEEN UNBOUNDED PRECEDING AND CURRENT ROW
        )
    FROM dl.window_join_events e
    LEFT JOIN dl.window_join_codes c
        ON e.code = c.code
);
