# name: test/sql/cascade_window_partition_delta.test
# description: WINDOW_PARTITION emits signed cascade deltas when facts.force_view_delta_cascade=true
# group: [sql]

require openivm

statement ok
SET openivm_files_path='__TEST_DIR__';

statement ok
CREATE TABLE cw_src (id INT, grp VARCHAR, val INT);

statement ok
INSERT INTO cw_src VALUES
    (1, 'a', 10),
    (2, 'a', 20),
    (3, 'b', 5),
    (4, 'b', 15);

statement ok
CREATE MATERIALIZED VIEW cw_mv AS
    SELECT id, grp, val, ROW_NUMBER() OVER (PARTITION BY grp ORDER BY val, id) AS rn
    FROM cw_src;

# ==========================================
# Compile-only: force_view_delta_cascade=false should emit the
# in-place WINDOW_PARTITION program (DELETE/INSERT on data,
# DELETE FROM openivm_delta_<base>) with no signed-cascade INSERT
# into openivm_delta_cw_mv.
# ==========================================

query IT
SELECT refresh_type, refresh_type_name
FROM openivm_compile_with_facts(
    'cw_mv',
    '{"target_dialect":"duckdb","compile_only":true,"force_view_delta_cascade":false}'
)
LIMIT 1;
----
5	WINDOW_PARTITION

query I
SELECT CASE WHEN
       string_agg(sql, ' ' ORDER BY stmt_order) LIKE '%DELETE FROM %openivm_data_cw_mv%'
   AND string_agg(sql, ' ' ORDER BY stmt_order) LIKE '%INSERT INTO %openivm_data_cw_mv%'
   AND string_agg(sql, ' ' ORDER BY stmt_order) LIKE '%DELETE FROM openivm_delta_cw_mv%'
   AND string_agg(sql, ' ' ORDER BY stmt_order) NOT LIKE '%INSERT INTO openivm_delta_cw_mv%'
   THEN 1 ELSE 0 END
FROM openivm_compile_with_facts(
    'cw_mv',
    '{"target_dialect":"duckdb","compile_only":true,"force_view_delta_cascade":false}'
)
WHERE stmt_kind = 'data';
----
1

# ==========================================
# Compile-only: force_view_delta_cascade=true must emit old/new temp
# tables and a signed INSERT INTO openivm_delta_cw_mv with both legs.
# ==========================================

query IT
SELECT refresh_type, refresh_type_name
FROM openivm_compile_with_facts(
    'cw_mv',
    '{"target_dialect":"duckdb","compile_only":true,"force_view_delta_cascade":true}'
)
LIMIT 1;
----
5	WINDOW_PARTITION

query I
SELECT CASE WHEN
       string_agg(sql, ' ' ORDER BY stmt_order) LIKE '%CREATE OR REPLACE TEMP TABLE openivm_old_cw_mv AS%'
   AND string_agg(sql, ' ' ORDER BY stmt_order) LIKE '%CREATE OR REPLACE TEMP TABLE openivm_new_cw_mv AS%'
   AND string_agg(sql, ' ' ORDER BY stmt_order) LIKE '%INSERT INTO openivm_delta_cw_mv%'
   AND string_agg(sql, ' ' ORDER BY stmt_order) LIKE '%CAST%-1%INTEGER%'
   AND string_agg(sql, ' ' ORDER BY stmt_order) LIKE '%UNION ALL%'
   AND string_agg(sql, ' ' ORDER BY stmt_order) LIKE '%CAST%1%INTEGER%'
   AND string_agg(sql, ' ' ORDER BY stmt_order) LIKE '%DROP TABLE IF EXISTS openivm_old_cw_mv%'
   AND string_agg(sql, ' ' ORDER BY stmt_order) LIKE '%DROP TABLE IF EXISTS openivm_new_cw_mv%'
   THEN 1 ELSE 0 END
FROM openivm_compile_with_facts(
    'cw_mv',
    '{"target_dialect":"duckdb","compile_only":true,"force_view_delta_cascade":true}'
)
WHERE stmt_kind = 'data';
----
1

# ==========================================
# Runtime correctness: PRAGMA refresh uses default CompileFacts (cascade
# off), so it still applies the in-place WINDOW_PARTITION program to
# openivm_data_cw_mv and the user-visible MV stays bidirectionally
# consistent with the base ROW_NUMBER query. Signed-delta emission into
# openivm_delta_cw_mv requires facts.force_view_delta_cascade=true and is
# covered by spark-ext integration tests.
# ==========================================

statement ok
INSERT INTO cw_src VALUES (5, 'a', 15);

statement ok
PRAGMA refresh('cw_mv');

query I
SELECT COUNT(*) FROM (
    SELECT * FROM openivm_data_cw_mv
    EXCEPT ALL
    SELECT id, grp, val, ROW_NUMBER() OVER (PARTITION BY grp ORDER BY val, id) AS rn FROM cw_src
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT id, grp, val, ROW_NUMBER() OVER (PARTITION BY grp ORDER BY val, id) AS rn FROM cw_src
    EXCEPT ALL
    SELECT * FROM openivm_data_cw_mv
);
----
0

statement ok
UPDATE cw_src SET val = 12 WHERE id = 2;

statement ok
PRAGMA refresh('cw_mv');

query I
SELECT COUNT(*) FROM (
    SELECT * FROM openivm_data_cw_mv
    EXCEPT ALL
    SELECT id, grp, val, ROW_NUMBER() OVER (PARTITION BY grp ORDER BY val, id) AS rn FROM cw_src
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT id, grp, val, ROW_NUMBER() OVER (PARTITION BY grp ORDER BY val, id) AS rn FROM cw_src
    EXCEPT ALL
    SELECT * FROM openivm_data_cw_mv
);
----
0

statement ok
DELETE FROM cw_src WHERE id = 1;

statement ok
PRAGMA refresh('cw_mv');

query I
SELECT COUNT(*) FROM (
    SELECT * FROM openivm_data_cw_mv
    EXCEPT ALL
    SELECT id, grp, val, ROW_NUMBER() OVER (PARTITION BY grp ORDER BY val, id) AS rn FROM cw_src
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT id, grp, val, ROW_NUMBER() OVER (PARTITION BY grp ORDER BY val, id) AS rn FROM cw_src
    EXCEPT ALL
    SELECT * FROM openivm_data_cw_mv
);
----
0
