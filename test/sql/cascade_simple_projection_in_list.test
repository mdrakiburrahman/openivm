               'K41', 'K42', 'K43', 'K44', 'K45', 'K46', 'K47', 'K48', 'K49', 'K50'
           ) AS in_bucket
    FROM cspl_in50_item;

statement ok
PRAGMA compile_refresh('cspl_in50_mv');

query I
SELECT CASE
           WHEN contains(content, 'INSERT INTO openivm_delta_cspl_in50_mv') AND
                contains(content, 'openivm_delta_cspl_in50_item') AND
                NOT contains(content, 'SELECT NULL::')
           THEN 1 ELSE 0
       END
FROM read_text('__TEST_DIR__/openivm_upsert_queries_cspl_in50_mv.sql');
----
1

