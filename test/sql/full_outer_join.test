# name: test/sql/full_outer_join.test
# description: Test IVM with FULL OUTER JOIN (Zhang & Larson bidirectional recompute)
# group: [sql]

require openivm

statement ok
SET openivm_cascade_refresh = 'off';

# ============================================================
# Setup
# ============================================================

statement ok
CREATE TABLE employees (id INT, name VARCHAR);

statement ok
CREATE TABLE projects (id INT, emp_id INT, title VARCHAR);

statement ok
INSERT INTO employees VALUES (1, 'Alice'), (2, 'Bob'), (3, 'Charlie');

statement ok
INSERT INTO projects VALUES (10, 1, 'Alpha'), (20, 1, 'Beta'), (30, 4, 'Gamma');

# ============================================================
# Basic FULL OUTER JOIN projection
# ============================================================

statement ok
CREATE MATERIALIZED VIEW emp_projects AS
    SELECT e.name, p.title
    FROM employees e FULL OUTER JOIN projects p ON e.id = p.emp_id;

# Initial: Alice matched (2 projects), Bob/Charlie unmatched-left, Gamma unmatched-right
query II
SELECT * FROM emp_projects ORDER BY name NULLS LAST, title NULLS LAST;
----
Alice	Alpha
Alice	Beta
Bob	NULL
Charlie	NULL
NULL	Gamma

# EXCEPT ALL both directions
query I
SELECT COUNT(*) FROM (
    SELECT e.name, p.title FROM employees e FULL OUTER JOIN projects p ON e.id = p.emp_id
    EXCEPT ALL
    SELECT * FROM emp_projects
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM emp_projects
    EXCEPT ALL
    SELECT e.name, p.title FROM employees e FULL OUTER JOIN projects p ON e.id = p.emp_id
);
----
0

# ============================================================
# Insert into right side: Bob gets a project (unmatched-left -> matched)
# ============================================================

statement ok
INSERT INTO projects VALUES (40, 2, 'Delta');

statement ok
PRAGMA refresh('emp_projects');

query I
SELECT COUNT(*) FROM (
    SELECT e.name, p.title FROM employees e FULL OUTER JOIN projects p ON e.id = p.emp_id
    EXCEPT ALL
    SELECT * FROM emp_projects
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM emp_projects
    EXCEPT ALL
    SELECT e.name, p.title FROM employees e FULL OUTER JOIN projects p ON e.id = p.emp_id
);
----
0

