# Insert into right side with no match: new unmatched-right row
# ============================================================

statement ok
INSERT INTO projects VALUES (50, 99, 'Epsilon');

statement ok
PRAGMA refresh('emp_projects');

query I
SELECT COUNT(*) FROM (
    SELECT e.name, p.title FROM employees e FULL OUTER JOIN projects p ON e.id = p.emp_id
    EXCEPT ALL
    SELECT * FROM emp_projects
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM emp_projects
    EXCEPT ALL
    SELECT e.name, p.title FROM employees e FULL OUTER JOIN projects p ON e.id = p.emp_id
);
----
0

