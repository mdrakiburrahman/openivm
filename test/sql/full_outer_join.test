# ============================================================
# Test: All 8 transitions in a single refresh
# {insert,delete} × {left,right} × {matched,unmatched}
# ============================================================

statement ok
CREATE TABLE trans_l (id INT, grp VARCHAR);

statement ok
CREATE TABLE trans_r (id INT, lid INT, val INT);

statement ok
INSERT INTO trans_l VALUES (1, 'A'), (2, 'B'), (3, 'C'), (4, 'D');

statement ok
INSERT INTO trans_r VALUES (1, 1, 10), (2, 2, 20), (3, 50, 30), (4, 60, 40);

statement ok
CREATE MATERIALIZED VIEW mv_trans AS
    SELECT l.grp, SUM(r.val) AS total, COUNT(r.val) AS cnt
    FROM trans_l l FULL OUTER JOIN trans_r r ON l.id = r.lid
    GROUP BY l.grp;

# 1. INSERT LEFT MATCHED: insert left id=50, matches right lid=50
# 2. INSERT LEFT UNMATCHED: insert left id=99, no right match
# 3. DELETE LEFT MATCHED: delete left id=1, right lid=1 becomes unmatched
# 4. DELETE LEFT UNMATCHED: delete left id=3, was unmatched-left
# 5. INSERT RIGHT MATCHED: insert right lid=2, adds to B
# 6. INSERT RIGHT UNMATCHED: insert right lid=200, no left match
# 7. DELETE RIGHT MATCHED: delete right lid=2 (id=2), B loses its match
# 8. DELETE RIGHT UNMATCHED: delete right lid=60 (id=4), shrinks NULL group
statement ok
INSERT INTO trans_l VALUES (50, 'E');

statement ok
INSERT INTO trans_l VALUES (99, 'Z');

statement ok
DELETE FROM trans_l WHERE id = 1;

statement ok
DELETE FROM trans_l WHERE id = 3;

statement ok
INSERT INTO trans_r VALUES (5, 2, 25);

statement ok
INSERT INTO trans_r VALUES (6, 200, 60);

statement ok
DELETE FROM trans_r WHERE id = 2;

statement ok
DELETE FROM trans_r WHERE id = 4;

statement ok
PRAGMA refresh('mv_trans');

query I
SELECT COUNT(*) FROM (
    SELECT l.grp, SUM(r.val), COUNT(r.val) FROM trans_l l FULL OUTER JOIN trans_r r ON l.id = r.lid GROUP BY l.grp
    EXCEPT ALL SELECT * FROM mv_trans
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM mv_trans EXCEPT ALL
    SELECT l.grp, SUM(r.val), COUNT(r.val) FROM trans_l l FULL OUTER JOIN trans_r r ON l.id = r.lid GROUP BY l.grp
);
----
0

# ============================================================
# Test: Large batch with many conflicting INSERT+DELETE
# ============================================================

statement ok
CREATE TABLE batch_l (id INT, grp VARCHAR);

statement ok
CREATE TABLE batch_r (id INT, lid INT, val INT);

statement ok
INSERT INTO batch_l VALUES (1, 'A'), (2, 'B'), (3, 'C'), (4, 'D'), (5, 'E');

statement ok
INSERT INTO batch_r VALUES (1, 1, 10), (2, 1, 20), (3, 2, 30), (4, 6, 40), (5, 7, 50);

statement ok
CREATE MATERIALIZED VIEW mv_batch AS
    SELECT l.grp, SUM(r.val) AS total, COUNT(r.val) AS cnt
    FROM batch_l l FULL OUTER JOIN batch_r r ON l.id = r.lid
    GROUP BY l.grp;

# Batch: many conflicting ops
statement ok
DELETE FROM batch_r WHERE lid = 1;

statement ok
