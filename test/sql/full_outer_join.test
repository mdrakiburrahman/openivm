statement ok
CREATE MATERIALIZED VIEW mv_empty AS
    SELECT l.grp, SUM(r.val) AS total, COUNT(r.val) AS cnt
    FROM empty_l l FULL OUTER JOIN empty_r r ON l.id = r.lid
    GROUP BY l.grp;

query I
SELECT COUNT(*) FROM (
    SELECT l.grp, SUM(r.val), COUNT(r.val) FROM empty_l l FULL OUTER JOIN empty_r r ON l.id = r.lid GROUP BY l.grp
    EXCEPT ALL SELECT * FROM mv_empty
);
