# ============================================================
# MERGE mode: Zhang & Larson incremental MERGE (openivm_full_outer_merge)
# ============================================================

statement ok
SET openivm_full_outer_merge = true;

statement ok
CREATE TABLE items (id INT, category VARCHAR);

statement ok
CREATE TABLE sales (id INT, item_id INT, amount INT);

statement ok
INSERT INTO items VALUES (1, 'A'), (2, 'B'), (3, 'C');

statement ok
INSERT INTO sales VALUES (1, 1, 100), (2, 1, 200), (3, 5, 300);

statement ok
CREATE MATERIALIZED VIEW cat_sales AS
    SELECT i.category, SUM(s.amount) AS total, COUNT(s.amount) AS cnt
    FROM items i FULL OUTER JOIN sales s ON i.id = s.item_id
    GROUP BY i.category;

# Initial check
query I
SELECT COUNT(*) FROM (
    SELECT i.category, SUM(s.amount), COUNT(s.amount) FROM items i FULL OUTER JOIN sales s ON i.id = s.item_id GROUP BY i.category
    EXCEPT ALL
    SELECT * FROM cat_sales
);
----
0

# --- MERGE: insert sale matching B (unmatched-left → matched) ---
statement ok
INSERT INTO sales VALUES (4, 2, 150);

statement ok
PRAGMA refresh('cat_sales');

query I
SELECT COUNT(*) FROM (
    SELECT i.category, SUM(s.amount), COUNT(s.amount) FROM items i FULL OUTER JOIN sales s ON i.id = s.item_id GROUP BY i.category
    EXCEPT ALL
    SELECT * FROM cat_sales
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM cat_sales
    EXCEPT ALL
    SELECT i.category, SUM(s.amount), COUNT(s.amount) FROM items i FULL OUTER JOIN sales s ON i.id = s.item_id GROUP BY i.category
);
----
0

