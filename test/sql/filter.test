# name: test/sql/filter.test
# description: Test IVM with filters
# group: [sql]

require openivm

statement ok
CREATE TABLE products (id INT, name VARCHAR, price INT, category VARCHAR);

statement ok
INSERT INTO products VALUES (1, 'Widget', 10, 'A'), (2, 'Gadget', 25, 'B'), (3, 'Doohickey', 5, 'A');

statement ok
create materialized view cheap_products as (select id, name, price from products where price < 20);

query III
SELECT id, name, price FROM cheap_products ORDER BY id;
----
1	Widget	10
3	Doohickey	5

# --- Insert: matching filter ---
statement ok
INSERT INTO products VALUES (4, 'Thingamajig', 8, 'A');

statement ok
pragma refresh('cheap_products');

query III
SELECT id, name, price FROM cheap_products ORDER BY id;
----
1	Widget	10
3	Doohickey	5
4	Thingamajig	8

# --- Insert: NOT matching filter (price >= 20) ---
statement ok
INSERT INTO products VALUES (5, 'Expensive', 50, 'B');

statement ok
pragma refresh('cheap_products');

# MV unchanged (filtered out)
query III
SELECT id, name, price FROM cheap_products ORDER BY id;
----
1	Widget	10
3	Doohickey	5
4	Thingamajig	8

# --- Delete: row that was in the view ---
statement ok
DELETE FROM products WHERE id = 1;

statement ok
pragma refresh('cheap_products');

query III
SELECT id, name, price FROM cheap_products ORDER BY id;
----
3	Doohickey	5
4	Thingamajig	8

# --- No-op PRAGMA ---
statement ok
pragma refresh('cheap_products');

query III
SELECT id, name, price FROM cheap_products ORDER BY id;
----
3	Doohickey	5
4	Thingamajig	8

# --- Insert at the boundary (price = 19, just under filter) ---
statement ok
INSERT INTO products VALUES (6, 'Boundary', 19, 'C');

statement ok
pragma refresh('cheap_products');

query III
SELECT id, name, price FROM cheap_products ORDER BY id;
----
3	Doohickey	5
4	Thingamajig	8
6	Boundary	19

# --- Insert at the boundary (price = 20, NOT matching filter) ---
statement ok
INSERT INTO products VALUES (7, 'TooExpensive', 20, 'C');

statement ok
pragma refresh('cheap_products');

query III
SELECT id, name, price FROM cheap_products ORDER BY id;
----
3	Doohickey	5
4	Thingamajig	8
6	Boundary	19

# --- Mixed insert + delete ---
statement ok
INSERT INTO products VALUES (8, 'Cheap', 1, 'A');

statement ok
DELETE FROM products WHERE id = 3;

statement ok
pragma refresh('cheap_products');

query III
SELECT id, name, price FROM cheap_products ORDER BY id;
----
4	Thingamajig	8
6	Boundary	19
8	Cheap	1

# --- Delete row not in MV (should be no-op for MV) ---
statement ok
DELETE FROM products WHERE id = 5;

statement ok
pragma refresh('cheap_products');

query III
SELECT id, name, price FROM cheap_products ORDER BY id;
----
4	Thingamajig	8
6	Boundary	19
8	Cheap	1

# ==========================================
# NULL in WHERE predicate columns
# ==========================================

statement ok
CREATE TABLE filt_null (id INT, price INT, active BOOLEAN);

statement ok
INSERT INTO filt_null VALUES (1, 10, true), (2, NULL, true), (3, 20, NULL), (4, 15, false);

statement ok
CREATE MATERIALIZED VIEW mv_filt_null AS
    SELECT id, price FROM filt_null WHERE price > 5 AND active = true;

statement ok
PRAGMA refresh('mv_filt_null');

# Cross-check after initial load — only id=1 matches (price=10, active=true)
query I
SELECT COUNT(*) FROM (
    SELECT id, price FROM filt_null WHERE price > 5 AND active = true
    EXCEPT ALL
    SELECT id, price FROM mv_filt_null
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT id, price FROM mv_filt_null
    EXCEPT ALL
    SELECT id, price FROM filt_null WHERE price > 5 AND active = true
);
----
0

# UPDATE: set price = NULL where id = 1 — id=1 removed from MV
statement ok
UPDATE filt_null SET price = NULL WHERE id = 1;

statement ok
PRAGMA refresh('mv_filt_null');

query I
SELECT COUNT(*) FROM (
    SELECT id, price FROM filt_null WHERE price > 5 AND active = true
    EXCEPT ALL
    SELECT id, price FROM mv_filt_null
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT id, price FROM mv_filt_null
    EXCEPT ALL
    SELECT id, price FROM filt_null WHERE price > 5 AND active = true
);
----
0

# UPDATE: set active = true where id = 4 — id=4 (price=15) now matches filter
statement ok
UPDATE filt_null SET active = true WHERE id = 4;

statement ok
PRAGMA refresh('mv_filt_null');

query I
SELECT COUNT(*) FROM (
    SELECT id, price FROM filt_null WHERE price > 5 AND active = true
    EXCEPT ALL
    SELECT id, price FROM mv_filt_null
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT id, price FROM mv_filt_null
    EXCEPT ALL
    SELECT id, price FROM filt_null WHERE price > 5 AND active = true
);
----
0

# INSERT: (5, NULL, true) — no match (NULL price), (6, 100, NULL) — no match (NULL active)
statement ok
INSERT INTO filt_null VALUES (5, NULL, true), (6, 100, NULL);

statement ok
PRAGMA refresh('mv_filt_null');

query I
SELECT COUNT(*) FROM (
    SELECT id, price FROM filt_null WHERE price > 5 AND active = true
    EXCEPT ALL
    SELECT id, price FROM mv_filt_null
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT id, price FROM mv_filt_null
    EXCEPT ALL
    SELECT id, price FROM filt_null WHERE price > 5 AND active = true
);
----
0

# ==========================================
# Bulk insert where most rows don't match filter
# ==========================================

statement ok
CREATE TABLE filt_bulk (id INT, val INT);

statement ok
INSERT INTO filt_bulk VALUES (1, 100);

statement ok
CREATE MATERIALIZED VIEW mv_filt_bulk AS
    SELECT id, val FROM filt_bulk WHERE val > 50;

statement ok
PRAGMA refresh('mv_filt_bulk');

# Cross-check after initial load
query I
SELECT COUNT(*) FROM (
    SELECT id, val FROM filt_bulk WHERE val > 50
    EXCEPT ALL
    SELECT id, val FROM mv_filt_bulk
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT id, val FROM mv_filt_bulk
    EXCEPT ALL
    SELECT id, val FROM filt_bulk WHERE val > 50
);
----
0

# Insert 1000 rows with val=1 (none match) + 3 rows with val=999 (all match)
statement ok
INSERT INTO filt_bulk SELECT 1000 + i, 1 FROM range(1000) t(i);

statement ok
INSERT INTO filt_bulk VALUES (9001, 999), (9002, 999), (9003, 999);

statement ok
PRAGMA refresh('mv_filt_bulk');

# MV gains only 3 rows
query I
SELECT COUNT(*) FROM (
    SELECT id, val FROM filt_bulk WHERE val > 50
    EXCEPT ALL
    SELECT id, val FROM mv_filt_bulk
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT id, val FROM mv_filt_bulk
    EXCEPT ALL
    SELECT id, val FROM filt_bulk WHERE val > 50
);
----
0

# Delete 1000 rows with val=1 — none in MV, MV unchanged
statement ok
DELETE FROM filt_bulk WHERE val = 1;

statement ok
PRAGMA refresh('mv_filt_bulk');

query I
SELECT COUNT(*) FROM (
    SELECT id, val FROM filt_bulk WHERE val > 50
    EXCEPT ALL
    SELECT id, val FROM mv_filt_bulk
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT id, val FROM mv_filt_bulk
    EXCEPT ALL
    SELECT id, val FROM filt_bulk WHERE val > 50
);
----
0

# ==========================================
# UPDATE moves row from inside to outside filter
# ==========================================

statement ok
CREATE TABLE filter_update (id INT, price INT);

statement ok
INSERT INTO filter_update VALUES (1, 10), (2, 15), (3, 25);

statement ok
CREATE MATERIALIZED VIEW mv_filter_update AS SELECT id, price FROM filter_update WHERE price < 20;

# Initial: ids 1, 2 match
statement ok
UPDATE filter_update SET price = 30 WHERE id = 2;

statement ok
PRAGMA refresh('mv_filter_update');

query I
SELECT COUNT(*) FROM (
    SELECT id, price FROM filter_update WHERE price < 20
    EXCEPT ALL SELECT * FROM mv_filter_update
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM mv_filter_update
    EXCEPT ALL SELECT id, price FROM filter_update WHERE price < 20
);
----
0

# UPDATE moves row back inside
statement ok
UPDATE filter_update SET price = 5 WHERE id = 3;

statement ok
PRAGMA refresh('mv_filter_update');

query I
SELECT COUNT(*) FROM (
    SELECT id, price FROM filter_update WHERE price < 20
    EXCEPT ALL SELECT * FROM mv_filter_update
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM mv_filter_update
    EXCEPT ALL SELECT id, price FROM filter_update WHERE price < 20
);
----
0

# ==========================================
# DISTINCT + FILTER
# ==========================================

statement ok
CREATE TABLE df_data (category VARCHAR, score INT);

statement ok
INSERT INTO df_data VALUES ('A', 10), ('A', 20), ('B', 30), ('B', 30), ('C', 5);

statement ok
CREATE MATERIALIZED VIEW mv_df AS
    SELECT DISTINCT category, score FROM df_data WHERE score > 10;

# Insert duplicate (no DISTINCT change) + new matching row
statement ok
INSERT INTO df_data VALUES ('B', 30), ('C', 50);

statement ok
PRAGMA refresh('mv_df');

query I
SELECT COUNT(*) FROM (
    SELECT DISTINCT category, score FROM df_data WHERE score > 10
    EXCEPT ALL SELECT * FROM mv_df
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM mv_df
    EXCEPT ALL SELECT DISTINCT category, score FROM df_data WHERE score > 10
);
----
0

# Delete rows that cross the filter boundary
statement ok
DELETE FROM df_data WHERE category = 'A' AND score = 20;

statement ok
PRAGMA refresh('mv_df');

query I
SELECT COUNT(*) FROM (
    SELECT DISTINCT category, score FROM df_data WHERE score > 10
    EXCEPT ALL SELECT * FROM mv_df
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM mv_df
    EXCEPT ALL SELECT DISTINCT category, score FROM df_data WHERE score > 10
);
----
0
