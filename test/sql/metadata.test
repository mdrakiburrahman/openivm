# name: test/sql/metadata.test
# description: Test that IVM metadata is correctly created and cleaned up
# group: [sql]

require openivm

load __TEST_DIR__/openivm_metadata_test.db

statement ok
SET openivm_files_path='__TEST_DIR__';

# ==========================================
# Setup: Create base tables and materialized views
# ==========================================

statement ok
CREATE TABLE t1 (id INT, grp VARCHAR, val INT);

statement ok
INSERT INTO t1 VALUES (1, 'a', 10), (2, 'b', 20);

statement ok
CREATE TABLE t2 (id INT, name VARCHAR);

statement ok
INSERT INTO t2 VALUES (1, 'alice'), (2, 'bob');

statement ok
CREATE MATERIALIZED VIEW mv1 AS SELECT grp, sum(val) as total FROM t1 GROUP BY grp;

statement ok
CREATE MATERIALIZED VIEW mv2 AS SELECT id, name FROM t2;

# ==========================================
# Test 1: Metadata tables exist after first MV creation
# ==========================================

query I
SELECT count(*) FROM openivm_views;
----
2

query I
SELECT count(*) FROM openivm_delta_tables;
----
2

# ==========================================
# Test 2: openivm_views has correct entries
# ==========================================

query II
SELECT view_name, type FROM openivm_views ORDER BY view_name;
----
mv1	0
mv2	2

# type 0 = AGGREGATE_GROUP, type 2 = SIMPLE_PROJECTION

# Verify the stored SQL is non-empty and contains the expected table/column references
query I
SELECT sql_string IS NOT NULL AND LENGTH(sql_string) > 0 AND sql_string LIKE '%sum%' AND sql_string LIKE '%grp%' FROM openivm_views WHERE view_name = 'mv1';
----
true

# ==========================================
# Test 3: openivm_delta_tables has correct entries
# ==========================================

query II
SELECT view_name, table_name FROM openivm_delta_tables ORDER BY view_name;
----
mv1	openivm_delta_t1
mv2	openivm_delta_t2

# ==========================================
# Test 4: Delta tables exist
# ==========================================

query I
SELECT count(*) FROM openivm_delta_t1;
----
0

query I
SELECT count(*) FROM openivm_delta_t2;
----
0

query I
SELECT count(*) FROM openivm_delta_mv1;
----
0

query I
SELECT count(*) FROM openivm_delta_mv2;
----
0

# ==========================================
# Test 5: last_update timestamps are set
# ==========================================

query I
SELECT count(*) FROM openivm_views WHERE last_update IS NOT NULL;
----
2

query I
SELECT count(*) FROM openivm_delta_tables WHERE last_update IS NOT NULL;
----
2

# ==========================================
# Test 6: IVM works before any drops (sanity check)
# ==========================================

statement ok
INSERT INTO t1 VALUES (3, 'a', 5);

statement ok
PRAGMA refresh('mv1');

query II
SELECT grp, total FROM mv1 ORDER BY grp;
----
a	15
b	20

# ==========================================
# Test 7: DROP MATERIALIZED VIEW cleans up metadata
# ==========================================

statement ok
DROP VIEW mv1;

# Entry should be removed from openivm_views
query I
SELECT count(*) FROM openivm_views WHERE view_name = 'mv1';
----
0

# Entries should be removed from openivm_delta_tables
query I
SELECT count(*) FROM openivm_delta_tables WHERE view_name = 'mv1';
----
0

# Delta view for the MV should be dropped
statement error
SELECT count(*) FROM openivm_delta_mv1;
----
does not exist

# openivm_delta_t1 should be dropped since no other MV uses t1
statement error
SELECT count(*) FROM openivm_delta_t1;
----
does not exist

# mv2 metadata should be untouched
query I
SELECT count(*) FROM openivm_views WHERE view_name = 'mv2';
----
1

query I
SELECT count(*) FROM openivm_delta_tables WHERE view_name = 'mv2';
----
1

# ==========================================
# Test 8: After drop, base table still works normally
# ==========================================

statement ok
INSERT INTO t1 VALUES (4, 'c', 100);

query I
SELECT count(*) FROM t1;
----
4

# ==========================================
# Test 9: Can re-create MV with same name after drop
# ==========================================

statement ok
CREATE MATERIALIZED VIEW mv1 AS SELECT grp, sum(val) as total FROM t1 GROUP BY grp;

query II
SELECT grp, total FROM mv1 ORDER BY grp;
----
a	15
b	20
c	100

query I
SELECT count(*) FROM openivm_views WHERE view_name = 'mv1';
----
1

# ==========================================
# Test 10: DROP second MV, delta table cleanup
# ==========================================

# Drop mv2 — openivm_delta_t2 should be cleaned up since no other MV uses t2
statement ok
DROP VIEW mv2;

query I
SELECT count(*) FROM openivm_views WHERE view_name = 'mv2';
----
0

query I
SELECT count(*) FROM openivm_delta_tables WHERE view_name = 'mv2';
----
0

statement error
SELECT count(*) FROM openivm_delta_mv2;
----
does not exist

# openivm_delta_t2 should be dropped since no MV depends on t2 anymore
statement error
SELECT count(*) FROM openivm_delta_t2;
----
does not exist

# ==========================================
# Test 11: Shared base table — delta kept when still needed
# ==========================================

# Create two MVs on same base table
statement ok
CREATE MATERIALIZED VIEW mv_shared1 AS SELECT grp, sum(val) as s FROM t1 GROUP BY grp;

statement ok
CREATE MATERIALIZED VIEW mv_shared2 AS SELECT grp, count(val) as c FROM t1 GROUP BY grp;

query I
SELECT count(*) FROM openivm_delta_tables WHERE table_name = 'openivm_delta_t1';
----
3

# Drop one — openivm_delta_t1 should remain (mv1 and mv_shared2 still use it)
statement ok
DROP VIEW mv_shared1;

query I
SELECT count(*) FROM openivm_delta_tables WHERE table_name = 'openivm_delta_t1';
----
2

# openivm_delta_t1 still exists
query I
SELECT count(*) FROM openivm_delta_t1;
----
0

# mv_shared2 still works
statement ok
INSERT INTO t1 VALUES (5, 'a', 7);

statement ok
PRAGMA refresh('mv_shared2');

query II
SELECT grp, c FROM mv_shared2 ORDER BY grp;
----
a	3
b	1
c	1

# ==========================================
# Test 12: DROP base table with CASCADE drops dependent MVs
# ==========================================

statement ok
CREATE TABLE t3 (id INT, val INT);

statement ok
INSERT INTO t3 VALUES (1, 100);

statement ok
CREATE MATERIALIZED VIEW mv_t3 AS SELECT sum(val) as total FROM t3;

query I
SELECT count(*) FROM openivm_views WHERE view_name = 'mv_t3';
----
1

# Regular DROP should fail because mv_t3 depends on t3... or DuckDB just drops it.
# Let's test CASCADE explicitly.
statement ok
DROP TABLE t3 CASCADE;

# MV should be gone
statement error
SELECT * FROM mv_t3;
----
does not exist

# Metadata should be cleaned up
query I
SELECT count(*) FROM openivm_views WHERE view_name = 'mv_t3';
----
0

query I
SELECT count(*) FROM openivm_delta_tables WHERE view_name = 'mv_t3';
----
0

# Delta tables should be gone
statement error
SELECT count(*) FROM openivm_delta_t3;
----
does not exist

statement error
SELECT count(*) FROM openivm_delta_mv_t3;
----
does not exist

# ==========================================
# Test 13: PRAGMA refresh on dropped MV gives clear error
# ==========================================

statement error
PRAGMA refresh('mv_t3');
----
does not exist

# ==========================================
# Test 14: Drop all MVs — system tables still exist but are empty
# ==========================================

# Clean up remaining MVs
statement ok
DROP VIEW mv1;

statement ok
DROP VIEW mv_shared2;

query I
SELECT count(*) FROM openivm_views;
----
0

query I
SELECT count(*) FROM openivm_delta_tables;
----
0

# ==========================================
# Test 15: Create new MV after all previous were dropped
# ==========================================

statement ok
CREATE TABLE fresh (id INT, val INT);

statement ok
INSERT INTO fresh VALUES (1, 42);

statement ok
CREATE MATERIALIZED VIEW mv_fresh AS SELECT sum(val) as total FROM fresh;

query I
SELECT total FROM mv_fresh;
----
42

query I
SELECT count(*) FROM openivm_views;
----
1

statement ok
INSERT INTO fresh VALUES (2, 8);

statement ok
PRAGMA refresh('mv_fresh');

query I
SELECT total FROM mv_fresh;
----
50

# NOTE: DROP MATERIALIZED VIEW syntax is not supported because DuckDB's
# internal PG parser intercepts it before our extension gets a chance.
# Use DROP VIEW to drop materialized views (the user-facing name is a VIEW).

# ==========================================
# Re-create MV with same name after DROP (different query)
# ==========================================

statement ok
CREATE TABLE recreate_base (id INT, val INT, category VARCHAR);

statement ok
INSERT INTO recreate_base VALUES (1, 10, 'a'), (2, 20, 'b');

statement ok
CREATE MATERIALIZED VIEW mv_recreate AS SELECT id, val FROM recreate_base;

query II
SELECT id, val FROM mv_recreate ORDER BY id;
----
1	10
2	20

statement ok
DROP VIEW mv_recreate;

# Re-create with a completely different query (aggregate instead of projection)
statement ok
CREATE MATERIALIZED VIEW mv_recreate AS SELECT category, SUM(val) AS total FROM recreate_base GROUP BY category;

query II
SELECT category, total FROM mv_recreate ORDER BY category;
----
a	10
b	20

statement ok
INSERT INTO recreate_base VALUES (3, 30, 'a');

statement ok
pragma refresh('mv_recreate');

query II
SELECT category, total FROM mv_recreate ORDER BY category;
----
a	40
b	20

# Cross-check
query II
SELECT category, SUM(val) FROM recreate_base GROUP BY category ORDER BY category;
----
a	40
b	20

# ==========================================
# VIEW wrapper: SELECT * hides internal columns
# ==========================================

statement ok
CREATE TABLE view_test (id INT, val INT);

statement ok
INSERT INTO view_test VALUES (1, 10), (2, 20);

statement ok
CREATE MATERIALIZED VIEW mv_view_test AS SELECT DISTINCT val FROM view_test;

# The MV is a VIEW over openivm_data_mv_view_test. Internal columns should be hidden.
# SELECT * should return only user-facing columns (val), not openivm_distinct_count.
query I
SELECT COUNT(*) FROM (SELECT * FROM mv_view_test);
----
2

# Verify the data table exists separately
query I
SELECT COUNT(*) FROM openivm_data_mv_view_test;
----
2

# ==========================================
# DROP VIEW cleans up data table + delta + metadata
# ==========================================

statement ok
CREATE TABLE drop_test (id INT, val INT);

statement ok
INSERT INTO drop_test VALUES (1, 10);

statement ok
CREATE MATERIALIZED VIEW mv_drop_test AS SELECT val FROM drop_test;

# Verify everything exists
query I
SELECT COUNT(*) FROM openivm_views WHERE view_name = 'mv_drop_test';
----
1

query I
SELECT COUNT(*) FROM openivm_delta_tables WHERE view_name = 'mv_drop_test';
----
1

query I
SELECT COUNT(*) FROM information_schema.tables WHERE table_name = 'openivm_data_mv_drop_test';
----
1

# DROP VIEW should clean up everything
statement ok
DROP VIEW mv_drop_test;

query I
SELECT COUNT(*) FROM openivm_views WHERE view_name = 'mv_drop_test';
----
0

query I
SELECT COUNT(*) FROM openivm_delta_tables WHERE view_name = 'mv_drop_test';
----
0

query I
SELECT COUNT(*) FROM information_schema.tables WHERE table_name = 'openivm_data_mv_drop_test';
----
0

query I
SELECT COUNT(*) FROM information_schema.tables WHERE table_name = 'openivm_delta_mv_drop_test';
----
0
