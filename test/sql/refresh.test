# name: test/sql/refresh.test
# description: Test REFRESH EVERY metadata, PRAGMA refresh_status, and manual refresh coexistence
# group: [sql]

require openivm

statement ok
SET openivm_files_path='__TEST_DIR__';

# ==========================================
# Test 1: REFRESH EVERY stores interval in metadata
# ==========================================

statement ok
CREATE TABLE sales (region VARCHAR, amount INT);

statement ok
INSERT INTO sales VALUES ('east', 100), ('west', 200);

statement ok
CREATE MATERIALIZED VIEW mv_auto REFRESH EVERY '5 minutes' AS
    SELECT region, SUM(amount) AS total, COUNT(*) AS cnt
    FROM sales GROUP BY region;

query I
SELECT refresh_interval FROM openivm_views WHERE view_name = 'mv_auto';
----
300

# ==========================================
# Test 2: Manual refresh still works alongside REFRESH EVERY config
# ==========================================

statement ok
INSERT INTO sales VALUES ('east', 50);

statement ok
PRAGMA refresh('mv_auto');

query III
SELECT region, total, cnt FROM mv_auto ORDER BY region;
----
east	150	2
west	200	1

# Cross-check
query I
SELECT count(*) FROM (
    SELECT region, total, cnt FROM mv_auto
    EXCEPT ALL
    SELECT region, SUM(amount), COUNT(*) FROM sales GROUP BY region
);
----
0

# ==========================================
# Test 3: PRAGMA refresh_status returns correct metadata (non-timestamp columns)
# ==========================================

# refresh_status returns 6 columns; we verify the pragma doesn't error out
statement ok
PRAGMA refresh_status('mv_auto');

# ==========================================
# Test 4: View without REFRESH EVERY has NULL interval
# ==========================================

statement ok
CREATE MATERIALIZED VIEW mv_manual AS
    SELECT region, SUM(amount) AS total FROM sales GROUP BY region;

query I
SELECT refresh_interval IS NULL FROM openivm_views WHERE view_name = 'mv_manual';
----
true

statement ok
PRAGMA refresh_status('mv_manual');

# ==========================================
# Test 5: Multiple views with different intervals
# ==========================================

statement ok
CREATE TABLE orders (id INT, qty INT);

statement ok
INSERT INTO orders VALUES (1, 10), (2, 20);

statement ok
CREATE MATERIALIZED VIEW mv_fast REFRESH EVERY '1 minute' AS
    SELECT SUM(qty) AS total, COUNT(*) AS cnt FROM orders;

statement ok
CREATE MATERIALIZED VIEW mv_slow REFRESH EVERY '1 hour' AS
    SELECT id, qty FROM orders;

query II
SELECT view_name, refresh_interval FROM openivm_views
    WHERE refresh_interval IS NOT NULL ORDER BY refresh_interval;
----
mv_fast	60
mv_auto	300
mv_slow	3600

# ==========================================
# Test 6: Manual PRAGMA refresh on scheduled view works correctly
# ==========================================

statement ok
INSERT INTO orders VALUES (3, 30);

statement ok
PRAGMA refresh('mv_fast');

query II
SELECT total, cnt FROM mv_fast;
----
60	3

query I
SELECT count(*) FROM (
    SELECT total, cnt FROM mv_fast
    EXCEPT ALL
    SELECT SUM(qty), COUNT(*) FROM orders
);
----
0

# ==========================================
# Test 7: Crash recovery — refresh_in_progress flag
# Simulate a crash by manually setting the flag to true.
# Next refresh should detect it and do a full recompute.
# ==========================================

statement ok
CREATE TABLE crash_test (id INT, val INT);

statement ok
INSERT INTO crash_test SELECT i, i * 10 FROM range(1, 11) t(i);

statement ok
CREATE MATERIALIZED VIEW mv_crash AS
    SELECT val, COUNT(*) AS cnt FROM crash_test GROUP BY val;

statement ok
INSERT INTO crash_test SELECT i, i * 10 FROM range(11, 21) t(i);

# Simulate a crash: set the flag without actually refreshing
statement ok
UPDATE openivm_views SET refresh_in_progress = true WHERE view_name = 'mv_crash';

# Verify flag is set
query I
SELECT refresh_in_progress FROM openivm_views WHERE view_name = 'mv_crash';
----
true

# Next refresh should detect the flag and do full recompute
statement ok
PRAGMA refresh('mv_crash');

# Flag should be cleared
query I
SELECT refresh_in_progress FROM openivm_views WHERE view_name = 'mv_crash';
----
false

# MV should be correct (full recompute recovers from any inconsistency)
query I
SELECT count(*) FROM (
    SELECT val, cnt FROM mv_crash
    EXCEPT ALL
    SELECT val, COUNT(*) AS cnt FROM crash_test GROUP BY val
);
----
0

query I
SELECT count(*) FROM (
    SELECT val, COUNT(*) AS cnt FROM crash_test GROUP BY val
    EXCEPT ALL
    SELECT val, cnt FROM mv_crash
);
----
0

# ==========================================
# Test 8: Normal refresh clears the flag correctly
# ==========================================

statement ok
INSERT INTO crash_test SELECT i, i * 10 FROM range(21, 31) t(i);

statement ok
PRAGMA refresh('mv_crash');

# Flag should be false after a normal refresh
query I
SELECT refresh_in_progress FROM openivm_views WHERE view_name = 'mv_crash';
----
false

query I
SELECT count(*) FROM (
    SELECT val, cnt FROM mv_crash
    EXCEPT ALL
    SELECT val, COUNT(*) AS cnt FROM crash_test GROUP BY val
);
----
0

# ==========================================
# Test 9: ALTER MATERIALIZED VIEW changes interval in metadata
# ==========================================

statement ok
ALTER MATERIALIZED VIEW mv_auto SET REFRESH EVERY '10 minutes';

query I
SELECT refresh_interval FROM openivm_views WHERE view_name = 'mv_auto';
----
600

statement ok
ALTER MATERIALIZED VIEW mv_auto SET REFRESH MANUAL;

query I
SELECT refresh_interval IS NULL FROM openivm_views WHERE view_name = 'mv_auto';
----
true

# Manual PRAGMA still works after disabling auto-refresh
statement ok
INSERT INTO sales VALUES ('north', 500);

statement ok
PRAGMA refresh('mv_auto');

query I
SELECT count(*) FROM (
    SELECT region, total, cnt FROM mv_auto
    EXCEPT ALL
    SELECT region, SUM(amount), COUNT(*) FROM sales GROUP BY region
);
----
0
