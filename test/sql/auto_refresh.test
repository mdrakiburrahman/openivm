# name: test/sql/auto_refresh.test
# description: Test that adaptive cost model correctly handles both IVM and full recompute paths
# group: [sql]

require openivm

statement ok
SET openivm_files_path='__TEST_DIR__';

# ==========================================
# Test 1: Projection — small delta → IVM path
# ==========================================

statement ok
CREATE TABLE proj_base (id INT, name VARCHAR);

statement ok
INSERT INTO proj_base SELECT i, 'name_' || i::VARCHAR FROM range(1, 101) t(i);

statement ok
CREATE MATERIALIZED VIEW mv_proj AS SELECT id, name FROM proj_base;

query I
SELECT count(*) FROM mv_proj;
----
100

# Small insert — should take IVM path
statement ok
INSERT INTO proj_base VALUES (101, 'new_name');

query IIIIII
PRAGMA refresh_cost('mv_proj');
----
incremental	8.643856	401.000000	8.643856	401.000000	false

statement ok
PRAGMA refresh('mv_proj');

query I
SELECT count(*) FROM mv_proj;
----
101

query II
SELECT id, name FROM mv_proj WHERE id = 101;
----
101	new_name

statement ok
SET openivm_profile_refresh = true;

statement ok
CREATE TABLE profile_proj_base (id INT, name VARCHAR);

statement ok
INSERT INTO profile_proj_base VALUES (1, 'one');

statement ok
CREATE MATERIALIZED VIEW mv_profile_proj AS SELECT id, name FROM profile_proj_base;

query I
SELECT count(*) FROM openivm_refresh_profile WHERE view_name = 'mv_profile_proj' AND step_name = 'create_mv_initial_load' AND duration_ms >= 0;
----
1

query I
SELECT count(*) FROM openivm_refresh_profile WHERE view_name = 'mv_profile_proj' AND step_name = 'create_mv_total' AND duration_ms >= 0;
----
1

query I
SELECT count(*) FROM openivm_refresh_profile WHERE view_name = 'mv_profile_proj' AND step_name IN ('create_compile_full_plan', 'create_compile_lpts') AND duration_ms >= 0;
----
2

query I
SELECT count(*) FROM openivm_refresh_profile WHERE view_name = 'mv_profile_proj' AND step_name = 'create_mv_mv_delta_table' AND contains(detail, 'statements=1');
----
1

statement ok
INSERT INTO profile_proj_base VALUES (2, 'two');

statement ok
PRAGMA refresh('mv_profile_proj');

query I
SELECT count(*) FROM openivm_refresh_profile WHERE view_name = 'mv_profile_proj' AND step_name = 'total_refresh';
----
1

query I
SELECT count(*) FROM openivm_refresh_profile WHERE view_name = 'mv_profile_proj' AND step_name = 'adaptive_cost_estimate';
----
0

query I
SELECT count(*) FROM openivm_refresh_profile WHERE view_name = 'mv_profile_proj' AND step_name IN ('acquire_locks', 'generate_refresh_sql', 'execute_refresh_sql', 'total_refresh') AND duration_ms >= 0;
----
4

query I
SELECT count(*) FROM openivm_refresh_profile WHERE view_name = 'mv_profile_proj' AND step_name IN ('generate_refresh_sql.context', 'generate_refresh_sql.metadata_lookup', 'generate_refresh_sql.dispatch', 'generate_refresh_sql.assembly') AND duration_ms >= 0;
----
4

statement ok
SET openivm_profile_refresh = false;

# ==========================================
# Test 2: Projection — large delta → recompute path
# ==========================================

statement ok
INSERT INTO proj_base SELECT i, 'batch_' || i::VARCHAR FROM range(102, 402) t(i);

query IIIIII
PRAGMA refresh_cost('mv_proj');
----
full	2597.463445	704.000000	2597.463445	704.000000	false

statement ok
PRAGMA refresh('mv_proj');

query I
SELECT count(*) FROM mv_proj;
----
401

query II
SELECT id, name FROM mv_proj WHERE id = 1;
----
1	name_1

query II
SELECT id, name FROM mv_proj WHERE id = 401;
----
401	batch_401

# ==========================================
# Test 3: Aggregate — small delta → IVM path
# ==========================================

statement ok
CREATE TABLE agg_base (id INT, grp INT, val INT);

statement ok
INSERT INTO agg_base SELECT i, i % 10, i * 3 FROM range(1, 201) t(i);

statement ok
CREATE MATERIALIZED VIEW mv_agg AS SELECT grp, sum(val) as total, count(val) as cnt FROM agg_base GROUP BY grp;

query I
SELECT count(*) FROM mv_agg;
----
10

# Small insert into one group
statement ok
INSERT INTO agg_base VALUES (201, 0, 999);

statement ok
INSERT INTO agg_base VALUES (202, 0, 1);

query IIIIII
PRAGMA refresh_cost('mv_agg');
----
incremental	6.000000	232.000000	6.000000	232.000000	false

statement ok
PRAGMA refresh('mv_agg');

query II
SELECT total, cnt FROM mv_agg WHERE grp = 0;
----
7300	22

query II
SELECT total, cnt FROM mv_agg WHERE grp = 1;
----
5760	20

# ==========================================
# Test 4: Projection — delete triggers recompute
# ==========================================

statement ok
CREATE TABLE del_base (id INT, val INT);

statement ok
INSERT INTO del_base SELECT i, i * 10 FROM range(1, 101) t(i);

statement ok
CREATE MATERIALIZED VIEW mv_del AS SELECT id, val FROM del_base;

query I
SELECT count(*) FROM mv_del;
----
100

# Delete 80% of the table
statement ok
DELETE FROM del_base WHERE id > 20;

query IIIIII
PRAGMA refresh_cost('mv_del');
----
full	691.508495	400.000000	691.508495	400.000000	false

statement ok
PRAGMA refresh('mv_del');

query I
SELECT count(*) FROM mv_del;
----
20

query I
SELECT max(id) FROM mv_del;
----
20

# ==========================================
# Test 5: Aggregate — delete + recompute correctness
# ==========================================

statement ok
CREATE TABLE agg_del (id INT, grp VARCHAR, val INT);

statement ok
INSERT INTO agg_del SELECT i, CASE WHEN i % 2 = 0 THEN 'even' ELSE 'odd' END, i FROM range(1, 51) t(i);

statement ok
CREATE MATERIALIZED VIEW mv_agg_del AS SELECT grp, sum(val) as total, count(val) as cnt FROM agg_del GROUP BY grp;

query III
SELECT grp, total, cnt FROM mv_agg_del ORDER BY grp;
----
even	650	25
odd	625	25

# Delete all even rows — large delta relative to base
statement ok
DELETE FROM agg_del WHERE grp = 'even';

query IIIIII
PRAGMA refresh_cost('mv_agg_del');
----
incremental	29.000000	56.000000	29.000000	56.000000	false

statement ok
PRAGMA refresh('mv_agg_del');

query III
SELECT grp, total, cnt FROM mv_agg_del ORDER BY grp;
----
odd	625	25

# ==========================================
# Test 6: Multiple refresh cycles with varying delta sizes
# ==========================================

statement ok
CREATE TABLE multi (id INT, grp INT, val INT);

statement ok
INSERT INTO multi SELECT i, i % 5, i FROM range(1, 101) t(i);

statement ok
CREATE MATERIALIZED VIEW mv_multi AS SELECT grp, sum(val) as total FROM multi GROUP BY grp;

# Cycle 1: small delta (IVM)
statement ok
INSERT INTO multi VALUES (101, 0, 500);

query IIIIII
PRAGMA refresh_cost('mv_multi');
----
incremental	3.000000	116.000000	3.000000	116.000000	false

statement ok
PRAGMA refresh('mv_multi');

query II
SELECT grp, total FROM mv_multi WHERE grp = 0;
----
0	1550

# Cycle 2: another small delta (IVM)
statement ok
INSERT INTO multi VALUES (102, 1, 1000);

query IIIIII
PRAGMA refresh_cost('mv_multi');
----
incremental	3.000000	117.000000	3.000000	117.000000	false

statement ok
PRAGMA refresh('mv_multi');

query II
SELECT grp, total FROM mv_multi WHERE grp = 1;
----
1	1970

# Cycle 3: large batch insert (may trigger recompute)
statement ok
INSERT INTO multi SELECT i, i % 5, i * 2 FROM range(200, 500) t(i);

query IIIIII
PRAGMA refresh_cost('mv_multi');
----
incremental	310.000000	417.000000	310.000000	417.000000	false

statement ok
PRAGMA refresh('mv_multi');

query I
SELECT count(*) FROM multi;
----
402

query II
SELECT grp, total FROM mv_multi ORDER BY grp;
----
0	43250
1	43790
2	42930
3	43070
4	43210

query II
SELECT grp, sum(val) as total FROM multi GROUP BY grp ORDER BY grp;
----
0	43250
1	43790
2	42930
3	43070
4	43210

# ==========================================
# Test 7: Empty delta — no-op refresh
# ==========================================

query IIIIII
PRAGMA refresh_cost('mv_multi');
----
incremental	0.000000	417.000000	0.000000	417.000000	false

statement ok
PRAGMA refresh('mv_multi');

query II
SELECT grp, total FROM mv_multi ORDER BY grp;
----
0	43250
1	43790
2	42930
3	43070
4	43210

# ==========================================
# Test 8: Projection with filter — both paths
# ==========================================

statement ok
CREATE TABLE filt (id INT, status VARCHAR, val INT);

statement ok
INSERT INTO filt SELECT i, CASE WHEN i % 3 = 0 THEN 'active' ELSE 'inactive' END, i FROM range(1, 151) t(i);

statement ok
CREATE MATERIALIZED VIEW mv_filt AS SELECT id, val FROM filt WHERE status = 'active';

query I
SELECT count(*) FROM mv_filt;
----
50

# Small insert — IVM path
statement ok
INSERT INTO filt VALUES (151, 'active', 151);

query IIIIII
PRAGMA refresh_cost('mv_filt');
----
incremental	4.343928	226.000000	4.343928	226.000000	false

statement ok
PRAGMA refresh('mv_filt');

query I
SELECT count(*) FROM mv_filt;
----
51

# Large insert — recompute path
statement ok
INSERT INTO filt SELECT i, 'active', i FROM range(200, 500) t(i);

query IIIIII
PRAGMA refresh_cost('mv_filt');
----
full	1303.083011	379.000000	1303.083011	379.000000	false

statement ok
PRAGMA refresh('mv_filt');

query I
SELECT count(*) FROM mv_filt;
----
351

query I
SELECT count(*) FROM filt WHERE status = 'active';
----
351

# ==========================================
# Test 9: Aggregate with MIN/MAX — both paths preserve correctness
# ==========================================

statement ok
CREATE TABLE minmax_base (id INT, grp VARCHAR, val INT);

statement ok
INSERT INTO minmax_base SELECT i, CASE WHEN i % 3 = 0 THEN 'a' WHEN i % 3 = 1 THEN 'b' ELSE 'c' END, i FROM range(1, 61) t(i);

statement ok
CREATE MATERIALIZED VIEW mv_minmax AS SELECT grp, min(val) as lo, max(val) as hi, count(val) as cnt FROM minmax_base GROUP BY grp;

query IIII
SELECT grp, lo, hi, cnt FROM mv_minmax ORDER BY grp;
----
a	3	60	20
b	1	58	20
c	2	59	20

# Small insert — IVM
statement ok
INSERT INTO minmax_base VALUES (61, 'a', 0);

query IIIIII
PRAGMA refresh_cost('mv_minmax');
----
incremental	3.000000	70.000000	3.000000	70.000000	false

statement ok
PRAGMA refresh('mv_minmax');

query IIII
SELECT grp, lo, hi, cnt FROM mv_minmax ORDER BY grp;
----
a	0	60	21
b	1	58	20
c	2	59	20

# Delete current min — triggers recompute for MIN
statement ok
DELETE FROM minmax_base WHERE id = 61;

query IIIIII
PRAGMA refresh_cost('mv_minmax');
----
incremental	3.000000	70.000000	3.000000	70.000000	false

statement ok
PRAGMA refresh('mv_minmax');

query IIII
SELECT grp, lo, hi, cnt FROM mv_minmax ORDER BY grp;
----
a	3	60	20
b	1	58	20
c	2	59	20

# ==========================================
# Test 10: Cross-check — IVM result always matches full query
# ==========================================

statement ok
CREATE TABLE xcheck (id INT, cat VARCHAR, amount INT);

statement ok
INSERT INTO xcheck SELECT i, chr(65 + (i::INT % 4)), i * 10 FROM range(1, 81) t(i);

statement ok
CREATE MATERIALIZED VIEW mv_xcheck AS SELECT cat, sum(amount) as total, count(amount) as n FROM xcheck GROUP BY cat;

# Refresh 1: small insert
statement ok
INSERT INTO xcheck VALUES (81, 'A', 9999);

query IIIIII
PRAGMA refresh_cost('mv_xcheck');
----
incremental	3.000000	93.000000	3.000000	93.000000	false

statement ok
PRAGMA refresh('mv_xcheck');

query III
SELECT cat, total, n FROM mv_xcheck ORDER BY cat;
----
A	18399	21
B	7800	20
C	8000	20
D	8200	20

query III
SELECT cat, sum(amount), count(amount) FROM xcheck GROUP BY cat ORDER BY cat;
----
A	18399	21
B	7800	20
C	8000	20
D	8200	20

# Refresh 2: delete
statement ok
DELETE FROM xcheck WHERE cat = 'D';

query IIIIII
PRAGMA refresh_cost('mv_xcheck');
----
incremental	28.000000	93.000000	28.000000	93.000000	false

statement ok
PRAGMA refresh('mv_xcheck');

query III
SELECT cat, total, n FROM mv_xcheck ORDER BY cat;
----
A	18399	21
B	7800	20
C	8000	20

query III
SELECT cat, sum(amount), count(amount) FROM xcheck GROUP BY cat ORDER BY cat;
----
A	18399	21
B	7800	20
C	8000	20

# Refresh 3: large batch
statement ok
INSERT INTO xcheck SELECT i, 'A', 1 FROM range(1, 301) t(i);

query IIIIII
PRAGMA refresh_cost('mv_xcheck');
----
incremental	306.000000	370.000000	306.000000	370.000000	false

statement ok
PRAGMA refresh('mv_xcheck');

query III
SELECT cat, total, n FROM mv_xcheck ORDER BY cat;
----
A	18699	321
B	7800	20
C	8000	20

query III
SELECT cat, sum(amount), count(amount) FROM xcheck GROUP BY cat ORDER BY cat;
----
A	18699	321
B	7800	20
C	8000	20

# ==========================================
# Test 11: PRAGMA refresh_cost — verify cost estimator decisions
# ==========================================

statement ok
CREATE TABLE cost_base (id INT, name VARCHAR);

statement ok
INSERT INTO cost_base SELECT i, 'name_' || i::VARCHAR FROM range(1, 101) t(i);

statement ok
CREATE MATERIALIZED VIEW mv_cost AS SELECT id, name FROM cost_base;

# No pending delta — IVM should be extremely cheap
statement ok
PRAGMA refresh('mv_cost');

query IIIIII
PRAGMA refresh_cost('mv_cost');
----
incremental	0.000000	400.000000	0.000000	400.000000	false

# Small delta (1 row on 100-row base) → incremental
statement ok
INSERT INTO cost_base VALUES (101, 'x');

query IIIIII
PRAGMA refresh_cost('mv_cost');
----
incremental	8.643856	401.000000	8.643856	401.000000	false

statement ok
PRAGMA refresh('mv_cost');

# Large delta (300 rows on 101-row base) → full recompute
statement ok
INSERT INTO cost_base SELECT i, 'batch' FROM range(200, 500) t(i);

query IIIIII
PRAGMA refresh_cost('mv_cost');
----
full	2597.463445	704.000000	2597.463445	704.000000	false

statement ok
PRAGMA refresh('mv_cost');

# After refresh, delta is empty — back to incremental
query IIIIII
PRAGMA refresh_cost('mv_cost');
----
incremental	0.000000	1604.000000	0.000000	1604.000000	false

# ==========================================
# Test 12: openivm_refresh_mode = 'full' — force full recompute
# ==========================================

statement ok
CREATE TABLE mode_base (id INT, grp VARCHAR, val INT);

statement ok
INSERT INTO mode_base SELECT i, CASE WHEN i % 2 = 0 THEN 'even' ELSE 'odd' END, i FROM range(1, 51) t(i);

statement ok
CREATE MATERIALIZED VIEW mv_mode AS SELECT grp, sum(val) as total, count(val) as cnt FROM mode_base GROUP BY grp;

query III
SELECT grp, total, cnt FROM mv_mode ORDER BY grp;
----
even	650	25
odd	625	25

# Small delta — cost model would pick IVM, but we force full
statement ok
SET openivm_refresh_mode = 'full';

statement ok
INSERT INTO mode_base VALUES (51, 'even', 999);

# Cost model says incremental, but we override
query IIIIII
PRAGMA refresh_cost('mv_mode');
----
incremental	3.000000	57.000000	3.000000	57.000000	false

statement ok
PRAGMA refresh('mv_mode');

# Result should still be correct regardless of path
query III
SELECT grp, total, cnt FROM mv_mode ORDER BY grp;
----
even	1649	26
odd	625	25

query III
SELECT grp, sum(val), count(val) FROM mode_base GROUP BY grp ORDER BY grp;
----
even	1649	26
odd	625	25

# ==========================================
# Test 13: openivm_refresh_mode = 'incremental' — force IVM
# ==========================================

statement ok
SET openivm_refresh_mode = 'incremental';

# Delta of 300 rows — cost model still picks incremental (304 < 357)
statement ok
INSERT INTO mode_base SELECT i, 'odd', 1 FROM range(100, 400) t(i);

query IIIIII
PRAGMA refresh_cost('mv_mode');
----
incremental	304.000000	357.000000	304.000000	357.000000	false

statement ok
PRAGMA refresh('mv_mode');

# Result should still be correct
query III
SELECT grp, total, cnt FROM mv_mode ORDER BY grp;
----
even	1649	26
odd	925	325

query III
SELECT grp, sum(val), count(val) FROM mode_base GROUP BY grp ORDER BY grp;
----
even	1649	26
odd	925	325

# ==========================================
# Test 14: openivm_refresh_mode = 'auto' — default, cost model decides
# ==========================================

statement ok
SET openivm_refresh_mode = 'auto';

statement ok
INSERT INTO mode_base VALUES (999, 'even', 1);

statement ok
PRAGMA refresh('mv_mode');

query III
SELECT grp, total, cnt FROM mv_mode ORDER BY grp;
----
even	1650	27
odd	925	325

query III
SELECT grp, sum(val), count(val) FROM mode_base GROUP BY grp ORDER BY grp;
----
even	1650	27
odd	925	325

# ==========================================
# Test 15: Filter selectivity — cost model accounts for selective filters
# ==========================================

statement ok
CREATE TABLE sel_base (id INT, val INT);

statement ok
INSERT INTO sel_base SELECT i, i FROM range(1, 10001) t(i);

# Highly selective: WHERE val > 9900 keeps ~1% of rows
statement ok
CREATE MATERIALIZED VIEW mv_selfilt AS SELECT id, val FROM sel_base WHERE val > 9900;

query I
SELECT count(*) FROM mv_selfilt;
----
100

# Insert 100 rows that all pass the filter
statement ok
INSERT INTO sel_base SELECT i, i FROM range(10001, 10101) t(i);

# IVM cost should be reduced by filter selectivity (~1% selectivity)
query IIIIII
PRAGMA refresh_cost('mv_selfilt');
----
incremental	252.877124	2320.000000	252.877124	2320.000000	false

statement ok
PRAGMA refresh('mv_selfilt');

query I
SELECT count(*) FROM mv_selfilt;
----
200

# Cross-check: EXCEPT ALL both directions
query II
SELECT * FROM mv_selfilt EXCEPT ALL SELECT id, val FROM sel_base WHERE val > 9900;
----

query II
SELECT id, val FROM sel_base WHERE val > 9900 EXCEPT ALL SELECT * FROM mv_selfilt;
----

# ==========================================
# Test 16: Filter selectivity — non-matching inserts are cheap
# ==========================================

# Insert 200 rows that do NOT pass the filter (val = 0)
statement ok
INSERT INTO sel_base SELECT i, 0 FROM range(20001, 20201) t(i);

# Despite 200 delta rows, filter selectivity keeps IVM cost manageable
query IIIIII
PRAGMA refresh_cost('mv_selfilt');
----
incremental	545.754248	2660.000000	545.754248	2660.000000	false

statement ok
PRAGMA refresh('mv_selfilt');

# Count unchanged — filter rejects all new rows
query I
SELECT count(*) FROM mv_selfilt;
----
200

# Cross-check
query II
SELECT * FROM mv_selfilt EXCEPT ALL SELECT id, val FROM sel_base WHERE val > 9900;
----

query II
SELECT id, val FROM sel_base WHERE val > 9900 EXCEPT ALL SELECT * FROM mv_selfilt;
----

# ==========================================
# Test 17: Filter selectivity — mixed DML correctness
# ==========================================

# Insert passing row, insert non-passing row, delete a passing row
statement ok
INSERT INTO sel_base VALUES (30001, 99999);

statement ok
INSERT INTO sel_base VALUES (30002, 1);

statement ok
DELETE FROM sel_base WHERE id = 9901;

statement ok
PRAGMA refresh('mv_selfilt');

query I
SELECT count(*) FROM mv_selfilt;
----
200

# Cross-check
query II
SELECT * FROM mv_selfilt EXCEPT ALL SELECT id, val FROM sel_base WHERE val > 9900;
----

query II
SELECT id, val FROM sel_base WHERE val > 9900 EXCEPT ALL SELECT * FROM mv_selfilt;
----

# ==========================================
# Test 18: Learned cost model — history recording and correctness
# ==========================================

statement ok
SET openivm_adaptive_refresh = true;

statement ok
CREATE TABLE lt (id INT, grp INT, val INT);

statement ok
INSERT INTO lt SELECT i, i % 5, i FROM range(1, 101) t(i);

statement ok
CREATE MATERIALIZED VIEW mv_lt AS SELECT grp, sum(val) as total FROM lt GROUP BY grp;

# 3 refreshes with varying delta sizes
statement ok
INSERT INTO lt VALUES (101, 0, 500);

statement ok
PRAGMA refresh('mv_lt');

statement ok
INSERT INTO lt VALUES (102, 1, 500);

statement ok
PRAGMA refresh('mv_lt');

statement ok
INSERT INTO lt SELECT i, i % 5, i FROM range(200, 210) t(i);

statement ok
PRAGMA refresh('mv_lt');

# History recorded: 3 incremental entries with non-negative durations
query I
SELECT count(*) FROM openivm_refresh_history WHERE view_name = 'mv_lt' AND method = 'incremental' AND actual_duration_ms >= 0;
----
3

# Profiling is off by default.
query I
SELECT count(*) FROM openivm_refresh_profile WHERE view_name = 'mv_lt';
----
0

statement ok
SET openivm_profile_refresh = true;

statement ok
INSERT INTO lt VALUES (103, 2, 500);

statement ok
PRAGMA refresh('mv_lt');

query I
SELECT count(*) FROM openivm_refresh_profile WHERE view_name = 'mv_lt' AND step_name IN ('generate_refresh_sql', 'execute_refresh_sql', 'total_refresh');
----
3

query I
SELECT count(*) FROM openivm_refresh_profile WHERE view_name = 'mv_lt' AND step_name = 'execute_refresh_sql_stmt';
----
7

query I
SELECT CASE WHEN count(*) >= 13 THEN 1 ELSE 0 END FROM openivm_refresh_profile WHERE view_name = 'mv_lt' AND duration_ms >= 0;
----
1

statement ok
INSERT INTO openivm_refresh_profile
  (refresh_id, view_name, profile_timestamp, step_order, step_name, duration_ms, detail)
VALUES ('old_profile_row', 'mv_lt', current_timestamp::TIMESTAMP - INTERVAL '32 days', 0, 'old', 0, '');

statement ok
INSERT INTO lt VALUES (104, 3, 500);

statement ok
PRAGMA refresh('mv_lt');

query I
SELECT count(*) FROM openivm_refresh_profile WHERE refresh_id = 'old_profile_row';
----
0

statement ok
SET openivm_profile_retention_days = 0;

statement ok
INSERT INTO lt VALUES (105, 4, 500);

statement ok
PRAGMA refresh('mv_lt');

query I
SELECT count(DISTINCT refresh_id) FROM openivm_refresh_profile WHERE view_name = 'mv_lt';
----
1

query I
SELECT count(*) FROM openivm_refresh_profile WHERE view_name = 'mv_lt' AND step_name = 'total_refresh';
----
1

statement ok
SET openivm_profile_retention_days = 31;

statement ok
SET openivm_profile_refresh = false;

# Correctness preserved through learned cost model
query II
SELECT grp, total FROM mv_lt EXCEPT ALL SELECT grp, sum(val) FROM lt GROUP BY grp;
----

query II
SELECT grp, sum(val) FROM lt GROUP BY grp EXCEPT ALL SELECT grp, total FROM mv_lt;
----

# ==========================================
# Test 19: Learned cost model — cold start is uncalibrated
# ==========================================

statement ok
CREATE TABLE cold_base (id INT, val INT);

statement ok
INSERT INTO cold_base SELECT i, i FROM range(1, 101) t(i);

statement ok
CREATE MATERIALIZED VIEW mv_cold AS SELECT id, val FROM cold_base;

statement ok
INSERT INTO cold_base VALUES (101, 101);

# No history — predicted_ms equals static cost, calibrated = false
query IIIIII
PRAGMA refresh_cost('mv_cold');
----
incremental	8.643856	401.000000	8.643856	401.000000	false

# ==========================================
# Test 20: Learned cost model — history cleanup on REPLACE
# ==========================================

query I
SELECT count(*) FROM openivm_refresh_history WHERE view_name = 'mv_lt';
----
6

statement ok
CREATE OR REPLACE MATERIALIZED VIEW mv_lt AS SELECT grp, sum(val) as total FROM lt GROUP BY grp;

query I
SELECT count(*) FROM openivm_refresh_history WHERE view_name = 'mv_lt';
----
0

statement ok
SET openivm_adaptive_refresh = false;

# ==========================================
# Test 21: Empty-delta term skipping — 3-way join, only 1 table changes
# ==========================================

statement ok
CREATE TABLE ed_a (id INT PRIMARY KEY, val INT);

statement ok
CREATE TABLE ed_b (id INT PRIMARY KEY, label VARCHAR);

statement ok
CREATE TABLE ed_c (id INT PRIMARY KEY, tag VARCHAR);

statement ok
INSERT INTO ed_a SELECT i, i * 10 FROM range(1, 51) t(i);

statement ok
INSERT INTO ed_b SELECT i, 'b_' || i::VARCHAR FROM range(1, 51) t(i);

statement ok
INSERT INTO ed_c SELECT i, 'c_' || i::VARCHAR FROM range(1, 51) t(i);

statement ok
CREATE MATERIALIZED VIEW mv_ed AS SELECT a.val, b.label, c.tag FROM ed_a a JOIN ed_b b ON a.id = b.id JOIN ed_c c ON a.id = c.id;

query I
SELECT count(*) FROM mv_ed;
----
50

# Insert into only table A — tables B and C have empty deltas
statement ok
INSERT INTO ed_a VALUES (51, 510);

statement ok
INSERT INTO ed_b VALUES (51, 'b_51');

statement ok
INSERT INTO ed_c VALUES (51, 'c_51');

statement ok
PRAGMA refresh('mv_ed');

# Cross-check: MV matches base query
query III
SELECT val, label, tag FROM mv_ed WHERE val = 510;
----
510	b_51	c_51

query I
SELECT count(*) FROM (SELECT a.val, b.label, c.tag FROM ed_a a JOIN ed_b b ON a.id = b.id JOIN ed_c c ON a.id = c.id EXCEPT ALL SELECT * FROM mv_ed);
----
0

query I
SELECT count(*) FROM (SELECT * FROM mv_ed EXCEPT ALL SELECT a.val, b.label, c.tag FROM ed_a a JOIN ed_b b ON a.id = b.id JOIN ed_c c ON a.id = c.id);
----
0

# Now insert into ONLY table A (B and C have empty deltas)
statement ok
INSERT INTO ed_a VALUES (52, 999);

statement ok
PRAGMA refresh('mv_ed');

# Row 52 exists in A but not in B/C — no join match, MV unchanged
query I
SELECT count(*) FROM mv_ed;
----
51

# Cross-check still holds
query I
SELECT count(*) FROM (SELECT a.val, b.label, c.tag FROM ed_a a JOIN ed_b b ON a.id = b.id JOIN ed_c c ON a.id = c.id EXCEPT ALL SELECT * FROM mv_ed);
----
0
