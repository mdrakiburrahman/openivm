DELETE FROM proj_net_zero WHERE x = 99;

statement ok
PRAGMA refresh('mv_proj_net_zero');

# MV should be unchanged (net zero delta for x=99)
query I
SELECT COUNT(*) FROM (
    SELECT x, y FROM proj_net_zero
    EXCEPT ALL
    SELECT x, y FROM mv_proj_net_zero
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT x, y FROM mv_proj_net_zero
    EXCEPT ALL
    SELECT x, y FROM proj_net_zero
);
----
0

