# ==========================================
# Expressions in SELECT (computed columns)
# ==========================================

statement ok
CREATE TABLE expr_base (a INT, b INT, c INT);

statement ok
INSERT INTO expr_base VALUES (1, 10, 100), (2, 20, 200);

statement ok
CREATE MATERIALIZED VIEW mv_expr AS SELECT a * 2 AS doubled, b + c AS total, c - b AS diff FROM expr_base;

query III
SELECT doubled, total, diff FROM mv_expr ORDER BY doubled;
----
2	110	90
4	220	180

statement ok
INSERT INTO expr_base VALUES (3, 30, 300), (4, 40, 400);

statement ok
DELETE FROM expr_base WHERE a = 1;

statement ok
PRAGMA refresh('mv_expr');

# Cross-check
query I
SELECT COUNT(*) FROM (
    SELECT a * 2 AS doubled, b + c AS total, c - b AS diff FROM expr_base
    EXCEPT ALL
    SELECT doubled, total, diff FROM mv_expr
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT doubled, total, diff FROM mv_expr
    EXCEPT ALL
    SELECT a * 2 AS doubled, b + c AS total, c - b AS diff FROM expr_base
);
----
0

# ==========================================
# Expressions with NULL propagation and type coercion
# ==========================================

statement ok
CREATE TABLE proj_null_expr (a INT, b INT, c VARCHAR);

statement ok
INSERT INTO proj_null_expr VALUES (10, 0, 'hello'), (NULL, 5, 'world'), (20, NULL, NULL);

statement ok
CREATE MATERIALIZED VIEW mv_proj_null_expr AS
    SELECT a, COALESCE(a, -1) AS safe_a, a * b AS product, LENGTH(c) AS clen FROM proj_null_expr;

statement ok
PRAGMA refresh('mv_proj_null_expr');

# Cross-check after initial load
query I
SELECT COUNT(*) FROM (
    SELECT a, COALESCE(a, -1) AS safe_a, a * b AS product, LENGTH(c) AS clen FROM proj_null_expr
    EXCEPT ALL
    SELECT a, safe_a, product, clen FROM mv_proj_null_expr
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT a, safe_a, product, clen FROM mv_proj_null_expr
    EXCEPT ALL
    SELECT a, COALESCE(a, -1) AS safe_a, a * b AS product, LENGTH(c) AS clen FROM proj_null_expr
);
----
0

# UPDATE: set a = NULL where a = 10 — product becomes NULL, safe_a becomes -1
statement ok
UPDATE proj_null_expr SET a = NULL WHERE a = 10;

statement ok
PRAGMA refresh('mv_proj_null_expr');

query I
SELECT COUNT(*) FROM (
    SELECT a, COALESCE(a, -1) AS safe_a, a * b AS product, LENGTH(c) AS clen FROM proj_null_expr
    EXCEPT ALL
    SELECT a, safe_a, product, clen FROM mv_proj_null_expr
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT a, safe_a, product, clen FROM mv_proj_null_expr
    EXCEPT ALL
    SELECT a, COALESCE(a, -1) AS safe_a, a * b AS product, LENGTH(c) AS clen FROM proj_null_expr
);
----
0

# DELETE all rows, then refresh (MV should be empty)
statement ok
DELETE FROM proj_null_expr;

statement ok
PRAGMA refresh('mv_proj_null_expr');

query I
SELECT COUNT(*) FROM (
    SELECT a, COALESCE(a, -1) AS safe_a, a * b AS product, LENGTH(c) AS clen FROM proj_null_expr
    EXCEPT ALL
    SELECT a, safe_a, product, clen FROM mv_proj_null_expr
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT a, safe_a, product, clen FROM mv_proj_null_expr
    EXCEPT ALL
    SELECT a, COALESCE(a, -1) AS safe_a, a * b AS product, LENGTH(c) AS clen FROM proj_null_expr
);
----
0

