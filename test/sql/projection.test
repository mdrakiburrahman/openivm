# ==========================================
# JOIN + FILTER + PROJECTION (computed expressions on filtered join)
# ==========================================

statement ok
CREATE TABLE jfp_items (id INT, name VARCHAR, weight DOUBLE);

statement ok
CREATE TABLE jfp_prices (item_id INT, unit_price DOUBLE);

statement ok
INSERT INTO jfp_items VALUES (1, 'Bolt', 0.5), (2, 'Nut', 0.1), (3, 'Beam', 50.0);

statement ok
INSERT INTO jfp_prices VALUES (1, 2.0), (2, 0.5), (3, 100.0);

statement ok
CREATE MATERIALIZED VIEW mv_jfp AS
    SELECT i.name, i.weight * p.unit_price AS cost
    FROM jfp_items i INNER JOIN jfp_prices p ON i.id = p.item_id
    WHERE i.weight < 10.0;

# Only Bolt and Nut match (weight < 10). Bolt cost=1.0, Nut cost=0.05
statement ok
INSERT INTO jfp_items VALUES (4, 'Washer', 0.02);

statement ok
INSERT INTO jfp_prices VALUES (4, 0.1);

statement ok
PRAGMA refresh('mv_jfp');

query I
SELECT COUNT(*) FROM (
    SELECT i.name, i.weight * p.unit_price
    FROM jfp_items i INNER JOIN jfp_prices p ON i.id = p.item_id WHERE i.weight < 10.0
    EXCEPT ALL SELECT * FROM mv_jfp
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM mv_jfp
    EXCEPT ALL SELECT i.name, i.weight * p.unit_price
    FROM jfp_items i INNER JOIN jfp_prices p ON i.id = p.item_id WHERE i.weight < 10.0
);
----
0

# Delete Bolt from items + update Beam weight to be under threshold
statement ok
DELETE FROM jfp_items WHERE id = 1;

statement ok
UPDATE jfp_items SET weight = 5.0 WHERE id = 3;

statement ok
PRAGMA refresh('mv_jfp');

query I
SELECT COUNT(*) FROM (
    SELECT i.name, i.weight * p.unit_price
    FROM jfp_items i INNER JOIN jfp_prices p ON i.id = p.item_id WHERE i.weight < 10.0
    EXCEPT ALL SELECT * FROM mv_jfp
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM mv_jfp
    EXCEPT ALL SELECT i.name, i.weight * p.unit_price
    FROM jfp_items i INNER JOIN jfp_prices p ON i.id = p.item_id WHERE i.weight < 10.0
);
----
0

# ============================================================
# POSITION(x IN y) and other keyword-syntax function calls.
# DuckDB's parser treats `position(x, y)` as invalid — the `position` identifier
# is reserved for the `POSITION(x IN y)` form — but accepts `"position"(x, y)`
# as a regular function call. LPTS emits the quoted form so view_query round-
# trips through the binder.
# ============================================================

statement ok
CREATE TABLE pos_t (id INT, name VARCHAR);

statement ok
INSERT INTO pos_t VALUES (1, 'apple'), (2, 'banana'), (3, 'cherry'), (4, 'date');

statement ok
CREATE MATERIALIZED VIEW mv_pos AS
    SELECT id, POSITION('a' IN name) AS pos_a FROM pos_t;

query I
SELECT COUNT(*) FROM (
    SELECT * FROM mv_pos
    EXCEPT ALL SELECT id, POSITION('a' IN name) AS pos_a FROM pos_t
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT id, POSITION('a' IN name) AS pos_a FROM pos_t
    EXCEPT ALL SELECT * FROM mv_pos
);
----
0

statement ok
INSERT INTO pos_t VALUES (5, 'apricot'), (6, 'fig');

statement ok
DELETE FROM pos_t WHERE id = 4;

statement ok
UPDATE pos_t SET name = 'pear' WHERE id = 1;

statement ok
PRAGMA refresh('mv_pos');

query I
SELECT COUNT(*) FROM (
    SELECT * FROM mv_pos
    EXCEPT ALL SELECT id, POSITION('a' IN name) AS pos_a FROM pos_t
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT id, POSITION('a' IN name) AS pos_a FROM pos_t
    EXCEPT ALL SELECT * FROM mv_pos
);
----
0

# ============================================================
# Projection top-k: ORDER BY + LIMIT without GROUP BY
# Maintains the unlimited projection incrementally; the view applies top-k at read time.
# ============================================================

statement ok
CREATE TABLE topkp_t (id INT, name VARCHAR, score INT);

statement ok
INSERT INTO topkp_t VALUES (1,'alice',80),(2,'bob',95),(3,'carol',70),(4,'dave',88),(5,'eve',92);

statement ok
CREATE MATERIALIZED VIEW topkp_mv AS
  SELECT id, name, score FROM topkp_t ORDER BY score DESC LIMIT 3;

query I
SELECT count(*) FROM (
  SELECT * FROM topkp_mv
  EXCEPT ALL
  SELECT * FROM (SELECT id, name, score FROM topkp_t ORDER BY score DESC LIMIT 3) _q
);
----
0

query I
SELECT count(*) FROM (
  SELECT * FROM (SELECT id, name, score FROM topkp_t ORDER BY score DESC LIMIT 3) _q
  EXCEPT ALL
  SELECT * FROM topkp_mv
);
----
0

# ==========================================
# Source-dependent UNNEST projection
# ==========================================

statement ok
CREATE TABLE proj_unnest_src(id INT, arr INT[]);

statement ok
INSERT INTO proj_unnest_src VALUES
  (1, [10, 10]),
  (2, []),
  (3, NULL),
  (4, [20]);

statement ok
CREATE MATERIALIZED VIEW proj_unnest_mv AS
  SELECT id, unnest(arr) AS elem FROM proj_unnest_src;

statement ok
INSERT INTO proj_unnest_src VALUES (5, [30, 40]), (6, []);

statement ok
UPDATE proj_unnest_src SET arr = [10, 99] WHERE id = 1;

statement ok
DELETE FROM proj_unnest_src WHERE id = 4;

statement ok
PRAGMA refresh('proj_unnest_mv');

query I
SELECT COUNT(*) FROM (
  SELECT id, elem FROM proj_unnest_mv
  EXCEPT ALL
  SELECT id, unnest(arr) AS elem FROM proj_unnest_src
);
----
0

query I
SELECT COUNT(*) FROM (
  SELECT id, unnest(arr) AS elem FROM proj_unnest_src
  EXCEPT ALL
  SELECT id, elem FROM proj_unnest_mv
);
----
0

statement ok
PRAGMA refresh('proj_unnest_mv');

query I
SELECT COUNT(*) FROM (
  SELECT id, elem FROM proj_unnest_mv
  EXCEPT ALL
  SELECT id, unnest(arr) AS elem FROM proj_unnest_src
);
----
0

query I
SELECT COUNT(*) FROM (
  SELECT id, unnest(arr) AS elem FROM proj_unnest_src
  EXCEPT ALL
  SELECT id, elem FROM proj_unnest_mv
);
----
0

statement ok
CREATE TABLE proj_unnest_filter_src(id INT, arr INT[]);

statement ok
INSERT INTO proj_unnest_filter_src VALUES
  (1, [5, 15]),
  (2, [20]),
  (3, []),
  (4, NULL);

statement ok
CREATE MATERIALIZED VIEW proj_unnest_filter_mv AS
  SELECT elem
  FROM (SELECT unnest(arr) AS elem FROM proj_unnest_filter_src) u
  WHERE elem > 10;

statement ok
INSERT INTO proj_unnest_filter_src VALUES (5, [9, 11, 12]);

statement ok
UPDATE proj_unnest_filter_src SET arr = [1, 100] WHERE id = 1;

statement ok
DELETE FROM proj_unnest_filter_src WHERE id = 2;

statement ok
PRAGMA refresh('proj_unnest_filter_mv');

query I
SELECT COUNT(*) FROM (
  SELECT elem FROM proj_unnest_filter_mv
  EXCEPT ALL
  SELECT elem
  FROM (SELECT unnest(arr) AS elem FROM proj_unnest_filter_src) u
  WHERE elem > 10
);
----
0

query I
SELECT COUNT(*) FROM (
  SELECT elem
  FROM (SELECT unnest(arr) AS elem FROM proj_unnest_filter_src) u
  WHERE elem > 10
  EXCEPT ALL
  SELECT elem FROM proj_unnest_filter_mv
);
----
0

# ==========================================
# Join projection over a derived-table leaf
# ==========================================

statement ok
CREATE TABLE proj_join_item(i_id INT, i_price INT, i_name VARCHAR);

statement ok
CREATE TABLE proj_join_stock(s_w_id INT, s_i_id INT, s_quantity INT);

statement ok
INSERT INTO proj_join_item VALUES (1, 60, 'a'), (2, 40, 'b');

statement ok
INSERT INTO proj_join_stock VALUES (1, 1, 10), (1, 2, 20);

statement ok
CREATE MATERIALIZED VIEW proj_join_mv AS
    SELECT s.s_w_id, s.s_i_id, s.s_quantity, iv.i_name
    FROM proj_join_stock s
    JOIN (SELECT i_id, i_name FROM proj_join_item WHERE i_price > 50) iv
      ON s.s_i_id = iv.i_id;

statement ok
UPDATE proj_join_stock SET s_quantity = 11 WHERE s_w_id = 1 AND s_i_id = 1;

statement ok
PRAGMA refresh('proj_join_mv');

query I
SELECT COUNT(*) FROM (
    SELECT * FROM proj_join_mv
    EXCEPT ALL
    SELECT s.s_w_id, s.s_i_id, s.s_quantity, iv.i_name
    FROM proj_join_stock s
    JOIN (SELECT i_id, i_name FROM proj_join_item WHERE i_price > 50) iv
      ON s.s_i_id = iv.i_id
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT s.s_w_id, s.s_i_id, s.s_quantity, iv.i_name
    FROM proj_join_stock s
    JOIN (SELECT i_id, i_name FROM proj_join_item WHERE i_price > 50) iv
      ON s.s_i_id = iv.i_id
    EXCEPT ALL
    SELECT * FROM proj_join_mv
);
----
0

# Projection delete should rank only affected join candidates while preserving bag semantics.
statement ok
CREATE TABLE proj_rank_w(w_id INT, w_name VARCHAR);

statement ok
CREATE TABLE proj_rank_d(d_w_id INT, d_id INT);

statement ok
CREATE TABLE proj_rank_c(c_w_id INT, c_id INT);

statement ok
INSERT INTO proj_rank_w VALUES (1, 'w1'), (2, 'w2');

statement ok
INSERT INTO proj_rank_d VALUES (1, 10), (1, 10), (2, 20);

statement ok
INSERT INTO proj_rank_c VALUES (1, 100), (1, 100), (2, 200);

statement ok
CREATE MATERIALIZED VIEW proj_rank_mv AS
    SELECT w.w_id, d.d_id, c.c_id
    FROM proj_rank_w w
