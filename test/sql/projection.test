statement ok
PRAGMA refresh('mv_proj_net_zero');

# Cross-check after initial load
query I
SELECT COUNT(*) FROM (
    SELECT x, y FROM proj_net_zero
    EXCEPT ALL
    SELECT x, y FROM mv_proj_net_zero
);
