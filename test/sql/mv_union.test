# ==========================================
# Both sides empty then repopulated
# ==========================================

statement ok
CREATE TABLE u_a (id INT);

statement ok
CREATE TABLE u_b (id INT);

statement ok
INSERT INTO u_a VALUES (1), (2), (3);

statement ok
INSERT INTO u_b VALUES (4), (5);

statement ok
CREATE MATERIALIZED VIEW mv_union_empty AS
    SELECT id FROM u_a UNION ALL SELECT id FROM u_b;

statement ok
PRAGMA ivm('mv_union_empty');

# Cross-check after initial load
query I
SELECT COUNT(*) FROM (
    (SELECT id FROM u_a UNION ALL SELECT id FROM u_b)
    EXCEPT ALL
    SELECT id FROM mv_union_empty
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT id FROM mv_union_empty
    EXCEPT ALL
    (SELECT id FROM u_a UNION ALL SELECT id FROM u_b)
);
----
0

# Delete all from both sides
statement ok
DELETE FROM u_a;

statement ok
DELETE FROM u_b;

statement ok
PRAGMA ivm('mv_union_empty');

# MV should be empty
query I
SELECT COUNT(*) FROM (
    (SELECT id FROM u_a UNION ALL SELECT id FROM u_b)
    EXCEPT ALL
    SELECT id FROM mv_union_empty
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT id FROM mv_union_empty
    EXCEPT ALL
    (SELECT id FROM u_a UNION ALL SELECT id FROM u_b)
);
----
0

# Repopulate both sides
statement ok
INSERT INTO u_a VALUES (10), (20);

statement ok
INSERT INTO u_b VALUES (30), (40), (50);

statement ok
PRAGMA ivm('mv_union_empty');

query I
SELECT COUNT(*) FROM (
    (SELECT id FROM u_a UNION ALL SELECT id FROM u_b)
    EXCEPT ALL
    SELECT id FROM mv_union_empty
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT id FROM mv_union_empty
    EXCEPT ALL
    (SELECT id FROM u_a UNION ALL SELECT id FROM u_b)
);
----
0

# ==========================================
# Heavy duplicates one side, delete all from other
# ==========================================

statement ok
CREATE TABLE u_dup_l (id INT);

statement ok
CREATE TABLE u_dup_r (id INT);

# Insert 5x id=1 in left, 3x id=1 in right
statement ok
INSERT INTO u_dup_l VALUES (1), (1), (1), (1), (1);

statement ok
INSERT INTO u_dup_r VALUES (1), (1), (1);

statement ok
CREATE MATERIALIZED VIEW mv_union_dup AS
    SELECT id FROM u_dup_l UNION ALL SELECT id FROM u_dup_r;

statement ok
PRAGMA ivm('mv_union_dup');

# Cross-check: 8 rows with id=1
query I
SELECT COUNT(*) FROM (
    (SELECT id FROM u_dup_l UNION ALL SELECT id FROM u_dup_r)
    EXCEPT ALL
    SELECT id FROM mv_union_dup
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT id FROM mv_union_dup
    EXCEPT ALL
    (SELECT id FROM u_dup_l UNION ALL SELECT id FROM u_dup_r)
);
----
0

# Delete all from left
statement ok
DELETE FROM u_dup_l;

statement ok
PRAGMA ivm('mv_union_dup');

# Cross-check: 3 rows remain (from right only)
query I
SELECT COUNT(*) FROM (
    (SELECT id FROM u_dup_l UNION ALL SELECT id FROM u_dup_r)
    EXCEPT ALL
    SELECT id FROM mv_union_dup
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT id FROM mv_union_dup
    EXCEPT ALL
    (SELECT id FROM u_dup_l UNION ALL SELECT id FROM u_dup_r)
);
----
0

# Insert 10x id=1 in left
statement ok
INSERT INTO u_dup_l SELECT 1 FROM range(10);

statement ok
PRAGMA ivm('mv_union_dup');

# Cross-check: 13 rows total
query I
SELECT COUNT(*) FROM (
    (SELECT id FROM u_dup_l UNION ALL SELECT id FROM u_dup_r)
    EXCEPT ALL
    SELECT id FROM mv_union_dup
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT id FROM mv_union_dup
    EXCEPT ALL
    (SELECT id FROM u_dup_l UNION ALL SELECT id FROM u_dup_r)
);
----
0

# ==========================================
# One side goes completely empty
# ==========================================

statement ok
CREATE TABLE u_side_a (id INT, name VARCHAR);

statement ok
CREATE TABLE u_side_b (id INT, name VARCHAR);

statement ok
INSERT INTO u_side_a VALUES (1, 'alpha'), (2, 'beta');

statement ok
INSERT INTO u_side_b VALUES (3, 'gamma'), (4, 'delta');

statement ok
CREATE MATERIALIZED VIEW mv_union_side AS
    SELECT id, name FROM u_side_a UNION ALL SELECT id, name FROM u_side_b;

# DELETE all from side A
statement ok
DELETE FROM u_side_a;

statement ok
PRAGMA ivm('mv_union_side');

query I
SELECT COUNT(*) FROM (
    SELECT id, name FROM u_side_a UNION ALL SELECT id, name FROM u_side_b
    EXCEPT ALL SELECT * FROM mv_union_side
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM mv_union_side
    EXCEPT ALL (SELECT id, name FROM u_side_a UNION ALL SELECT id, name FROM u_side_b)
);
----
0

# Repopulate side A with different data
statement ok
INSERT INTO u_side_a VALUES (5, 'epsilon'), (6, 'zeta');

statement ok
PRAGMA ivm('mv_union_side');

query I
SELECT COUNT(*) FROM (
    SELECT id, name FROM u_side_a UNION ALL SELECT id, name FROM u_side_b
    EXCEPT ALL SELECT * FROM mv_union_side
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM mv_union_side
    EXCEPT ALL (SELECT id, name FROM u_side_a UNION ALL SELECT id, name FROM u_side_b)
);
----
0

# ==========================================
# UNION ALL + AGGREGATE (aggregate on top of union)
# ==========================================

statement ok
CREATE TABLE ua_online (product VARCHAR, qty INT);

statement ok
CREATE TABLE ua_store (product VARCHAR, qty INT);

statement ok
INSERT INTO ua_online VALUES ('Widget', 10), ('Gadget', 20);

statement ok
INSERT INTO ua_store VALUES ('Widget', 5), ('Widget', 3), ('Gadget', 7);

statement ok
CREATE MATERIALIZED VIEW mv_total_sales AS
    SELECT product, SUM(qty) AS total
    FROM (SELECT product, qty FROM ua_online UNION ALL SELECT product, qty FROM ua_store)
    GROUP BY product;

# Insert into both sides + delete from one
statement ok
INSERT INTO ua_online VALUES ('Widget', 100);

statement ok
DELETE FROM ua_store WHERE product = 'Gadget';

statement ok
PRAGMA ivm('mv_total_sales');

query I
SELECT COUNT(*) FROM (
    SELECT product, SUM(qty) FROM (SELECT product, qty FROM ua_online UNION ALL SELECT product, qty FROM ua_store) GROUP BY product
    EXCEPT ALL SELECT * FROM mv_total_sales
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM mv_total_sales
    EXCEPT ALL SELECT product, SUM(qty) FROM (SELECT product, qty FROM ua_online UNION ALL SELECT product, qty FROM ua_store) GROUP BY product
);
----
0

# ==========================================
# Multi-table JOIN + UNION (different joins unioned)
# ==========================================

statement ok
CREATE TABLE mu_emp (id INT, name VARCHAR, dept_id INT);

statement ok
CREATE TABLE mu_dept (id INT, dname VARCHAR);

statement ok
CREATE TABLE mu_contractor (id INT, name VARCHAR, dept_id INT);

statement ok
INSERT INTO mu_dept VALUES (1, 'Eng'), (2, 'Sales');

statement ok
INSERT INTO mu_emp VALUES (1, 'Alice', 1), (2, 'Bob', 2);

statement ok
INSERT INTO mu_contractor VALUES (10, 'Xander', 1);

statement ok
CREATE MATERIALIZED VIEW mv_all_staff AS
    SELECT e.name, d.dname FROM mu_emp e INNER JOIN mu_dept d ON e.dept_id = d.id
    UNION ALL
    SELECT c.name, d.dname FROM mu_contractor c INNER JOIN mu_dept d ON c.dept_id = d.id;

statement ok
INSERT INTO mu_contractor VALUES (11, 'Yara', 2);

statement ok
DELETE FROM mu_emp WHERE id = 2;

statement ok
PRAGMA ivm('mv_all_staff');

query I
SELECT COUNT(*) FROM (
    (SELECT e.name, d.dname FROM mu_emp e INNER JOIN mu_dept d ON e.dept_id = d.id
     UNION ALL
     SELECT c.name, d.dname FROM mu_contractor c INNER JOIN mu_dept d ON c.dept_id = d.id)
    EXCEPT ALL SELECT * FROM mv_all_staff
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM mv_all_staff
    EXCEPT ALL
    (SELECT e.name, d.dname FROM mu_emp e INNER JOIN mu_dept d ON e.dept_id = d.id
     UNION ALL
     SELECT c.name, d.dname FROM mu_contractor c INNER JOIN mu_dept d ON c.dept_id = d.id)
);
----
0

# ==========================================
# UNION ALL over aggregates (each branch has its own GROUP BY)
# Regression for has_union_over_agg: must route to GROUP_RECOMPUTE, not SIMPLE_AGGREGATE
# ==========================================

statement ok
CREATE TABLE uoa_customer (w_id INT, balance DOUBLE);

statement ok
CREATE TABLE uoa_history (w_id INT, amount DOUBLE);

statement ok
INSERT INTO uoa_customer VALUES (1, 100.0), (1, 200.0), (2, 50.0);

statement ok
INSERT INTO uoa_history VALUES (1, 10.0), (2, 20.0), (2, 30.0);

statement ok
CREATE MATERIALIZED VIEW mv_uoa AS
    SELECT w_id, SUM(balance) AS total FROM uoa_customer GROUP BY w_id
    UNION ALL
    SELECT w_id, SUM(amount) FROM uoa_history GROUP BY w_id;

# Verify classification is GROUP_RECOMPUTE (6), not SIMPLE_AGGREGATE (1)
query I
SELECT type FROM _duckdb_ivm_views WHERE view_name = 'mv_uoa';
----
6

statement ok
INSERT INTO uoa_customer VALUES (1, 300.0);

statement ok
DELETE FROM uoa_history WHERE w_id = 2 AND amount = 20.0;

statement ok
PRAGMA ivm('mv_uoa');

query I
SELECT COUNT(*) FROM (
    (SELECT w_id, SUM(balance) AS total FROM uoa_customer GROUP BY w_id
     UNION ALL
     SELECT w_id, SUM(amount) FROM uoa_history GROUP BY w_id)
    EXCEPT ALL SELECT * FROM mv_uoa
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM mv_uoa
    EXCEPT ALL
    (SELECT w_id, SUM(balance) AS total FROM uoa_customer GROUP BY w_id
     UNION ALL
     SELECT w_id, SUM(amount) FROM uoa_history GROUP BY w_id)
);
----
0

# Second refresh with mixed deltas (insert + delete on both tables)
statement ok
INSERT INTO uoa_history VALUES (3, 99.0);

statement ok
DELETE FROM uoa_customer WHERE w_id = 2;

statement ok
PRAGMA ivm('mv_uoa');

query I
SELECT COUNT(*) FROM (
    (SELECT w_id, SUM(balance) AS total FROM uoa_customer GROUP BY w_id
     UNION ALL
     SELECT w_id, SUM(amount) FROM uoa_history GROUP BY w_id)
    EXCEPT ALL SELECT * FROM mv_uoa
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM mv_uoa
    EXCEPT ALL
    (SELECT w_id, SUM(balance) AS total FROM uoa_customer GROUP BY w_id
     UNION ALL
     SELECT w_id, SUM(amount) FROM uoa_history GROUP BY w_id)
