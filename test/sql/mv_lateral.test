# name: test/sql/mv_lateral.test
# description: materialized view maintenance for LATERAL / DELIM_JOIN plans
# group: [sql]

require openivm

statement ok
CREATE TABLE lat_customer (c_id INT, c_w_id INT);

statement ok
CREATE TABLE lat_history (h_c_id INT, h_c_w_id INT, h_amount INT);

statement ok
INSERT INTO lat_customer VALUES (1, 1), (1, 1), (2, 1);

statement ok
INSERT INTO lat_history VALUES (1, 1, 10), (1, 1, 20), (2, 1, 5);

statement ok
CREATE MATERIALIZED VIEW mv_lat AS
    SELECT c.c_id, c.c_w_id, lat.total_payments
    FROM lat_customer c
    JOIN LATERAL (
        SELECT SUM(h_amount) AS total_payments
        FROM lat_history
        WHERE h_c_id = c.c_id AND h_c_w_id = c.c_w_id
    ) lat ON true;

# DELIM/DEPENDENT aggregate views use affected-key recompute, not scalar aggregate upsert.
query I
SELECT type FROM _duckdb_ivm_views WHERE view_name = 'mv_lat';
----
6

query I
SELECT COUNT(*) FROM (
    (SELECT c.c_id, c.c_w_id, lat.total_payments
     FROM lat_customer c
     JOIN LATERAL (
         SELECT SUM(h_amount) AS total_payments
         FROM lat_history
         WHERE h_c_id = c.c_id AND h_c_w_id = c.c_w_id
     ) lat ON true)
    EXCEPT ALL SELECT * FROM mv_lat
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM mv_lat
    EXCEPT ALL
    (SELECT c.c_id, c.c_w_id, lat.total_payments
     FROM lat_customer c
     JOIN LATERAL (
         SELECT SUM(h_amount) AS total_payments
         FROM lat_history
         WHERE h_c_id = c.c_id AND h_c_w_id = c.c_w_id
     ) lat ON true)
);
----
0

# Scalar correlated subqueries use DuckDB's SINGLE DELIM_JOIN shape.
statement ok
CREATE TABLE lat_scalar_wh(w_id INT, w_name VARCHAR);

statement ok
INSERT INTO lat_scalar_wh VALUES (1, 'w1'), (2, 'w2'), (4, 'w4');

statement ok
CREATE MATERIALIZED VIEW mv_lat_scalar AS
    WITH numbers AS (SELECT generate_series AS n FROM generate_series(1, 5))
    SELECT n, (SELECT w_name FROM lat_scalar_wh WHERE w_id = n) AS wh_name
    FROM numbers;

query I
SELECT type FROM _duckdb_ivm_views WHERE view_name = 'mv_lat_scalar';
----
6

query I
SELECT COUNT(*) FROM (
    (WITH numbers AS (SELECT generate_series AS n FROM generate_series(1, 5))
     SELECT n, (SELECT w_name FROM lat_scalar_wh WHERE w_id = n) AS wh_name
     FROM numbers)
    EXCEPT ALL SELECT * FROM mv_lat_scalar
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM mv_lat_scalar
    EXCEPT ALL
    (WITH numbers AS (SELECT generate_series AS n FROM generate_series(1, 5))
     SELECT n, (SELECT w_name FROM lat_scalar_wh WHERE w_id = n) AS wh_name
     FROM numbers)
);
----
0

statement ok
