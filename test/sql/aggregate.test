statement ok
DELETE FROM t5 WHERE id = 4;

statement ok
PRAGMA refresh('mv_simple_min');

query I
SELECT min_val FROM mv_simple_min;
----
50

# Test 6: MIN/MAX with JOIN + GROUP BY

statement ok
CREATE TABLE departments (dept_id INT, dept_name VARCHAR);

statement ok
INSERT INTO departments VALUES (1, 'engineering'), (2, 'sales');

statement ok
CREATE TABLE employees (id INT, dept_id INT, salary INT);

statement ok
INSERT INTO employees VALUES (1, 1, 100), (2, 1, 200), (3, 2, 150), (4, 2, 300);

statement ok
CREATE MATERIALIZED VIEW mv_dept_salaries AS
    SELECT d.dept_name, MIN(e.salary) AS min_salary, MAX(e.salary) AS max_salary
    FROM departments d INNER JOIN employees e ON e.dept_id = d.dept_id
    GROUP BY d.dept_name;

statement ok
INSERT INTO employees VALUES (5, 1, 50);

statement ok
PRAGMA refresh('mv_dept_salaries');

query III
SELECT dept_name, min_salary, max_salary FROM mv_dept_salaries ORDER BY dept_name;
----
engineering	50	200
sales	150	300

statement ok
DELETE FROM employees WHERE id = 5;

statement ok
PRAGMA refresh('mv_dept_salaries');

query III
SELECT dept_name, min_salary, max_salary FROM mv_dept_salaries ORDER BY dept_name;
----
engineering	100	200
sales	150	300

statement ok
INSERT INTO departments VALUES (3, 'marketing');

statement ok
INSERT INTO employees VALUES (6, 3, 75);

statement ok
PRAGMA refresh('mv_dept_salaries');

query III
SELECT dept_name, min_salary, max_salary FROM mv_dept_salaries ORDER BY dept_name;
----
engineering	100	200
marketing	75	75
sales	150	300

# ==========================================
# AVG aggregate (group-recompute strategy)
# ==========================================

statement ok
CREATE TABLE avg_data (grp VARCHAR, val DOUBLE);

statement ok
INSERT INTO avg_data VALUES ('a', 10), ('a', 20), ('b', 30);

statement ok
CREATE MATERIALIZED VIEW mv_avg AS SELECT grp, AVG(val) AS avg_val FROM avg_data GROUP BY grp;

query II
SELECT grp, avg_val FROM mv_avg ORDER BY grp;
----
a	15.0
b	30.0

statement ok
INSERT INTO avg_data VALUES ('a', 40), ('c', 100);

statement ok
pragma refresh('mv_avg');

query II
SELECT grp, avg_val FROM mv_avg ORDER BY grp;
----
a	23.333333333333332
b	30.0
c	100.0

# Cross-check
query II
SELECT grp, AVG(val) FROM avg_data GROUP BY grp ORDER BY grp;
----
a	23.333333333333332
b	30.0
c	100.0

# Delete from group
statement ok
DELETE FROM avg_data WHERE grp = 'a' AND val = 10;

statement ok
pragma refresh('mv_avg');

query II
SELECT grp, avg_val FROM mv_avg ORDER BY grp;
----
a	30.0
b	30.0
c	100.0

# Ungrouped AVG
statement ok
CREATE TABLE avg_ungrouped (val INT);

statement ok
INSERT INTO avg_ungrouped VALUES (10), (20), (30);

statement ok
CREATE MATERIALIZED VIEW mv_avg_scalar AS SELECT AVG(val) AS avg_val FROM avg_ungrouped;

query I
SELECT avg_val FROM mv_avg_scalar;
----
20.0

statement ok
INSERT INTO avg_ungrouped VALUES (40);

statement ok
pragma refresh('mv_avg_scalar');

query I
SELECT avg_val FROM mv_avg_scalar;
----
25.0

# Cross-check
query I
SELECT AVG(val) FROM avg_ungrouped;
----
25.0

# ==========================================
# HAVING clause (optimized to FILTER above AGGREGATE by DuckDB)
# ==========================================

statement ok
CREATE TABLE having_test (region VARCHAR, amount INT);

statement ok
INSERT INTO having_test VALUES ('a', 100), ('a', 200), ('b', 50), ('c', 10);

statement ok
CREATE MATERIALIZED VIEW mv_having AS SELECT region, SUM(amount) AS total FROM having_test GROUP BY region HAVING SUM(amount) > 60;

query II
SELECT region, total FROM mv_having ORDER BY region;
----
a	300

statement ok
INSERT INTO having_test VALUES ('b', 100), ('c', 200);

statement ok
PRAGMA refresh('mv_having');

# Cross-check
query I
SELECT COUNT(*) FROM (
    SELECT region, SUM(amount) AS total FROM having_test GROUP BY region HAVING SUM(amount) > 60
    EXCEPT ALL
    SELECT region, total FROM mv_having
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT region, total FROM mv_having
    EXCEPT ALL
    SELECT region, SUM(amount) AS total FROM having_test GROUP BY region HAVING SUM(amount) > 60
);
----
0

# ==========================================
# CASE WHEN in aggregates
# ==========================================

statement ok
CREATE TABLE case_test (category VARCHAR, value INT);

statement ok
INSERT INTO case_test VALUES ('a', 10), ('a', -5), ('b', 20), ('b', -3);

statement ok
CREATE MATERIALIZED VIEW mv_case AS SELECT category, SUM(CASE WHEN value > 0 THEN value ELSE 0 END) AS pos_sum FROM case_test GROUP BY category;

query II
SELECT category, pos_sum FROM mv_case ORDER BY category;
----
a	10
b	20

statement ok
INSERT INTO case_test VALUES ('a', 30), ('b', -100), ('c', 50);

statement ok
PRAGMA refresh('mv_case');

# Cross-check
query I
SELECT COUNT(*) FROM (
    SELECT category, SUM(CASE WHEN value > 0 THEN value ELSE 0 END) AS pos_sum FROM case_test GROUP BY category
    EXCEPT ALL
    SELECT category, pos_sum FROM mv_case
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT category, pos_sum FROM mv_case
    EXCEPT ALL
    SELECT category, SUM(CASE WHEN value > 0 THEN value ELSE 0 END) AS pos_sum FROM case_test GROUP BY category
);
----
0

# ==========================================
# NULL values in aggregate columns with edge case deletions
# ==========================================

statement ok
CREATE TABLE agg_null_edge (grp VARCHAR, val INT);

statement ok
INSERT INTO agg_null_edge VALUES ('a', 10), ('a', NULL), ('b', NULL), ('b', NULL), ('c', 30);

statement ok
CREATE MATERIALIZED VIEW mv_agg_null_edge AS
    SELECT grp, SUM(val) AS total, COUNT(*) AS cnt, COUNT(val) AS cnt_val
    FROM agg_null_edge GROUP BY grp;

statement ok
PRAGMA refresh('mv_agg_null_edge');

# Cross-check after initial load
query I
SELECT COUNT(*) FROM (
    SELECT grp, SUM(val) AS total, COUNT(*) AS cnt, COUNT(val) AS cnt_val FROM agg_null_edge GROUP BY grp
    EXCEPT ALL
