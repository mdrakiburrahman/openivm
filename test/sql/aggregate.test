statement ok
INSERT INTO case_avg VALUES (2, 100), (2, 100), (2, 100), (2, 100), (2, 100);

statement ok
PRAGMA refresh('mv_case_avg');

query TT
SELECT grp, tier FROM mv_case_avg ORDER BY grp;
