# ==========================================
# DATE columns as GROUP BY keys
# ==========================================

statement ok
CREATE TABLE daily_sales (sale_date DATE, amount INT);

statement ok
INSERT INTO daily_sales VALUES ('2024-01-01', 100), ('2024-01-01', 200), ('2024-01-02', 300);

statement ok
CREATE MATERIALIZED VIEW mv_daily AS SELECT sale_date, SUM(amount) AS total FROM daily_sales GROUP BY sale_date;

query II
SELECT sale_date, total FROM mv_daily ORDER BY sale_date;
----
2024-01-01	300
2024-01-02	300

statement ok
INSERT INTO daily_sales VALUES ('2024-01-02', 50), ('2024-01-03', 400);

statement ok
pragma refresh('mv_daily');

query II
SELECT sale_date, total FROM mv_daily ORDER BY sale_date;
----
2024-01-01	300
2024-01-02	350
2024-01-03	400

# Cross-check
query II
SELECT sale_date, SUM(amount) FROM daily_sales GROUP BY sale_date ORDER BY sale_date;
----
2024-01-01	300
2024-01-02	350
2024-01-03	400

# ==========================================
# Empty table → CREATE MV → INSERT → refresh
# ==========================================

statement ok
CREATE TABLE empty_base (id INT, val INT);

statement ok
CREATE MATERIALIZED VIEW mv_empty AS SELECT id, SUM(val) AS total FROM empty_base GROUP BY id;

query II
SELECT id, total FROM mv_empty;
----

statement ok
INSERT INTO empty_base VALUES (1, 100), (2, 200);

statement ok
pragma refresh('mv_empty');

query II
SELECT id, total FROM mv_empty ORDER BY id;
----
1	100
2	200

# ==========================================
# Large batch INSERT (1000 rows)
# ==========================================

statement ok
CREATE TABLE batch_tbl (grp INT, val INT);

statement ok
CREATE MATERIALIZED VIEW mv_batch AS SELECT grp, SUM(val) AS total, COUNT(*) AS cnt FROM batch_tbl GROUP BY grp;

statement ok
INSERT INTO batch_tbl SELECT i % 10, i FROM range(1000) t(i);

statement ok
pragma refresh('mv_batch');

# Cross-check
query I
SELECT COUNT(*) FROM (
    SELECT grp, SUM(val) AS total, COUNT(*) AS cnt FROM batch_tbl GROUP BY grp
    EXCEPT
    SELECT grp, total, cnt FROM mv_batch
);
----
0

# ==========================================
# DELETE all rows → MV should be empty
# ==========================================

statement ok
CREATE TABLE del_all (grp VARCHAR, val INT);

statement ok
INSERT INTO del_all VALUES ('a', 1), ('b', 2);

statement ok
CREATE MATERIALIZED VIEW mv_del_all AS SELECT grp, SUM(val) AS total FROM del_all GROUP BY grp;

statement ok
DELETE FROM del_all;

statement ok
pragma refresh('mv_del_all');

query II
SELECT grp, total FROM mv_del_all;
----

# ==========================================
# UNGROUPED (SCALAR) AGGREGATES
# ==========================================


statement ok
CREATE TABLE scores (id INT, value INT, label VARCHAR);

statement ok
INSERT INTO scores VALUES (1, 10, 'a'), (2, 20, 'b'), (3, 30, 'c');

statement ok
create materialized view score_totals as (select sum(value) as total, count(label) as cnt from scores);

query II
SELECT total, cnt FROM score_totals;
----
60	3

# --- Insert ---
statement ok
INSERT INTO scores VALUES (4, 40, 'd');

statement ok
pragma refresh('score_totals');

query II
SELECT total, cnt FROM score_totals;
----
100	4

# --- Delete ---
statement ok
DELETE FROM scores WHERE id = 1;

statement ok
pragma refresh('score_totals');

query II
SELECT total, cnt FROM score_totals;
----
90	3

# --- Mixed insert + delete ---
statement ok
INSERT INTO scores VALUES (5, 50, 'e');

statement ok
DELETE FROM scores WHERE id = 2;

statement ok
pragma refresh('score_totals');

query II
SELECT total, cnt FROM score_totals;
----
120	3

# --- No-op PRAGMA ---
statement ok
pragma refresh('score_totals');

query II
SELECT total, cnt FROM score_totals;
----
120	3

# --- Batch insert ---
statement ok
INSERT INTO scores VALUES (6, 10, 'f'), (7, 20, 'g'), (8, 30, 'h');

statement ok
pragma refresh('score_totals');

query II
SELECT total, cnt FROM score_totals;
----
180	6

# --- Delete multiple rows at once ---
statement ok
DELETE FROM scores WHERE value <= 20;

statement ok
pragma refresh('score_totals');

# Remaining: id=3(30), id=4(40), id=5(50), id=8(30) = 150, cnt=4
query II
SELECT total, cnt FROM score_totals;
----
150	4


# ==========================================
# MIN / MAX AGGREGATES
# ==========================================

# Test 1: MIN with GROUP BY

statement ok
CREATE TABLE t1 (id INT, grp VARCHAR, val INT);

statement ok
INSERT INTO t1 VALUES (1, 'a', 10), (2, 'a', 20), (3, 'b', 30), (4, 'b', 5);

statement ok
CREATE MATERIALIZED VIEW mv_min AS SELECT grp, MIN(val) AS min_val FROM t1 GROUP BY grp;

statement ok
INSERT INTO t1 VALUES (5, 'a', 3);

statement ok
PRAGMA refresh('mv_min');

query II
SELECT grp, min_val FROM mv_min ORDER BY grp;
----
a	3
b	5

statement ok
DELETE FROM t1 WHERE id = 5;

statement ok
PRAGMA refresh('mv_min');

query II
SELECT grp, min_val FROM mv_min ORDER BY grp;
----
a	10
b	5

# Test 2: MAX with GROUP BY

statement ok
CREATE TABLE t2 (id INT, grp VARCHAR, val INT);

statement ok
INSERT INTO t2 VALUES (1, 'x', 100), (2, 'x', 200), (3, 'y', 50), (4, 'y', 75);

statement ok
CREATE MATERIALIZED VIEW mv_max AS SELECT grp, MAX(val) AS max_val FROM t2 GROUP BY grp;

statement ok
INSERT INTO t2 VALUES (5, 'y', 300);

statement ok
PRAGMA refresh('mv_max');

query II
SELECT grp, max_val FROM mv_max ORDER BY grp;
----
x	200
y	300

statement ok
DELETE FROM t2 WHERE id = 5;

statement ok
PRAGMA refresh('mv_max');

query II
SELECT grp, max_val FROM mv_max ORDER BY grp;
----
x	200
y	75

# Test 3: Mixed aggregates (SUM + MIN + MAX)

statement ok
CREATE TABLE t3 (id INT, grp VARCHAR, a INT, b INT, c INT);

statement ok
INSERT INTO t3 VALUES (1, 'g1', 10, 100, 1), (2, 'g1', 20, 200, 2), (3, 'g2', 30, 300, 3);

statement ok
CREATE MATERIALIZED VIEW mv_mixed AS SELECT grp, SUM(a) AS sum_a, MIN(b) AS min_b, MAX(c) AS max_c FROM t3 GROUP BY grp;

statement ok
INSERT INTO t3 VALUES (4, 'g1', 5, 50, 10);

statement ok
PRAGMA refresh('mv_mixed');

query IIII
SELECT grp, sum_a, min_b, max_c FROM mv_mixed ORDER BY grp;
----
g1	35	50	10
g2	30	300	3

statement ok
DELETE FROM t3 WHERE id = 4;

statement ok
PRAGMA refresh('mv_mixed');

query IIII
SELECT grp, sum_a, min_b, max_c FROM mv_mixed ORDER BY grp;
----
g1	30	100	2
g2	30	300	3

# Regression: AGGREGATE_HAVING with MIN must not use the insert-only MIN/MAX
# fast path when the actual delta contains deletes/updates.
statement ok
CREATE TABLE t_min_having (id INT, grp VARCHAR, val INT);

statement ok
INSERT INTO t_min_having VALUES (1, 'h1', 10), (2, 'h1', 20), (3, 'h2', 5);

statement ok
CREATE MATERIALIZED VIEW mv_min_having AS
    SELECT grp, MIN(val) AS min_val, COUNT(*) AS cnt
    FROM t_min_having
    GROUP BY grp
    HAVING COUNT(*) > 0;

query I
SELECT type FROM openivm_views WHERE view_name = 'mv_min_having';
----
4

statement ok
DELETE FROM t_min_having WHERE id = 1;

statement ok
PRAGMA refresh('mv_min_having');

query III
SELECT grp, min_val, cnt FROM mv_min_having ORDER BY grp;
----
h1	20	1
h2	5	1

query I
SELECT COUNT(*) FROM (
    SELECT grp, min_val, cnt FROM mv_min_having
    EXCEPT ALL
    SELECT grp, MIN(val) AS min_val, COUNT(*) AS cnt
    FROM t_min_having
    GROUP BY grp
    HAVING COUNT(*) > 0
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT grp, MIN(val) AS min_val, COUNT(*) AS cnt
    FROM t_min_having
    GROUP BY grp
    HAVING COUNT(*) > 0
    EXCEPT ALL
    SELECT grp, min_val, cnt FROM mv_min_having
);
----
0

# MAX + HAVING should also stay on AGGREGATE_HAVING so insert-only refresh can
# use the min/max MERGE fast path instead of GROUP_RECOMPUTE.
statement ok
CREATE TABLE t_max_having (id INT, grp VARCHAR, val INT);

statement ok
INSERT INTO t_max_having VALUES (1, 'h1', 10), (2, 'h1', 20), (3, 'h2', 5);

statement ok
CREATE MATERIALIZED VIEW mv_max_having AS
    SELECT grp, MAX(val) AS max_val
    FROM t_max_having
    GROUP BY grp
    HAVING MAX(val) > 0;

query I
SELECT type FROM openivm_views WHERE view_name = 'mv_max_having';
----
4

statement ok
INSERT INTO t_max_having VALUES (4, 'h1', 30), (5, 'h3', 40);

statement ok
PRAGMA refresh('mv_max_having');

query I
SELECT COUNT(*) FROM (
    SELECT grp, max_val FROM mv_max_having
    EXCEPT ALL
    SELECT grp, MAX(val) AS max_val
    FROM t_max_having
    GROUP BY grp
    HAVING MAX(val) > 0
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT grp, MAX(val) AS max_val
    FROM t_max_having
    GROUP BY grp
    HAVING MAX(val) > 0
    EXCEPT ALL
    SELECT grp, max_val FROM mv_max_having
);
----
0

# Computed MIN/MAX projections cannot use the AGGREGATE_HAVING merge path:
# the computed output has to be recomputed for affected groups, not summed.
statement ok
CREATE TABLE t_computed_min_having (id INT, grp VARCHAR, val INT);

statement ok
INSERT INTO t_computed_min_having VALUES (1, 'h1', 10), (2, 'h1', 20), (3, 'h2', 5);

statement ok
CREATE MATERIALIZED VIEW mv_computed_min_having AS
    SELECT grp, MIN(val) + 0 AS min_plus_zero, COUNT(*) AS cnt
    FROM t_computed_min_having
    GROUP BY grp
    HAVING COUNT(*) > 0;

query I
SELECT type FROM openivm_views WHERE view_name = 'mv_computed_min_having';
----
6

statement ok
INSERT INTO t_computed_min_having VALUES (4, 'h1', 1), (5, 'h3', 30);

statement ok
DELETE FROM t_computed_min_having WHERE id = 5;

statement ok
PRAGMA refresh('mv_computed_min_having');

query III
SELECT grp, min_plus_zero, cnt FROM mv_computed_min_having ORDER BY grp;
----
h1	1	3
h2	5	1

query I
SELECT COUNT(*) FROM (
    SELECT * FROM mv_computed_min_having
    EXCEPT ALL
    SELECT grp, MIN(val) + 0 AS min_plus_zero, COUNT(*) AS cnt
    FROM t_computed_min_having
    GROUP BY grp
    HAVING COUNT(*) > 0
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT grp, MIN(val) + 0 AS min_plus_zero, COUNT(*) AS cnt
    FROM t_computed_min_having
    GROUP BY grp
    HAVING COUNT(*) > 0
    EXCEPT ALL
    SELECT * FROM mv_computed_min_having
);
----
0

# MIN/MAX used only in HAVING is stored as a hidden openivm_having_* column.
# It must use group-recompute; aggregate MERGE can otherwise maintain the hidden
# MAX as a SUM and expose groups that still fail the HAVING predicate.
statement ok
CREATE TABLE t_hidden_max_having (id INT, grp VARCHAR, val INT);

statement ok
INSERT INTO t_hidden_max_having VALUES (1, 'h1', 5), (2, 'h2', 20);

statement ok
CREATE MATERIALIZED VIEW mv_hidden_max_having AS
    SELECT grp, COUNT(*) AS cnt
    FROM t_hidden_max_having
    GROUP BY grp
    HAVING MAX(val) > 10;

query I
SELECT type FROM openivm_views WHERE view_name = 'mv_hidden_max_having';
----
6

statement ok
INSERT INTO t_hidden_max_having VALUES (3, 'h1', 7), (4, 'h3', 30);

statement ok
UPDATE t_hidden_max_having SET val = 25 WHERE id = 2;

statement ok
DELETE FROM t_hidden_max_having WHERE id = 4;

statement ok
PRAGMA refresh('mv_hidden_max_having');

query I
SELECT COUNT(*) FROM (
    SELECT * FROM mv_hidden_max_having
    EXCEPT ALL
    SELECT grp, COUNT(*) AS cnt
    FROM t_hidden_max_having
    GROUP BY grp
    HAVING MAX(val) > 10
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT grp, COUNT(*) AS cnt
    FROM t_hidden_max_having
    GROUP BY grp
    HAVING MAX(val) > 10
    EXCEPT ALL
    SELECT * FROM mv_hidden_max_having
);
----
0

# Test 5: Ungrouped MIN aggregate

statement ok
CREATE TABLE t5 (id INT, val INT);

statement ok
INSERT INTO t5 VALUES (1, 100), (2, 50), (3, 200);

statement ok
CREATE MATERIALIZED VIEW mv_simple_min AS SELECT MIN(val) AS min_val FROM t5;

statement ok
