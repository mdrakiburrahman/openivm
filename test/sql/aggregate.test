    FROM tag_events GROUP BY kind;

statement ok
INSERT INTO tag_events VALUES ('click', 10), ('view', 5);

statement ok
DELETE FROM tag_events WHERE kind = 'click' AND amount = 5;

statement ok
PRAGMA refresh('mv_literal_tag');

query I
SELECT COUNT(*) FROM (
    SELECT * FROM mv_literal_tag
    EXCEPT ALL
    SELECT 'stat', kind, SUM(amount), COUNT(*) FROM tag_events GROUP BY kind
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT 'stat', kind, SUM(amount), COUNT(*) FROM tag_events GROUP BY kind
    EXCEPT ALL SELECT * FROM mv_literal_tag
);
----
0

# CASE over aggregate — value changes whenever the aggregate state changes,
# so neither summing deltas nor pass-through is correct. Group-recompute is.
statement ok
CREATE TABLE case_sales (region VARCHAR, rev INT);

statement ok
INSERT INTO case_sales VALUES ('EU', 100), ('EU', 500), ('US', 200), ('US', 900);

statement ok
CREATE MATERIALIZED VIEW mv_tier AS
    SELECT region,
           SUM(rev) AS total,
           COUNT(*) AS n,
           CASE WHEN SUM(rev) > 1000 THEN 'high' ELSE 'low' END AS tier
    FROM case_sales GROUP BY region;

# Push EU past the 1000 threshold, push US below by deleting the big row
statement ok
INSERT INTO case_sales VALUES ('EU', 500);

statement ok
DELETE FROM case_sales WHERE region = 'US' AND rev = 900;

statement ok
PRAGMA refresh('mv_tier');

query I
SELECT COUNT(*) FROM (
    SELECT * FROM mv_tier
    EXCEPT ALL
    SELECT region, SUM(rev), COUNT(*),
           CASE WHEN SUM(rev) > 1000 THEN 'high' ELSE 'low' END
    FROM case_sales GROUP BY region
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT region, SUM(rev), COUNT(*),
           CASE WHEN SUM(rev) > 1000 THEN 'high' ELSE 'low' END
    FROM case_sales GROUP BY region
    EXCEPT ALL SELECT * FROM mv_tier
);
----
0

# Verify the CASE value actually flipped for both groups
query TT
SELECT region, tier FROM mv_tier ORDER BY region;
----
EU	high
US	low

# LIST aggregate — lists are not element-wise summable, must re-list per group
