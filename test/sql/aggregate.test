INSERT INTO filter_t VALUES (6,'a',500,true),(7,'b',400,false),(8,'c',150,true);

statement ok
DELETE FROM filter_t WHERE id = 2;

statement ok
UPDATE filter_t SET val = 999, active = false WHERE id = 4;

statement ok
PRAGMA refresh('filter_mv');

query I
SELECT count(*) FROM (SELECT * FROM filter_mv EXCEPT ALL SELECT grp, COUNT(*) FILTER (WHERE active), SUM(val) FILTER (WHERE val > 100), AVG(val) FILTER (WHERE active) FROM filter_t GROUP BY grp);
----
0

query I
SELECT count(*) FROM (SELECT grp, COUNT(*) FILTER (WHERE active), SUM(val) FILTER (WHERE val > 100), AVG(val) FILTER (WHERE active) FROM filter_t GROUP BY grp EXCEPT ALL SELECT * FROM filter_mv);
----
0

# ============================================================
# BOOL_AND / BOOL_OR support
# BOOLEAN is non-summable → group-recompute path (Z-set correct).
# ============================================================

statement ok
CREATE TABLE bool_t (id INT, grp VARCHAR, flag BOOL);

statement ok
INSERT INTO bool_t VALUES (1,'x',true),(2,'x',false),(3,'y',true),(4,'y',true),(5,'z',false);

statement ok
CREATE MATERIALIZED VIEW bool_mv AS
  SELECT grp, BOOL_AND(flag) AS all_flag, BOOL_OR(flag) AS any_flag FROM bool_t GROUP BY grp;

query I
SELECT count(*) FROM (SELECT * FROM bool_mv EXCEPT ALL SELECT grp, BOOL_AND(flag), BOOL_OR(flag) FROM bool_t GROUP BY grp);
----
0

query I
SELECT count(*) FROM (SELECT grp, BOOL_AND(flag), BOOL_OR(flag) FROM bool_t GROUP BY grp EXCEPT ALL SELECT * FROM bool_mv);
----
0

# --- delete the only false in x → BOOL_AND flips to true ---
statement ok
DELETE FROM bool_t WHERE id = 2;

# --- delete one of two trues in y (BOOL_AND and BOOL_OR stay true) ---
statement ok
DELETE FROM bool_t WHERE id = 3;

# --- insert a false into y → BOOL_AND should become false ---
statement ok
INSERT INTO bool_t VALUES (6,'y',false);

statement ok
PRAGMA refresh('bool_mv');

query I
SELECT count(*) FROM (SELECT * FROM bool_mv EXCEPT ALL SELECT grp, BOOL_AND(flag), BOOL_OR(flag) FROM bool_t GROUP BY grp);
----
0

query I
SELECT count(*) FROM (SELECT grp, BOOL_AND(flag), BOOL_OR(flag) FROM bool_t GROUP BY grp EXCEPT ALL SELECT * FROM bool_mv);
----
0

# ============================================================
# Aggregate top-k: GROUP BY + ORDER BY + LIMIT
# All groups maintained in openivm_data_mv; ORDER BY LIMIT k
# applied in the VIEW definition at read time.
# ============================================================

statement ok
CREATE TABLE topk_t (id INT, grp VARCHAR, val INT);

statement ok
INSERT INTO topk_t VALUES
  (1,'a',100),(2,'a',200),(3,'b',50),(4,'b',300),
  (5,'c',150),(6,'c',250),(7,'d',10),(8,'d',5);

statement ok
CREATE MATERIALIZED VIEW topk_agg AS
  SELECT grp, SUM(val) AS total FROM topk_t GROUP BY grp ORDER BY total DESC LIMIT 3;

# Initial state: top 3 by total (a=300, b=350, c=400, d=15 → c,b,a top 3)
query I
SELECT count(*) FROM (
  SELECT * FROM topk_agg
  EXCEPT ALL
  SELECT * FROM (SELECT grp, SUM(val) AS total FROM topk_t GROUP BY grp ORDER BY total DESC LIMIT 3) _q
);
----
0

query I
SELECT count(*) FROM (
  SELECT * FROM (SELECT grp, SUM(val) AS total FROM topk_t GROUP BY grp ORDER BY total DESC LIMIT 3) _q
  EXCEPT ALL
  SELECT * FROM topk_agg
);
----
0

# ============================================================
# COUNT(DISTINCT constant) over duplicate join rows
# ============================================================

statement ok
CREATE TABLE cd_order (id INT, w_id INT);

statement ok
CREATE TABLE cd_new_order (o_id INT, w_id INT);

statement ok
INSERT INTO cd_order VALUES (1, 1), (2, 1);

statement ok
INSERT INTO cd_new_order VALUES (1, 1), (1, 1), (2, 1);

statement ok
CREATE MATERIALIZED VIEW mv_count_distinct_constant AS
  SELECT o.id, MIN(1) AS mn, MAX(1) AS mx, COUNT(DISTINCT 1) AS uniq
  FROM cd_order o
  JOIN cd_new_order no ON o.id = no.o_id AND o.w_id = no.w_id
  GROUP BY o.id;

query I
SELECT type FROM openivm_views WHERE view_name = 'mv_count_distinct_constant';
----
6

statement ok
INSERT INTO cd_new_order VALUES (1, 1);

statement ok
PRAGMA refresh('mv_count_distinct_constant');

query I
SELECT COUNT(*) FROM (
  SELECT * FROM mv_count_distinct_constant
  EXCEPT ALL
  SELECT o.id, MIN(1) AS mn, MAX(1) AS mx, COUNT(DISTINCT 1) AS uniq
  FROM cd_order o
  JOIN cd_new_order no ON o.id = no.o_id AND o.w_id = no.w_id
  GROUP BY o.id
);
----
0

query I
SELECT COUNT(*) FROM (
  SELECT o.id, MIN(1) AS mn, MAX(1) AS mx, COUNT(DISTINCT 1) AS uniq
  FROM cd_order o
  JOIN cd_new_order no ON o.id = no.o_id AND o.w_id = no.w_id
  GROUP BY o.id
  EXCEPT ALL
  SELECT * FROM mv_count_distinct_constant
);
----
0

