# ============================================================
# Non-summable columns in aggregate MVs — the delta MERGE path
# emits `sum(case mult=false then -<col> else <col> end)` for
# every non-key column, which fails type-checking for VARCHAR /
# BOOLEAN / LIST columns and gives wrong results for CASE over
# aggregates. These cases must fall back to group-recompute:
# delete affected groups, re-insert from the view query.
# ============================================================

# UPPER(group_key) — VARCHAR column deterministic in the group key
statement ok
CREATE TABLE nonadd_cust (w_id INT, state VARCHAR, bal DECIMAL(10,2));

statement ok
INSERT INTO nonadd_cust VALUES (1, 'ca', 100), (1, 'ca', 200), (1, 'ny', 150);

statement ok
CREATE MATERIALIZED VIEW mv_upper_state AS
    SELECT w_id, state, UPPER(state) AS state_upper, COUNT(*) AS cnt
    FROM nonadd_cust GROUP BY w_id, state;

statement ok
INSERT INTO nonadd_cust VALUES (1, 'ca', 300), (2, 'tx', 400);

statement ok
DELETE FROM nonadd_cust WHERE state = 'ny';

statement ok
PRAGMA refresh('mv_upper_state');

query I
SELECT COUNT(*) FROM (
    SELECT * FROM mv_upper_state
    EXCEPT ALL
    SELECT w_id, state, UPPER(state), COUNT(*) FROM nonadd_cust GROUP BY w_id, state
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT w_id, state, UPPER(state), COUNT(*) FROM nonadd_cust GROUP BY w_id, state
    EXCEPT ALL
    SELECT * FROM mv_upper_state
);
----
0

