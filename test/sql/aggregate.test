# CASE over AVG — aggregate state changes across the threshold repeatedly
statement ok
CREATE TABLE case_avg (grp INT, v DECIMAL(10,2));

statement ok
INSERT INTO case_avg VALUES (1, 100), (1, 200), (2, 1500), (2, 2500);

statement ok
CREATE MATERIALIZED VIEW mv_case_avg AS
    SELECT grp,
           AVG(v) AS avg_v,
           COUNT(*) AS n,
           CASE WHEN AVG(v) > 1000 THEN 'big' ELSE 'small' END AS tier
    FROM case_avg GROUP BY grp;

query TT
SELECT grp, tier FROM mv_case_avg ORDER BY grp;
----
1	small
2	big

