# ============================================================
# STDDEV/VARIANCE on flat-valued data — regression for crashes
# and drift after INSERT+DELETE. Without the MERGE-path CASE-WHEN +
# GREATEST(0, ...) clamp, sqrt() is called on a tiny-negative value
# (floating-point reassociation of (sum_sq - sum²/count)) and crashes.
# ============================================================

statement ok
CREATE TABLE sd_flat (id INT, grp INT, v DOUBLE);

statement ok
INSERT INTO sd_flat SELECT i, (i-1) % 3, 100.5 FROM range(1, 30) t(i);

statement ok
CREATE MATERIALIZED VIEW mv_flat_sd AS
    SELECT grp, STDDEV(v) AS sd, VARIANCE(v) AS vr,
           STDDEV_POP(v) AS sdp, VAR_POP(v) AS vrp, COUNT(*) AS n
    FROM sd_flat GROUP BY grp;

# Batch of inserts + deletes on flat data — variance is algebraically 0
# but floating-point makes it drift negative.
statement ok
INSERT INTO sd_flat SELECT i, (i-1) % 3, 100.5 FROM range(30, 60) t(i);

statement ok
DELETE FROM sd_flat WHERE grp = 0 AND id BETWEEN 1 AND 6;

statement ok
PRAGMA refresh('mv_flat_sd');

query I
SELECT COUNT(*) FROM (
    SELECT * FROM mv_flat_sd
    EXCEPT ALL
    SELECT grp, STDDEV(v), VARIANCE(v), STDDEV_POP(v), VAR_POP(v), COUNT(*)
    FROM sd_flat GROUP BY grp
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT grp, STDDEV(v), VARIANCE(v), STDDEV_POP(v), VAR_POP(v), COUNT(*)
    FROM sd_flat GROUP BY grp
    EXCEPT ALL SELECT * FROM mv_flat_sd
);
----
0

# ============================================================
# STDDEV/VARIANCE with groups crossing the count threshold:
# sample needs count > 1, population needs count > 0. When a DELETE
# drops a group to count=1 (or count=0), the MV must store NULL —
# not NaN or 0 from the raw algebraic formula.
# ============================================================

statement ok
CREATE TABLE sd_threshold (grp INT, v DOUBLE);

statement ok
INSERT INTO sd_threshold VALUES
    (1, 10), (1, 20), (1, 30),  -- grp 1: 3 rows
    (2, 100), (2, 200),          -- grp 2: 2 rows
    (3, 500);                    -- grp 3: 1 row (already below sample threshold)

statement ok
CREATE MATERIALIZED VIEW mv_thr_sd AS
    SELECT grp, STDDEV(v) AS sd, VARIANCE(v) AS vr,
           STDDEV_POP(v) AS sdp, VAR_POP(v) AS vrp, COUNT(*) AS n
    FROM sd_threshold GROUP BY grp;

# Cross-check initial state (grp=3 should have sd/vr = NULL, sdp/vrp = 0)
query I
SELECT COUNT(*) FROM (
    SELECT * FROM mv_thr_sd
    EXCEPT ALL
    SELECT grp, STDDEV(v), VARIANCE(v), STDDEV_POP(v), VAR_POP(v), COUNT(*)
    FROM sd_threshold GROUP BY grp
);
----
0

# Batch: DELETE brings grp=1 down to count=1, grp=2 down to count=0,
# and adds a new group that only ever has 1 row.
statement ok
DELETE FROM sd_threshold WHERE grp = 1 AND v IN (20, 30);

statement ok
DELETE FROM sd_threshold WHERE grp = 2;

statement ok
INSERT INTO sd_threshold VALUES (4, 999);

statement ok
PRAGMA refresh('mv_thr_sd');

query I
SELECT COUNT(*) FROM (
    SELECT * FROM mv_thr_sd WHERE n > 0
    EXCEPT ALL
    SELECT grp, STDDEV(v), VARIANCE(v), STDDEV_POP(v), VAR_POP(v), COUNT(*)
    FROM sd_threshold GROUP BY grp
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT grp, STDDEV(v), VARIANCE(v), STDDEV_POP(v), VAR_POP(v), COUNT(*)
    FROM sd_threshold GROUP BY grp
    EXCEPT ALL
    SELECT * FROM mv_thr_sd WHERE n > 0
);
----
0

# --- HAVING AVG(x) > k decomposes AVG (q0929 regression) ---
# Bug: RewriteDerivedAggregates only fired when plan->children[0] was directly
# LOGICAL_AGGREGATE_AND_GROUP_BY, but HAVING sits PROJECTION → FILTER → AGGREGATE,
# so AVG wasn't decomposed. The MV stored raw avg() and the delta CTE tried to
# SUM per-group averages, producing drift on any delta that touched the agg'd
# column.
# Fix: walk through a single LOGICAL_FILTER at the top level to reach the agg.

statement ok
CREATE TABLE hva_t(grp INT, v INT);

statement ok
INSERT INTO hva_t VALUES (1,10), (1,20), (2,-5), (2,-15), (3,100);

statement ok
CREATE MATERIALIZED VIEW mv_hva AS
    SELECT grp, AVG(v) AS a FROM hva_t GROUP BY grp HAVING AVG(v) > 0;

query I
SELECT count(*) FROM (
    SELECT * FROM mv_hva
    EXCEPT ALL SELECT grp, AVG(v) FROM hva_t GROUP BY grp HAVING AVG(v) > 0
);
----
0

# MV should have hidden sum+count columns (decomposition succeeded).
query I
SELECT count(*) FROM pragma_table_info('openivm_data_mv_hva') WHERE name LIKE 'openivm_sum_%';
----
1

# Delta: push an existing group over the HAVING threshold and add a new group.
statement ok
INSERT INTO hva_t VALUES (2, 100), (4, 50);

statement ok
PRAGMA refresh('mv_hva');

query I
SELECT count(*) FROM (
    SELECT * FROM mv_hva
    EXCEPT ALL SELECT grp, AVG(v) FROM hva_t GROUP BY grp HAVING AVG(v) > 0
);
----
0

query I
SELECT count(*) FROM (
    SELECT grp, AVG(v) FROM hva_t GROUP BY grp HAVING AVG(v) > 0
    EXCEPT ALL SELECT * FROM mv_hva
);
----
0

# ============================================================
# HAVING that references aggregates NOT in the SELECT list.
# The stripped predicate must reference hidden columns we add to the
# projection (`openivm_having_N`) — otherwise it falls back to rendering
# the aggregate's raw text (`sum(COALESCE(H_AMOUNT, 0))`, `count_star()`)
# into the view WHERE clause, where the base columns don't exist.
# ============================================================

# HAVING COUNT(*) > N when COUNT(*) isn't selected
statement ok
CREATE TABLE hav_hidden_count (w INT, i INT, amt INT);

statement ok
INSERT INTO hav_hidden_count VALUES (1,1,500),(1,1,600),(1,2,100),(1,2,50),(1,2,50),(1,2,50),(1,2,50);

statement ok
CREATE MATERIALIZED VIEW mv_hav_hidden_count AS
    SELECT w, i, SUM(amt) AS revenue FROM hav_hidden_count GROUP BY w, i
    HAVING SUM(amt) > 200 AND COUNT(*) > 3;

query I
SELECT count(*) FROM (
    SELECT * FROM mv_hav_hidden_count
    EXCEPT ALL
    SELECT w, i, SUM(amt) FROM hav_hidden_count GROUP BY w, i HAVING SUM(amt) > 200 AND COUNT(*) > 3
);
----
0

query I
SELECT count(*) FROM (
    SELECT w, i, SUM(amt) FROM hav_hidden_count GROUP BY w, i HAVING SUM(amt) > 200 AND COUNT(*) > 3
    EXCEPT ALL SELECT * FROM mv_hav_hidden_count
);
----
0

# Batched DML: flip one group below the COUNT threshold, push another past both thresholds
statement ok
DELETE FROM hav_hidden_count WHERE w = 1 AND i = 2 AND amt = 50;

statement ok
INSERT INTO hav_hidden_count VALUES (1,1,300),(1,1,50),(1,3,500),(1,3,500),(1,3,500),(1,3,500);

statement ok
UPDATE hav_hidden_count SET amt = amt + 10 WHERE w = 1 AND i = 1;

statement ok
PRAGMA refresh('mv_hav_hidden_count');

query I
SELECT count(*) FROM (
    SELECT * FROM mv_hav_hidden_count
    EXCEPT ALL
    SELECT w, i, SUM(amt) FROM hav_hidden_count GROUP BY w, i HAVING SUM(amt) > 200 AND COUNT(*) > 3
);
----
0

query I
SELECT count(*) FROM (
    SELECT w, i, SUM(amt) FROM hav_hidden_count GROUP BY w, i HAVING SUM(amt) > 200 AND COUNT(*) > 3
    EXCEPT ALL SELECT * FROM mv_hav_hidden_count
);
----
0

# HAVING SUM(COALESCE(x, 0)) — same aggregate function over a different expression
# than the one in SELECT. Left join produces NULLs that COALESCE treats as 0,
# so SUM(H_AMOUNT) and SUM(COALESCE(H_AMOUNT, 0)) diverge for unmatched groups.
statement ok
CREATE TABLE hav_coalesce_c (id INT, w INT, bal INT);

statement ok
CREATE TABLE hav_coalesce_h (c_id INT, c_w INT, amt INT);

statement ok
INSERT INTO hav_coalesce_c VALUES (1,1,100),(2,1,200),(3,1,50);

statement ok
INSERT INTO hav_coalesce_h VALUES (1,1,30),(2,1,250);

statement ok
CREATE MATERIALIZED VIEW mv_hav_coalesce AS
    SELECT c.w, SUM(c.bal) AS balance, SUM(h.amt) AS payments
    FROM hav_coalesce_c c LEFT JOIN hav_coalesce_h h ON c.id = h.c_id AND c.w = h.c_w
    GROUP BY c.w
    HAVING SUM(c.bal) > SUM(COALESCE(h.amt, 0));

query I
SELECT count(*) FROM (
    SELECT * FROM mv_hav_coalesce
    EXCEPT ALL
    SELECT c.w, SUM(c.bal), SUM(h.amt)
    FROM hav_coalesce_c c LEFT JOIN hav_coalesce_h h ON c.id = h.c_id AND c.w = h.c_w
    GROUP BY c.w HAVING SUM(c.bal) > SUM(COALESCE(h.amt, 0))
);
----
0

query I
SELECT count(*) FROM (
    SELECT c.w, SUM(c.bal), SUM(h.amt)
    FROM hav_coalesce_c c LEFT JOIN hav_coalesce_h h ON c.id = h.c_id AND c.w = h.c_w
    GROUP BY c.w HAVING SUM(c.bal) > SUM(COALESCE(h.amt, 0))
    EXCEPT ALL SELECT * FROM mv_hav_coalesce
);
----
0

# Fix B: CTE with AVG/STDDEV + non-pass-through expression in outer SELECT.
# The CTE alias (avg_bal) differs from the top-level alias (avg after ROUND),
# so the hidden openivm_sum_avg_bal / openivm_count_avg_bal columns can't directly
# reconstruct `avg`. CompileAggregateGroups detects the orphan derived alias
# and falls back to group-recompute (delete affected groups, re-insert via the
# full view query).
statement ok
CREATE TABLE fixb_customer (c_w_id INT, c_balance DECIMAL(12,2));

statement ok
INSERT INTO fixb_customer VALUES (1, 10.00), (1, 20.00), (2, 30.00);

statement ok
CREATE MATERIALIZED VIEW fixb_mv AS WITH per_warehouse AS (SELECT c_w_id, AVG(c_balance) AS avg_bal, STDDEV(c_balance) AS std_bal, COUNT(*) AS cnt FROM fixb_customer GROUP BY c_w_id) SELECT c_w_id, ROUND(avg_bal, 2) AS avg_r, ROUND(std_bal, 2) AS std_r, cnt, ROUND(avg_bal / NULLIF(std_bal, 0), 4) AS cv FROM per_warehouse;

# Batched DML before refresh — INSERT + DELETE + UPDATE on the same rows.
statement ok
INSERT INTO fixb_customer VALUES (1, 40.00), (2, 50.00), (3, 100.00);

statement ok
UPDATE fixb_customer SET c_balance = 15.00 WHERE c_w_id = 1 AND c_balance = 20.00;

statement ok
DELETE FROM fixb_customer WHERE c_w_id = 1 AND c_balance = 10.00;

statement ok
PRAGMA refresh('fixb_mv');

query I
SELECT count(*) FROM (SELECT * FROM fixb_mv EXCEPT ALL SELECT c_w_id, ROUND(AVG(c_balance), 2), ROUND(STDDEV(c_balance), 2), COUNT(*), ROUND(AVG(c_balance) / NULLIF(STDDEV(c_balance), 0), 4) FROM fixb_customer GROUP BY c_w_id);
----
0

query I
SELECT count(*) FROM (SELECT c_w_id, ROUND(AVG(c_balance), 2), ROUND(STDDEV(c_balance), 2), COUNT(*), ROUND(AVG(c_balance) / NULLIF(STDDEV(c_balance), 0), 4) FROM fixb_customer GROUP BY c_w_id EXCEPT ALL SELECT * FROM fixb_mv);
----
0

# Fix B variant: outer SELECT exposes AVG/STDDEV directly AS avg_b and std_b,
# but adds a computed `cv` column that references both. `cv` has no direct
# aggregate in the plan, so the orphan detection switches to group-recompute.
statement ok
CREATE MATERIALIZED VIEW fixb_cv AS WITH stats AS (SELECT c_w_id, AVG(c_balance) AS avg_b, STDDEV(c_balance) AS std_b FROM fixb_customer GROUP BY c_w_id) SELECT c_w_id, avg_b, std_b, ROUND(avg_b / NULLIF(std_b, 0), 4) AS cv FROM stats;

statement ok
INSERT INTO fixb_customer VALUES (1, 60.00), (3, 200.00);

statement ok
UPDATE fixb_customer SET c_balance = 80.00 WHERE c_w_id = 2 AND c_balance = 50.00;

statement ok
DELETE FROM fixb_customer WHERE c_w_id = 3 AND c_balance = 100.00;

statement ok
PRAGMA refresh('fixb_cv');

# Use printf('%.12g', …) to absorb 1-ULP AVG(DECIMAL) drift — we only care
# that the MV matches the base query within double precision.
query I
SELECT count(*) FROM (SELECT c_w_id, printf('%.12g', avg_b), printf('%.12g', std_b), printf('%.12g', cv) FROM fixb_cv EXCEPT ALL SELECT c_w_id, printf('%.12g', AVG(c_balance)::DOUBLE), printf('%.12g', STDDEV(c_balance)), printf('%.12g', ROUND(AVG(c_balance)::DOUBLE / NULLIF(STDDEV(c_balance), 0), 4)) FROM fixb_customer GROUP BY c_w_id);
----
0

query I
SELECT count(*) FROM (SELECT c_w_id, printf('%.12g', AVG(c_balance)::DOUBLE), printf('%.12g', STDDEV(c_balance)), printf('%.12g', ROUND(AVG(c_balance)::DOUBLE / NULLIF(STDDEV(c_balance), 0), 4)) FROM fixb_customer GROUP BY c_w_id EXCEPT ALL SELECT c_w_id, printf('%.12g', avg_b), printf('%.12g', std_b), printf('%.12g', cv) FROM fixb_cv);
----
0

# Fix B variant: ROUND(SUM(x) / NULLIF(COUNT(y), 0), N) — no AVG but two raw
# aggregates consumed in one computed column. The "type excess" detection
# (more aggregate_types entries than aggregate columns) triggers
# group-recompute.
statement ok
CREATE TABLE fixb_pay (w INT, d INT, c_bal DECIMAL(12,2), ytd DECIMAL(12,2), pay_cnt INT);

statement ok
INSERT INTO fixb_pay VALUES (1, 1, 10, 50, 2), (1, 1, 20, 60, 3), (1, 2, 30, 70, 1), (2, 1, 100, 120, 4);

statement ok
CREATE MATERIALIZED VIEW fixb_pay_mv AS SELECT w, d, COUNT(c_bal) AS cust, ROUND(SUM(c_bal) / NULLIF(COUNT(c_bal), 0), 2) AS avg_bal, ROUND(SUM(ytd) / NULLIF(SUM(pay_cnt), 0), 2) AS avg_pay FROM fixb_pay GROUP BY w, d;

statement ok
INSERT INTO fixb_pay VALUES (1, 1, 40, 80, 2), (2, 1, 50, 90, 1);

statement ok
UPDATE fixb_pay SET c_bal = 5, ytd = 15, pay_cnt = 1 WHERE w = 1 AND d = 2;

statement ok
DELETE FROM fixb_pay WHERE w = 1 AND d = 1 AND c_bal = 10;

statement ok
PRAGMA refresh('fixb_pay_mv');

query I
SELECT count(*) FROM (SELECT * FROM fixb_pay_mv EXCEPT ALL SELECT w, d, COUNT(c_bal), ROUND(SUM(c_bal) / NULLIF(COUNT(c_bal), 0), 2), ROUND(SUM(ytd) / NULLIF(SUM(pay_cnt), 0), 2) FROM fixb_pay GROUP BY w, d);
----
0

query I
SELECT count(*) FROM (SELECT w, d, COUNT(c_bal), ROUND(SUM(c_bal) / NULLIF(COUNT(c_bal), 0), 2), ROUND(SUM(ytd) / NULLIF(SUM(pay_cnt), 0), 2) FROM fixb_pay GROUP BY w, d EXCEPT ALL SELECT * FROM fixb_pay_mv);
----
0

# ============================================================
# AGGREGATE FILTER (WHERE p) rewrite
# AGG(x) FILTER (WHERE p) → AGG(CASE WHEN p THEN x END) before
# the compatibility checker, so FILTER views are incremental.
# ============================================================

statement ok
CREATE TABLE filter_t (id INT, grp VARCHAR, val INT, active BOOL);

statement ok
INSERT INTO filter_t VALUES (1,'a',10,true),(2,'a',200,true),(3,'a',50,false),(4,'b',300,true),(5,'b',80,false);

statement ok
CREATE MATERIALIZED VIEW filter_mv AS
  SELECT grp,
         COUNT(*) FILTER (WHERE active)       AS active_cnt,
         SUM(val)  FILTER (WHERE val > 100)   AS big_sum,
         AVG(val)  FILTER (WHERE active)      AS avg_active
  FROM filter_t GROUP BY grp;

query I
SELECT count(*) FROM (SELECT * FROM filter_mv EXCEPT ALL SELECT grp, COUNT(*) FILTER (WHERE active), SUM(val) FILTER (WHERE val > 100), AVG(val) FILTER (WHERE active) FROM filter_t GROUP BY grp);
----
0

query I
SELECT count(*) FROM (SELECT grp, COUNT(*) FILTER (WHERE active), SUM(val) FILTER (WHERE val > 100), AVG(val) FILTER (WHERE active) FROM filter_t GROUP BY grp EXCEPT ALL SELECT * FROM filter_mv);
----
0

# --- stress: batch conflicting DML then single refresh ---
