    SELECT * FROM mv_user_items
    EXCEPT ALL
    SELECT user_id, LIST(item_id ORDER BY item_id), COUNT(*)
    FROM list_events GROUP BY user_id
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT user_id, LIST(item_id ORDER BY item_id), COUNT(*)
    FROM list_events GROUP BY user_id
    EXCEPT ALL SELECT * FROM mv_user_items
);
