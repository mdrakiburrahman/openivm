# name: test/sql/schema_evolution.test
# description: Test ALTER TABLE handling — delta table sync and column reference blocking
# group: [sql]

require openivm

statement ok
SET openivm_files_path='__TEST_DIR__';

# ==========================================
# Setup
# ==========================================

statement ok
CREATE TABLE t (id INT, val INT, extra INT);

statement ok
INSERT INTO t VALUES (1, 10, 100), (2, 20, 200), (3, 10, 300);

statement ok
CREATE MATERIALIZED VIEW mv AS
    SELECT val, SUM(val) AS total, COUNT(*) AS cnt FROM t GROUP BY val;

query III
SELECT val, total, cnt FROM mv ORDER BY val;
----
10	20	2
20	20	1

# ==========================================
# Test 1: ADD COLUMN — delta synced, IVM works
# ==========================================

statement ok
ALTER TABLE t ADD COLUMN bonus INT;

statement ok
INSERT INTO t VALUES (4, 30, 400, 50);

statement ok
PRAGMA refresh('mv');

query III
SELECT val, total, cnt FROM mv ORDER BY val;
----
10	20	2
20	20	1
30	30	1

query I
SELECT count(*) FROM (
    SELECT val, total, cnt FROM mv
    EXCEPT ALL
    SELECT val, SUM(val), COUNT(*) FROM t GROUP BY val
);
----
0

# ==========================================
# Test 2: DROP unreferenced column — delta synced, IVM works
# ==========================================

statement ok
ALTER TABLE t DROP COLUMN bonus;

statement ok
INSERT INTO t VALUES (5, 10, 500);

statement ok
PRAGMA refresh('mv');

query I
SELECT count(*) FROM (
    SELECT val, total, cnt FROM mv
    EXCEPT ALL
    SELECT val, SUM(val), COUNT(*) FROM t GROUP BY val
);
----
0

# ==========================================
# Test 3: DROP referenced column — blocked with error
# ==========================================

statement error
ALTER TABLE t DROP COLUMN val;
----
referenced by materialized view

# ==========================================
# Test 4: RENAME unreferenced column — delta synced, IVM works
# ==========================================

statement ok
ALTER TABLE t RENAME COLUMN extra TO metadata;

statement ok
INSERT INTO t VALUES (6, 20, 600);

statement ok
PRAGMA refresh('mv');

query I
SELECT count(*) FROM (
    SELECT val, total, cnt FROM mv
    EXCEPT ALL
    SELECT val, SUM(val), COUNT(*) FROM t GROUP BY val
);
----
0

# ==========================================
# Test 5: RENAME referenced column — metadata rewritten, MV output preserved
# ==========================================

statement ok
ALTER TABLE t RENAME COLUMN val TO amount;

statement ok
INSERT INTO t VALUES (9, 30, 900);

statement ok
UPDATE t SET amount = 40 WHERE id = 6;

statement ok
DELETE FROM t WHERE id = 1;

statement ok
PRAGMA refresh('mv');

query I
SELECT count(*) FROM (
    SELECT val, total, cnt FROM mv
    EXCEPT ALL
    SELECT amount AS val, SUM(amount), COUNT(*) FROM t GROUP BY amount
);
----
0

query I
SELECT count(*) FROM (
    SELECT amount AS val, SUM(amount), COUNT(*) FROM t GROUP BY amount
    EXCEPT ALL
    SELECT val, total, cnt FROM mv
);
----
0

# ==========================================
# Test 6: ADD + DROP cycle — multiple schema changes, IVM stays correct
# ==========================================

statement ok
ALTER TABLE t ADD COLUMN temp1 INT;

statement ok
ALTER TABLE t ADD COLUMN temp2 VARCHAR;

statement ok
INSERT INTO t VALUES (7, 10, 700, 1, 'hello');

statement ok
PRAGMA refresh('mv');

statement ok
ALTER TABLE t DROP COLUMN temp1;

statement ok
ALTER TABLE t DROP COLUMN temp2;

statement ok
INSERT INTO t VALUES (8, 20, 800);

statement ok
PRAGMA refresh('mv');

query I
SELECT count(*) FROM (
    SELECT val, total, cnt FROM mv
    EXCEPT ALL
    SELECT amount AS val, SUM(amount), COUNT(*) FROM t GROUP BY amount
);
----
0

query I
SELECT count(*) FROM (
    SELECT amount AS val, SUM(amount), COUNT(*) FROM t GROUP BY amount
    EXCEPT ALL
    SELECT val, total, cnt FROM mv
);
----
0

# ==========================================
# Test 7: DISTINCT aux state survives referenced rename and aux-only repair
# ==========================================

statement ok
SET openivm_distinct_aux_state = true;

statement ok
CREATE TABLE se_dist (grp INT, machine VARCHAR, cores INT, spare INT);

statement ok
INSERT INTO se_dist VALUES
    (1, 'm1', 8, 0),
    (1, 'm1', 8, 0),
    (1, 'm2', 16, 0),
    (2, 'm3', 4, 0);

statement ok
CREATE MATERIALIZED VIEW se_dist_mv AS
    SELECT grp, SUM(cores) AS total_cores
    FROM (SELECT DISTINCT grp, machine, cores FROM se_dist WHERE machine IS NOT NULL) d
    GROUP BY grp;

statement ok
ALTER TABLE se_dist RENAME COLUMN cores TO cpu;

statement ok
INSERT INTO se_dist VALUES (1, 'm4', 32, 0);

statement ok
DELETE FROM se_dist WHERE machine = 'm1' AND cpu = 8;

statement ok
UPDATE se_dist SET cpu = 5 WHERE machine = 'm3';

statement ok
PRAGMA refresh('se_dist_mv');

query I
SELECT count(*) FROM (
    SELECT * FROM se_dist_mv
    EXCEPT ALL
    SELECT grp, SUM(cpu) AS total_cores
    FROM (SELECT DISTINCT grp, machine, cpu FROM se_dist WHERE machine IS NOT NULL) d
    GROUP BY grp
);
----
0

query I
SELECT count(*) FROM (
    SELECT grp, SUM(cpu) AS total_cores
    FROM (SELECT DISTINCT grp, machine, cpu FROM se_dist WHERE machine IS NOT NULL) d
    GROUP BY grp
    EXCEPT ALL
    SELECT * FROM se_dist_mv
);
----
0

query III
SELECT machine, cores, _count FROM openivm_distinct_count_se_dist_mv ORDER BY machine;
----
m2	16	1
m3	5	1
m4	32	1

statement error
ALTER TABLE se_dist DROP COLUMN cpu;
----
referenced by materialized view

statement ok
DROP TABLE openivm_distinct_count_se_dist_mv;

statement ok
PRAGMA refresh('se_dist_mv');

query I
SELECT count(*) FROM (
    SELECT * FROM se_dist_mv
    EXCEPT ALL
    SELECT grp, SUM(cpu) AS total_cores
    FROM (SELECT DISTINCT grp, machine, cpu FROM se_dist WHERE machine IS NOT NULL) d
    GROUP BY grp
);
----
0

query I
SELECT count(*) FROM (
    SELECT grp, SUM(cpu) AS total_cores
    FROM (SELECT DISTINCT grp, machine, cpu FROM se_dist WHERE machine IS NOT NULL) d
    GROUP BY grp
    EXCEPT ALL
    SELECT * FROM se_dist_mv
);
----
0

statement ok
SET openivm_distinct_aux_state = false;

# ==========================================
# Test 8: filtered group-count aux uses renamed source column incrementally
# ==========================================

statement ok
CREATE TABLE se_fgc (wid INT, cid INT, balance DOUBLE, extra INT);

statement ok
INSERT INTO se_fgc VALUES (1, 1, 100.0, 0), (2, 1, -50.0, 0), (3, 1, 10.0, 0);

statement ok
CREATE MATERIALIZED VIEW se_fgc_mv AS
    SELECT COUNT(*) AS neg_groups
    FROM (SELECT wid, SUM(balance) AS total FROM se_fgc GROUP BY wid) grouped
    WHERE total < 0;

statement ok
ALTER TABLE se_fgc RENAME COLUMN balance TO bal;

statement ok
INSERT INTO se_fgc VALUES (1, 2, -200.0, 0);

statement ok
DELETE FROM se_fgc WHERE wid = 2 AND cid = 1;

statement ok
UPDATE se_fgc SET bal = -20.0 WHERE wid = 3 AND cid = 1;

statement ok
PRAGMA refresh('se_fgc_mv');

query I
SELECT count(*) FROM (
    SELECT * FROM se_fgc_mv
    EXCEPT ALL
    SELECT COUNT(*) AS neg_groups
    FROM (SELECT wid, SUM(bal) AS total FROM se_fgc GROUP BY wid) grouped
    WHERE total < 0
);
----
0

query I
SELECT count(*) FROM (
    SELECT COUNT(*) AS neg_groups
    FROM (SELECT wid, SUM(bal) AS total FROM se_fgc GROUP BY wid) grouped
    WHERE total < 0
    EXCEPT ALL
    SELECT * FROM se_fgc_mv
);
----
0

