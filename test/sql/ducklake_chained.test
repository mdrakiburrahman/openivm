# ==========================================
# Cascade mode across DuckLake schemas
# ==========================================

statement ok
SET openivm_cascade_refresh = 'downstream';

statement ok
CREATE SCHEMA dl.bronze;

statement ok
CREATE SCHEMA dl.silver;

statement ok
CREATE SCHEMA dl.gold;

statement ok
CREATE TABLE dl.bronze.cross_schema_base (id INT, amount INT);

statement ok
INSERT INTO dl.bronze.cross_schema_base VALUES (1, 10);

statement ok
CREATE MATERIALIZED VIEW dl.silver.cross_schema_l1 AS
  SELECT id, amount FROM dl.bronze.cross_schema_base;

statement ok
CREATE MATERIALIZED VIEW dl.gold.cross_schema_l2 AS
  SELECT id, amount FROM dl.silver.openivm_data_cross_schema_l1;

statement ok
INSERT INTO dl.bronze.cross_schema_base VALUES (2, 20);

# Only refresh level 1 — level 2 should cascade in its own gold schema
statement ok
PRAGMA refresh_options('dl', 'silver', 'cross_schema_l1');

query II rowsort
SELECT id, amount FROM dl.silver.cross_schema_l1 ORDER BY id;
----
1	10
2	20

query II rowsort
SELECT id, amount FROM dl.gold.cross_schema_l2 ORDER BY id;
----
1	10
2	20

statement ok
SET openivm_cascade_refresh = 'upstream';

statement ok
INSERT INTO dl.bronze.cross_schema_base VALUES (3, 30);

# Only refresh level 2 — level 1 should cascade in its own silver schema first
statement ok
PRAGMA refresh_options('dl', 'gold', 'cross_schema_l2');

query II rowsort
SELECT id, amount FROM dl.silver.cross_schema_l1 ORDER BY id;
----
1	10
2	20
3	30

query II rowsort
SELECT id, amount FROM dl.gold.cross_schema_l2 ORDER BY id;
----
1	10
2	20
3	30

# Explicit refresh after an upstream delete/rewrite must not duplicate rows in the downstream schema.
# This covers gold views that read silver.openivm_data_* tables, as in the benchmark.
statement ok
SET openivm_cascade_refresh = 'off';

statement ok
DELETE FROM dl.bronze.cross_schema_base WHERE id = 2;

statement ok
PRAGMA refresh_options('dl', 'silver', 'cross_schema_l1');

statement ok
PRAGMA refresh_options('dl', 'gold', 'cross_schema_l2');

query I
SELECT count(*) FROM dl.gold.cross_schema_l2;
----
2

query I
SELECT count(*) FROM (
  SELECT id, amount FROM dl.gold.cross_schema_l2
  EXCEPT ALL
  SELECT id, amount FROM dl.silver.cross_schema_l1
);
----
0

query I
SELECT count(*) FROM (
  SELECT id, amount FROM dl.silver.cross_schema_l1
  EXCEPT ALL
  SELECT id, amount FROM dl.gold.cross_schema_l2
);
----
0

statement ok
CREATE MATERIALIZED VIEW dl.gold.cross_schema_join_l2 AS
  WITH l1 AS (
    SELECT id, amount FROM dl.silver.cross_schema_l1
  )
  SELECT l1.id, l1.amount, b.amount AS base_amount
  FROM l1
  JOIN dl.bronze.cross_schema_base b USING (id);

statement ok
INSERT INTO dl.bronze.cross_schema_base VALUES (4, 40);

statement ok
PRAGMA refresh_options('dl', 'silver', 'cross_schema_l1');

statement ok
PRAGMA refresh_options('dl', 'gold', 'cross_schema_join_l2');

query I
SELECT count(*) FROM (
  SELECT id, amount, base_amount FROM dl.gold.cross_schema_join_l2
  EXCEPT ALL
  SELECT id, amount, amount AS base_amount FROM dl.silver.cross_schema_l1
);
----
0

query I
SELECT count(*) FROM (
  SELECT id, amount, amount AS base_amount FROM dl.silver.cross_schema_l1
  EXCEPT ALL
  SELECT id, amount, base_amount FROM dl.gold.cross_schema_join_l2
);
----
0

# Projection chains use the upstream MV's materialized data table directly.
statement ok
CREATE TABLE dl.bronze.catalog_chain_base (id INT, amount INT);

statement ok
INSERT INTO dl.bronze.catalog_chain_base VALUES (1, 10), (2, 20);

statement ok
CREATE MATERIALIZED VIEW dl.bronze.catalog_chain_l1 AS
  SELECT id, amount FROM dl.bronze.catalog_chain_base;

statement ok
CREATE MATERIALIZED VIEW dl.silver.catalog_chain_l2 AS
  SELECT id, amount FROM dl.bronze.catalog_chain_l1;

query II
SELECT table_name, source_catalog
FROM openivm_delta_tables
WHERE view_name = 'catalog_chain_l2'
ORDER BY table_name;
----
openivm_data_catalog_chain_l1	dl

statement ok
INSERT INTO dl.bronze.catalog_chain_base VALUES (3, 30);

statement ok
PRAGMA refresh_options('dl', 'bronze', 'catalog_chain_l1');

statement ok
PRAGMA refresh_options('dl', 'silver', 'catalog_chain_l2');

query I
SELECT count(*) FROM (
  SELECT id, amount FROM dl.silver.catalog_chain_l2
  EXCEPT ALL
  SELECT id, amount FROM dl.bronze.catalog_chain_l1
);
----
0

query I
SELECT count(*) FROM (
  SELECT id, amount FROM dl.bronze.catalog_chain_l1
  EXCEPT ALL
  SELECT id, amount FROM dl.silver.catalog_chain_l2
);
----
0

# Benchmark-shaped persisted metadata can track an upstream MV through its
# companion delta_<upstream_mv> table. The downstream MV lives in DuckLake, but
# that companion delta table is a physical OpenIVM table, so refresh metadata
# updates and empty-delta probes must qualify it via source_catalog/source_schema
# instead of the target DuckLake schema.
statement ok
CREATE TABLE dl.bronze.catalog_window_base (
  sym VARCHAR,
  trade_date DATE,
  low_price INT,
  high_price INT
);

statement ok
INSERT INTO dl.bronze.catalog_window_base VALUES
  ('A', DATE '2026-01-01', 10, 20),
  ('A', DATE '2026-01-02', 8, 22),
  ('B', DATE '2026-01-01', 30, 40);

statement ok
CREATE MATERIALIZED VIEW dl.bronze.catalog_window_l1 AS
  SELECT sym, trade_date, low_price, high_price FROM dl.bronze.catalog_window_base;

statement ok
CREATE MATERIALIZED VIEW dl.silver.catalog_window_l2 AS
  SELECT
    sym,
    trade_date,
    low_price,
    high_price,
    MIN(low_price) OVER (PARTITION BY sym ORDER BY trade_date) AS running_low,
    MAX(high_price) OVER (PARTITION BY sym ORDER BY trade_date) AS running_high
  FROM dl.bronze.catalog_window_l1;

statement ok
UPDATE openivm_delta_tables
SET table_name = 'openivm_delta_catalog_window_l1',
    catalog_type = 'duckdb',
    source_catalog = 'dl',
    source_schema = 'bronze'
WHERE view_name = 'catalog_window_l2'
  AND table_name = 'openivm_data_catalog_window_l1';

query II
SELECT table_name, source_schema
FROM openivm_delta_tables
WHERE view_name = 'catalog_window_l2'
ORDER BY table_name;
----
openivm_delta_catalog_window_l1	bronze

statement ok
INSERT INTO dl.bronze.catalog_window_base VALUES
  ('A', DATE '2026-01-03', 7, 25),
  ('B', DATE '2026-01-02', 28, 41);

statement ok
PRAGMA refresh_options('dl', 'bronze', 'catalog_window_l1');

# The in-memory DuckLake test normally tracks the upstream MV through DuckLake
# snapshots. Seed the companion delta table to emulate the benchmark's persisted
# delta_<upstream_mv> dependency and force the downstream refresh to read it.
statement ok
INSERT INTO dl.bronze.openivm_delta_catalog_window_l1
SELECT sym, trade_date, low_price, high_price, 1, now()
FROM dl.bronze.catalog_window_l1
WHERE trade_date IN (DATE '2026-01-02', DATE '2026-01-03');

statement ok
PRAGMA refresh_options('dl', 'silver', 'catalog_window_l2');

query I
SELECT count(*) FROM (
  SELECT * FROM dl.silver.catalog_window_l2
  EXCEPT ALL
  SELECT
    sym,
    trade_date,
    low_price,
    high_price,
    MIN(low_price) OVER (PARTITION BY sym ORDER BY trade_date) AS running_low,
    MAX(high_price) OVER (PARTITION BY sym ORDER BY trade_date) AS running_high
  FROM dl.bronze.catalog_window_l1
);
----
0

query I
SELECT count(*) FROM (
  SELECT
    sym,
    trade_date,
    low_price,
    high_price,
    MIN(low_price) OVER (PARTITION BY sym ORDER BY trade_date) AS running_low,
    MAX(high_price) OVER (PARTITION BY sym ORDER BY trade_date) AS running_high
  FROM dl.bronze.catalog_window_l1
  EXCEPT ALL
  SELECT * FROM dl.silver.catalog_window_l2
);
----
0

# A second downstream refresh with no upstream changes must probe the same
# physical companion delta table and then skip cleanly.
statement ok
PRAGMA refresh_options('dl', 'silver', 'catalog_window_l2');

query I
SELECT count(*) FROM (
  SELECT * FROM dl.silver.catalog_window_l2
  EXCEPT ALL
  SELECT
    sym,
    trade_date,
    low_price,
    high_price,
    MIN(low_price) OVER (PARTITION BY sym ORDER BY trade_date) AS running_low,
    MAX(high_price) OVER (PARTITION BY sym ORDER BY trade_date) AS running_high
  FROM dl.bronze.catalog_window_l1
);
----
0

# ==========================================
# Cascade mode: downstream
# Refreshing mv_region should auto-refresh mv_top
# ==========================================

statement ok
SET openivm_cascade_refresh = 'downstream';

statement ok
INSERT INTO dl.sales VALUES (8, 'east', 1000);

# Only refresh level 1 — level 2 should cascade automatically
statement ok
PRAGMA refresh('mv_region');

# Both levels should be correct
query I
SELECT count(*) FROM (
  SELECT region, total, cnt FROM dl.mv_region
  EXCEPT ALL
  SELECT region, SUM(amount), COUNT(*) FROM dl.sales GROUP BY region
);
----
0

query I
SELECT count(*) FROM (
  SELECT region, total, cnt FROM dl.mv_top
  EXCEPT ALL
  SELECT region, SUM(amount), COUNT(*) FROM dl.sales GROUP BY region HAVING SUM(amount) > 100
);
----
0

query I
SELECT count(*) FROM (
  SELECT region, SUM(amount), COUNT(*) FROM dl.sales GROUP BY region HAVING SUM(amount) > 100
  EXCEPT ALL
  SELECT region, total, cnt FROM dl.mv_top
);
----
0

# ==========================================
# Cascade mode: upstream
# Refreshing mv_top should auto-refresh mv_region first
# ==========================================

statement ok
SET openivm_cascade_refresh = 'upstream';

statement ok
INSERT INTO dl.sales VALUES (9, 'west', 300);

# Only refresh level 2 — level 1 should be refreshed first
statement ok
PRAGMA refresh('mv_top');

query I
SELECT count(*) FROM (
  SELECT region, total, cnt FROM dl.mv_region
  EXCEPT ALL
  SELECT region, SUM(amount), COUNT(*) FROM dl.sales GROUP BY region
);
----
0

query I
SELECT count(*) FROM (
  SELECT region, total, cnt FROM dl.mv_top
  EXCEPT ALL
  SELECT region, SUM(amount), COUNT(*) FROM dl.sales GROUP BY region HAVING SUM(amount) > 100
);
----
