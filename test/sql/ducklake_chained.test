# name: test/sql/ducklake_chained.test
# description: Test chained MVs (table → mv1 → mv2) with DuckLake base tables
# group: [sql]

require openivm

require parquet

statement ok
INSTALL ducklake;

statement ok
LOAD ducklake;

statement ok
ATTACH '__TEST_DIR__/ducklake_chained.db' AS dl (TYPE ducklake);

# Disable auto cascade — refresh each MV explicitly in order
statement ok
SET openivm_cascade_refresh = 'off';

# ==========================================
# 2-level chain: dl.sales → dl.mv_region → dl.mv_top
# ==========================================

statement ok
CREATE TABLE dl.sales (id INT, region VARCHAR, amount INT);

statement ok
INSERT INTO dl.sales VALUES (1, 'east', 100), (2, 'west', 200), (3, 'east', 150), (4, 'south', 50);

# Level 1: aggregate per region
statement ok
CREATE MATERIALIZED VIEW dl.mv_region AS
  SELECT region, SUM(amount) as total, COUNT(*) as cnt
  FROM dl.sales GROUP BY region;

# Level 2: filter top regions
statement ok
CREATE MATERIALIZED VIEW dl.mv_top AS
  SELECT region, total, cnt FROM dl.mv_region WHERE total > 100;

# Initial state
query III rowsort
SELECT * FROM dl.mv_region ORDER BY region;
----
east	250	2
south	50	1
west	200	1

query III rowsort
SELECT * FROM dl.mv_top ORDER BY region;
----
east	250	2
west	200	1

# --- Insert: boost south above threshold ---
statement ok
INSERT INTO dl.sales VALUES (5, 'south', 200);

statement ok
PRAGMA refresh('mv_region');

statement ok
PRAGMA refresh('mv_top');

# EXCEPT ALL for level 1
query I
SELECT count(*) FROM (
  SELECT region, total, cnt FROM dl.mv_region
  EXCEPT ALL
  SELECT region, SUM(amount), COUNT(*) FROM dl.sales GROUP BY region
);
----
0

query I
SELECT count(*) FROM (
  SELECT region, SUM(amount), COUNT(*) FROM dl.sales GROUP BY region
  EXCEPT ALL
  SELECT region, total, cnt FROM dl.mv_region
);
----
0

# EXCEPT ALL for level 2
query I
SELECT count(*) FROM (
  SELECT region, total, cnt FROM dl.mv_top
  EXCEPT ALL
  SELECT region, SUM(amount), COUNT(*) FROM dl.sales GROUP BY region HAVING SUM(amount) > 100
);
----
0

query I
SELECT count(*) FROM (
SELECT region, SUM(amount), COUNT(*) FROM dl.sales GROUP BY region HAVING SUM(amount) > 100
  EXCEPT ALL
  SELECT region, total, cnt FROM dl.mv_top
);
----
0

# ==========================================
# Empty upstream cascade should skip unchanged ancestors and advance DuckLake
# snapshots for sources proven unchanged. A later real source update must still
# be detected.
# ==========================================

statement ok
SET openivm_cascade_refresh = 'upstream';

statement ok
SET openivm_skip_empty_deltas = true;

statement ok
CREATE TABLE dl.chain_skip_base (id INTEGER, v INTEGER);

statement ok
CREATE TABLE dl.chain_skip_unrelated (id INTEGER);

statement ok
INSERT INTO dl.chain_skip_base VALUES (1, 10);

statement ok
CREATE MATERIALIZED VIEW dl.chain_skip_l1 AS
SELECT id, v FROM dl.chain_skip_base;

statement ok
CREATE MATERIALIZED VIEW dl.chain_skip_l2 AS
SELECT id, v * 2 AS doubled FROM dl.chain_skip_l1;

statement ok
CREATE TEMP TABLE chain_skip_snapshots AS
SELECT view_name, table_name, last_snapshot_id AS snap
FROM openivm_delta_tables
WHERE view_name IN ('chain_skip_l1', 'chain_skip_l2');

statement ok
INSERT INTO dl.chain_skip_unrelated VALUES (1);

statement ok
PRAGMA refresh('chain_skip_l2');

query I
SELECT count(*) FROM openivm_delta_tables d
JOIN chain_skip_snapshots s
  ON d.view_name = s.view_name AND d.table_name = s.table_name
WHERE d.last_snapshot_id <= s.snap;
----
0

query I
SELECT count(*) FROM (
  SELECT id, v FROM dl.chain_skip_l1
  EXCEPT ALL
  SELECT id, v FROM dl.chain_skip_base
);
----
0

query I
SELECT count(*) FROM (
  SELECT id, v FROM dl.chain_skip_base
  EXCEPT ALL
  SELECT id, v FROM dl.chain_skip_l1
);
----
0

query I
SELECT count(*) FROM (
  SELECT id, doubled FROM dl.chain_skip_l2
  EXCEPT ALL
  SELECT id, v * 2 AS doubled FROM dl.chain_skip_base
);
----
0

query I
SELECT count(*) FROM (
  SELECT id, v * 2 AS doubled FROM dl.chain_skip_base
  EXCEPT ALL
  SELECT id, doubled FROM dl.chain_skip_l2
);
----
0

statement ok
INSERT INTO dl.chain_skip_base VALUES (2, 20);

statement ok
PRAGMA refresh('chain_skip_l2');

query I
SELECT count(*) FROM (
  SELECT id, v FROM dl.chain_skip_l1
  EXCEPT ALL
  SELECT id, v FROM dl.chain_skip_base
);
----
0

query I
SELECT count(*) FROM (
  SELECT id, v FROM dl.chain_skip_base
  EXCEPT ALL
  SELECT id, v FROM dl.chain_skip_l1
);
----
0

query I
SELECT count(*) FROM (
  SELECT id, doubled FROM dl.chain_skip_l2
  EXCEPT ALL
  SELECT id, v * 2 AS doubled FROM dl.chain_skip_base
);
----
0

query I
SELECT count(*) FROM (
  SELECT id, v * 2 AS doubled FROM dl.chain_skip_base
  EXCEPT ALL
  SELECT id, doubled FROM dl.chain_skip_l2
);
----
0

# ==========================================
# Cross-catalog DuckLake pipeline with non-dl catalog names
# ==========================================

statement ok
SET openivm_cascade_refresh = 'off';

statement ok
ATTACH '__TEST_DIR__/ducklake_chain_a.db' AS chain_a (TYPE ducklake);

statement ok
ATTACH '__TEST_DIR__/ducklake_chain_b.db' AS chain_b (TYPE ducklake);

statement ok
CREATE TABLE chain_a.pipeline_src (id INT, amount INT);

statement ok
INSERT INTO chain_a.pipeline_src VALUES (1, 10), (2, 20);

statement ok
CREATE MATERIALIZED VIEW chain_b.pipeline_l1 AS
SELECT id, amount FROM chain_a.pipeline_src;

statement ok
CREATE MATERIALIZED VIEW chain_a.pipeline_l2 AS
SELECT id, amount, amount * 2 AS doubled FROM chain_b.pipeline_l1;

query II rowsort
SELECT table_catalog, table_name
FROM information_schema.tables
WHERE table_name IN ('openivm_data_pipeline_l1', 'openivm_delta_pipeline_l1',
                     'openivm_data_pipeline_l2', 'openivm_delta_pipeline_l2')
ORDER BY table_catalog, table_name;
----
chain_a	openivm_data_pipeline_l2
chain_a	openivm_delta_pipeline_l2
chain_b	openivm_data_pipeline_l1
chain_b	openivm_delta_pipeline_l1

statement ok
INSERT INTO chain_a.pipeline_src VALUES (3, 30);

statement ok
PRAGMA refresh_options('chain_b', 'main', 'pipeline_l1');

statement ok
PRAGMA refresh_options('chain_a', 'main', 'pipeline_l2');

query I
SELECT count(*) FROM (
  SELECT id, amount FROM chain_a.pipeline_src
  EXCEPT ALL
  SELECT id, amount FROM chain_b.pipeline_l1
);
----
0

query I
SELECT count(*) FROM (
  SELECT id, amount FROM chain_b.pipeline_l1
  EXCEPT ALL
  SELECT id, amount FROM chain_a.pipeline_src
);
----
0

query I
SELECT count(*) FROM (
  SELECT id, amount, amount * 2 AS doubled FROM chain_b.pipeline_l1
  EXCEPT ALL
  SELECT id, amount, doubled FROM chain_a.pipeline_l2
);
----
0

query I
SELECT count(*) FROM (
  SELECT id, amount, doubled FROM chain_a.pipeline_l2
  EXCEPT ALL
  SELECT id, amount, amount * 2 AS doubled FROM chain_b.pipeline_l1
);
----
0

