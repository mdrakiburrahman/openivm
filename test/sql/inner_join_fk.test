# ==========================================
# Test 7: 2-table join with FK (simpler case)
# ==========================================

statement ok
CREATE TABLE departments(dept_id INTEGER PRIMARY KEY, dept_name VARCHAR);

statement ok
CREATE TABLE employees(emp_id INTEGER, dept_id INTEGER REFERENCES departments(dept_id), salary INTEGER);

statement ok
INSERT INTO departments VALUES (1, 'Engineering'), (2, 'Sales');

statement ok
INSERT INTO employees VALUES (1, 1, 100000), (2, 1, 120000), (3, 2, 80000);

statement ok
CREATE MATERIALIZED VIEW dept_costs AS
    SELECT d.dept_name, SUM(e.salary) as total_salary, COUNT(*) as headcount
    FROM employees e JOIN departments d ON e.dept_id = d.dept_id
    GROUP BY d.dept_name;

# Insert-only dimension change — FK pruning should apply
statement ok
INSERT INTO departments VALUES (3, 'Marketing');

statement ok
PRAGMA refresh('dept_costs');

query I
SELECT COUNT(*) FROM (
    SELECT d.dept_name, SUM(e.salary) as total_salary, COUNT(*) as headcount
    FROM employees e JOIN departments d ON e.dept_id = d.dept_id GROUP BY d.dept_name
    EXCEPT ALL SELECT * FROM dept_costs
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM dept_costs
    EXCEPT ALL
    SELECT d.dept_name, SUM(e.salary) as total_salary, COUNT(*) as headcount
    FROM employees e JOIN departments d ON e.dept_id = d.dept_id GROUP BY d.dept_name
);
----
0

# Now insert an employee in the new department
statement ok
INSERT INTO employees VALUES (4, 3, 90000);

statement ok
PRAGMA refresh('dept_costs');

query III
SELECT * FROM dept_costs ORDER BY dept_name;
----
Engineering	220000	2
Marketing	90000	1
Sales	80000	1

query I
SELECT COUNT(*) FROM (
    SELECT d.dept_name, SUM(e.salary) as total_salary, COUNT(*) as headcount
    FROM employees e JOIN departments d ON e.dept_id = d.dept_id GROUP BY d.dept_name
    EXCEPT ALL SELECT * FROM dept_costs
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM dept_costs
    EXCEPT ALL
    SELECT d.dept_name, SUM(e.salary) as total_salary, COUNT(*) as headcount
    FROM employees e JOIN departments d ON e.dept_id = d.dept_id GROUP BY d.dept_name
);
----
0

# ==========================================
# Test 8: Join WITHOUT FK — no pruning, still correct
# ==========================================

statement ok
CREATE TABLE t_left(a INTEGER, b INTEGER);

statement ok
CREATE TABLE t_right(b INTEGER, c INTEGER);

statement ok
INSERT INTO t_left VALUES (1, 10), (2, 20);

statement ok
INSERT INTO t_right VALUES (10, 100), (20, 200);

statement ok
CREATE MATERIALIZED VIEW mv_no_fk AS SELECT t_left.a, t_right.c FROM t_left JOIN t_right ON t_left.b = t_right.b;

statement ok
INSERT INTO t_right VALUES (30, 300);

statement ok
INSERT INTO t_left VALUES (3, 30);

statement ok
PRAGMA refresh('mv_no_fk');

query I
SELECT COUNT(*) FROM (
    SELECT t_left.a, t_right.c FROM t_left JOIN t_right ON t_left.b = t_right.b
    EXCEPT ALL SELECT * FROM mv_no_fk
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM mv_no_fk
    EXCEPT ALL
    SELECT t_left.a, t_right.c FROM t_left JOIN t_right ON t_left.b = t_right.b
);
----
0
