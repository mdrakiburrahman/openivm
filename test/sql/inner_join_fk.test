# name: test/sql/inner_join_fk.test
# description: Test FK-aware inclusion-exclusion pruning for IVM joins
# group: [sql]

require openivm

# ==========================================
# Star schema: 1 fact table, 2 dimension tables with FKs
# ==========================================

statement ok
CREATE TABLE dim_product(product_id INTEGER PRIMARY KEY, name VARCHAR);

statement ok
CREATE TABLE dim_region(region_id INTEGER PRIMARY KEY, region_name VARCHAR);

statement ok
CREATE TABLE fact_sales(sale_id INTEGER, product_id INTEGER REFERENCES dim_product(product_id), region_id INTEGER REFERENCES dim_region(region_id), amount DECIMAL(10,2));

statement ok
INSERT INTO dim_product VALUES (1, 'Widget'), (2, 'Gadget'), (3, 'Doohickey');

statement ok
INSERT INTO dim_region VALUES (10, 'North'), (20, 'South');

statement ok
INSERT INTO fact_sales VALUES (1, 1, 10, 100.0), (2, 2, 20, 200.0), (3, 1, 20, 150.0);

statement ok
CREATE MATERIALIZED VIEW fk_star AS
    SELECT p.name, r.region_name, SUM(f.amount) as total, COUNT(*) as cnt
    FROM fact_sales f
    JOIN dim_product p ON f.product_id = p.product_id
    JOIN dim_region r ON f.region_id = r.region_id
    GROUP BY p.name, r.region_name;

# ==========================================
# Test 1: INSERT into dimension only (insert-only, FK pruning applies)
# New PK value has no FK references — join with fact produces nothing.
# ==========================================

statement ok
INSERT INTO dim_product VALUES (4, 'Thingamajig');

statement ok
PRAGMA refresh('fk_star');

query I
SELECT COUNT(*) FROM (
    SELECT p.name, r.region_name, SUM(f.amount) as total, COUNT(*) as cnt
    FROM fact_sales f JOIN dim_product p ON f.product_id = p.product_id
    JOIN dim_region r ON f.region_id = r.region_id GROUP BY p.name, r.region_name
    EXCEPT ALL SELECT * FROM fk_star
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM fk_star
    EXCEPT ALL
    SELECT p.name, r.region_name, SUM(f.amount) as total, COUNT(*) as cnt
    FROM fact_sales f JOIN dim_product p ON f.product_id = p.product_id
    JOIN dim_region r ON f.region_id = r.region_id GROUP BY p.name, r.region_name
);
----
0

# ==========================================
# Test 2: INSERT into fact referencing the new dimension value
# ==========================================

statement ok
INSERT INTO fact_sales VALUES (4, 4, 10, 300.0);

statement ok
PRAGMA refresh('fk_star');

query I
SELECT COUNT(*) FROM (
    SELECT p.name, r.region_name, SUM(f.amount) as total, COUNT(*) as cnt
    FROM fact_sales f JOIN dim_product p ON f.product_id = p.product_id
    JOIN dim_region r ON f.region_id = r.region_id GROUP BY p.name, r.region_name
    EXCEPT ALL SELECT * FROM fk_star
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM fk_star
    EXCEPT ALL
    SELECT p.name, r.region_name, SUM(f.amount) as total, COUNT(*) as cnt
    FROM fact_sales f JOIN dim_product p ON f.product_id = p.product_id
    JOIN dim_region r ON f.region_id = r.region_id GROUP BY p.name, r.region_name
);
----
0

# Verify the new row appeared
query II
SELECT name, region_name FROM fk_star WHERE name = 'Thingamajig';
----
Thingamajig	North

# ==========================================
# Test 3: UPDATE dimension (delete+insert in delta, FK pruning must NOT apply)
# ==========================================

statement ok
UPDATE dim_product SET name = 'SuperWidget' WHERE product_id = 1;

statement ok
PRAGMA refresh('fk_star');

query I
SELECT COUNT(*) FROM (
    SELECT p.name, r.region_name, SUM(f.amount) as total, COUNT(*) as cnt
    FROM fact_sales f JOIN dim_product p ON f.product_id = p.product_id
    JOIN dim_region r ON f.region_id = r.region_id GROUP BY p.name, r.region_name
    EXCEPT ALL SELECT * FROM fk_star
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM fk_star
    EXCEPT ALL
    SELECT p.name, r.region_name, SUM(f.amount) as total, COUNT(*) as cnt
    FROM fact_sales f JOIN dim_product p ON f.product_id = p.product_id
    JOIN dim_region r ON f.region_id = r.region_id GROUP BY p.name, r.region_name
);
----
0

# Verify rename propagated
query I
SELECT COUNT(*) FROM fk_star WHERE name = 'Widget';
----
0

query I
SELECT COUNT(*) FROM fk_star WHERE name = 'SuperWidget';
----
2

# ==========================================
# Test 4: DELETE from dimension (FK pruning must NOT apply)
# ==========================================

statement ok
DELETE FROM fact_sales WHERE product_id = 3;

statement ok
DELETE FROM dim_product WHERE product_id = 3;

statement ok
PRAGMA refresh('fk_star');

query I
SELECT COUNT(*) FROM (
    SELECT p.name, r.region_name, SUM(f.amount) as total, COUNT(*) as cnt
    FROM fact_sales f JOIN dim_product p ON f.product_id = p.product_id
    JOIN dim_region r ON f.region_id = r.region_id GROUP BY p.name, r.region_name
    EXCEPT ALL SELECT * FROM fk_star
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM fk_star
    EXCEPT ALL
    SELECT p.name, r.region_name, SUM(f.amount) as total, COUNT(*) as cnt
    FROM fact_sales f JOIN dim_product p ON f.product_id = p.product_id
    JOIN dim_region r ON f.region_id = r.region_id GROUP BY p.name, r.region_name
);
----
0

# ==========================================
# Test 5: Simultaneous fact + dimension inserts (both insert-only)
# New dim value AND new fact referencing it in the same batch.
# ==========================================

statement ok
INSERT INTO dim_region VALUES (30, 'East');

statement ok
INSERT INTO fact_sales VALUES (5, 2, 30, 500.0);

statement ok
PRAGMA refresh('fk_star');

query I
SELECT COUNT(*) FROM (
    SELECT p.name, r.region_name, SUM(f.amount) as total, COUNT(*) as cnt
    FROM fact_sales f JOIN dim_product p ON f.product_id = p.product_id
    JOIN dim_region r ON f.region_id = r.region_id GROUP BY p.name, r.region_name
    EXCEPT ALL SELECT * FROM fk_star
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM fk_star
    EXCEPT ALL
    SELECT p.name, r.region_name, SUM(f.amount) as total, COUNT(*) as cnt
    FROM fact_sales f JOIN dim_product p ON f.product_id = p.product_id
    JOIN dim_region r ON f.region_id = r.region_id GROUP BY p.name, r.region_name
);
----
0

# Verify new cross-reference appeared
query II
SELECT name, region_name FROM fk_star WHERE region_name = 'East';
----
Gadget	East

