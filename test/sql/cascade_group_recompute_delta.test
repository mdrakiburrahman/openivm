# name: test/sql/cascade_group_recompute_delta.test
# description: GROUP_RECOMPUTE emits signed cascade deltas when facts.force_view_delta_cascade=true
# group: [sql]

require openivm

statement ok
SET openivm_files_path='__TEST_DIR__';

statement ok
CREATE TABLE cgr_items (id INT, warehouse INT, district INT, item INT, amount INT);

statement ok
INSERT INTO cgr_items VALUES
    (1, 1, 1, 10, 5),
    (2, 1, 1, 20, 3),
    (3, 1, 1, 10, 2),
    (4, 1, 2, 30, 8),
    (5, 2, 1, 40, 1);

statement ok
CREATE MATERIALIZED VIEW cgr_mv AS
    SELECT warehouse, district,
           COUNT(DISTINCT item) AS unique_items,
           COUNT(*) AS total_lines,
           SUM(amount) AS total_amount
    FROM cgr_items
    GROUP BY warehouse, district;

# ==========================================
# Compile-only: force_view_delta_cascade=false should emit the
# in-place GROUP_RECOMPUTE program (affected temp + DELETE/INSERT on data)
# with no signed-cascade INSERT into openivm_delta_cgr_mv.
# ==========================================

query IT
SELECT refresh_type, refresh_type_name
FROM openivm_compile_with_facts(
    'cgr_mv',
    '{"target_dialect":"duckdb","compile_only":true,"force_view_delta_cascade":false}'
)
LIMIT 1;
----
6	GROUP_RECOMPUTE

query I
SELECT CASE WHEN
       string_agg(sql, ' ' ORDER BY stmt_order) LIKE '%CREATE OR REPLACE TEMP TABLE openivm_affected_cgr_mv AS%'
   AND string_agg(sql, ' ' ORDER BY stmt_order) LIKE '%DELETE FROM %openivm_data_cgr_mv%'
   AND string_agg(sql, ' ' ORDER BY stmt_order) LIKE '%INSERT INTO %openivm_data_cgr_mv%'
   AND string_agg(sql, ' ' ORDER BY stmt_order) LIKE '%DROP TABLE IF EXISTS openivm_affected_cgr_mv%'
   AND string_agg(sql, ' ' ORDER BY stmt_order) NOT LIKE '%INSERT INTO openivm_delta_cgr_mv%'
   THEN 1 ELSE 0 END
FROM openivm_compile_with_facts(
    'cgr_mv',
    '{"target_dialect":"duckdb","compile_only":true,"force_view_delta_cascade":false}'
)
WHERE stmt_kind = 'data';
----
1

# ==========================================
# Compile-only: force_view_delta_cascade=true must emit the
# old/new temp tables and a signed INSERT into openivm_delta_cgr_mv with
# both -1 and +1 multiplicity legs.
# ==========================================

query IT
SELECT refresh_type, refresh_type_name
FROM openivm_compile_with_facts(
    'cgr_mv',
    '{"target_dialect":"duckdb","compile_only":true,"force_view_delta_cascade":true}'
)
LIMIT 1;
----
6	GROUP_RECOMPUTE

query I
SELECT CASE WHEN
       string_agg(sql, ' ' ORDER BY stmt_order) LIKE '%CREATE OR REPLACE TEMP TABLE openivm_old_cgr_mv AS%'
   AND string_agg(sql, ' ' ORDER BY stmt_order) LIKE '%CREATE OR REPLACE TEMP TABLE openivm_new_cgr_mv AS%'
   AND string_agg(sql, ' ' ORDER BY stmt_order) LIKE '%INSERT INTO openivm_delta_cgr_mv%'
   AND string_agg(sql, ' ' ORDER BY stmt_order) LIKE '%CAST%-1%INTEGER%'
   AND string_agg(sql, ' ' ORDER BY stmt_order) LIKE '%UNION ALL%'
   AND string_agg(sql, ' ' ORDER BY stmt_order) LIKE '%CAST%1%INTEGER%'
   AND string_agg(sql, ' ' ORDER BY stmt_order) LIKE '%DROP TABLE IF EXISTS openivm_affected_cgr_mv%'
   AND string_agg(sql, ' ' ORDER BY stmt_order) LIKE '%DROP TABLE IF EXISTS openivm_old_cgr_mv%'
   AND string_agg(sql, ' ' ORDER BY stmt_order) LIKE '%DROP TABLE IF EXISTS openivm_new_cgr_mv%'
   THEN 1 ELSE 0 END
FROM openivm_compile_with_facts(
    'cgr_mv',
    '{"target_dialect":"duckdb","compile_only":true,"force_view_delta_cascade":true}'
)
WHERE stmt_kind = 'data';
----
1

# ==========================================
# Runtime correctness: PRAGMA refresh uses default CompileFacts (no cascade),
# but still applies the GROUP_RECOMPUTE program to openivm_data_cgr_mv so the
# user-visible MV stays bidirectionally consistent with the base query.
# The signed-delta emission into openivm_delta_cgr_mv requires
# force_view_delta_cascade=true and is covered by spark-ext integration
# tests that drive the compile_with_facts surface end-to-end.
# ==========================================

statement ok
INSERT INTO cgr_items VALUES (6, 1, 1, 50, 4);

statement ok
PRAGMA refresh('cgr_mv');

query I
SELECT COUNT(*) FROM (
    SELECT warehouse, district, unique_items, total_lines, total_amount FROM openivm_data_cgr_mv
    EXCEPT ALL
    SELECT warehouse, district, COUNT(DISTINCT item), COUNT(*), SUM(amount)
    FROM cgr_items GROUP BY warehouse, district
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT warehouse, district, COUNT(DISTINCT item), COUNT(*), SUM(amount)
    FROM cgr_items GROUP BY warehouse, district
    EXCEPT ALL
    SELECT warehouse, district, unique_items, total_lines, total_amount FROM openivm_data_cgr_mv
);
----
0

statement ok
UPDATE cgr_items SET amount = 4 WHERE id = 6;

statement ok
PRAGMA refresh('cgr_mv');

query I
SELECT COUNT(*) FROM (
    SELECT warehouse, district, unique_items, total_lines, total_amount FROM openivm_data_cgr_mv
    EXCEPT ALL
    SELECT warehouse, district, COUNT(DISTINCT item), COUNT(*), SUM(amount)
    FROM cgr_items GROUP BY warehouse, district
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT warehouse, district, COUNT(DISTINCT item), COUNT(*), SUM(amount)
    FROM cgr_items GROUP BY warehouse, district
    EXCEPT ALL
    SELECT warehouse, district, unique_items, total_lines, total_amount FROM openivm_data_cgr_mv
);
----
0

statement ok
DELETE FROM cgr_items WHERE id = 2;

statement ok
PRAGMA refresh('cgr_mv');

query I
SELECT COUNT(*) FROM (
    SELECT warehouse, district, unique_items, total_lines, total_amount FROM openivm_data_cgr_mv
    EXCEPT ALL
    SELECT warehouse, district, COUNT(DISTINCT item), COUNT(*), SUM(amount)
    FROM cgr_items GROUP BY warehouse, district
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT warehouse, district, COUNT(DISTINCT item), COUNT(*), SUM(amount)
    FROM cgr_items GROUP BY warehouse, district
    EXCEPT ALL
    SELECT warehouse, district, unique_items, total_lines, total_amount FROM openivm_data_cgr_mv
);
