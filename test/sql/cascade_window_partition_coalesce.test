# name: test/sql/cascade_window_partition_coalesce.test
# description: Derived WINDOW_PARTITION keys over aliased joins emit real cascade deltas
# group: [sql]

require openivm

statement ok
SET openivm_files_path='__TEST_DIR__';

statement ok
SET openivm_emit_cascade_delta_for_recompute=true;

statement ok
CREATE TABLE cwpc_fin (id INT, cik INT, company_name VARCHAR, pts INT, amount INT);

statement ok
CREATE TABLE cwpc_company (company_id INT, name VARCHAR, effective_ts INT, end_ts INT);

statement ok
INSERT INTO cwpc_company VALUES (10, 'Acme', 0, 100), (20, 'Beta', 0, 100);

statement ok
INSERT INTO cwpc_fin VALUES (1, 10, 'Acme', 50, 100), (2, NULL, 'Beta', 50, 90);

statement ok
CREATE MATERIALIZED VIEW cwpc_mv AS
    WITH s1 AS (
        SELECT f.id,
               f.amount,
               COALESCE(c1.company_id, c2.company_id) AS company_id,
               COALESCE(c1.name, c2.name) AS company_name
        FROM cwpc_fin f
        LEFT JOIN cwpc_company c1
          ON f.cik = c1.company_id
         AND f.pts BETWEEN c1.effective_ts AND c1.end_ts
        LEFT JOIN cwpc_company c2
          ON f.company_name = c2.name
         AND f.pts BETWEEN c2.effective_ts AND c2.end_ts
    )
    SELECT id,
           company_id,
           company_name,
           amount,
           ROW_NUMBER() OVER (PARTITION BY company_id ORDER BY amount DESC, id) AS rn
    FROM s1;

query III
SELECT CASE WHEN lineage_json IS NOT NULL THEN 1 ELSE 0 END,
       CASE WHEN contains(lineage_json, '"lookup_col":"company_id"') THEN 1 ELSE 0 END,
       CASE WHEN contains(lineage_json, '"lookup_col":"name"') THEN 1 ELSE 0 END
FROM openivm_views
WHERE view_name = 'cwpc_mv';
----
1	1	1

statement ok
PRAGMA compile_refresh('cwpc_mv');

query I
SELECT CASE
           WHEN contains(content, 'CREATE OR REPLACE TEMP TABLE openivm_affected_cwpc_mv AS') AND
                contains(content, 'CREATE OR REPLACE TEMP TABLE openivm_old_cwpc_mv AS') AND
                contains(content, 'CREATE OR REPLACE TEMP TABLE openivm_new_cwpc_mv AS') AND
                contains(content, 'INSERT INTO openivm_delta_cwpc_mv') AND
                NOT contains(content, 'SELECT NULL::')
           THEN 1 ELSE 0
       END
FROM read_text('__TEST_DIR__/openivm_upsert_queries_cwpc_mv.sql');
----
1

statement ok
INSERT INTO cwpc_fin VALUES (3, 10, 'ignored', 50, 110);

statement ok
UPDATE cwpc_company SET name = 'AcmeX' WHERE company_id = 10;

statement ok
PRAGMA refresh('cwpc_mv');

query IITIII rowsort
SELECT id, company_id, company_name, amount, rn, openivm_multiplicity FROM openivm_delta_cwpc_mv;
----
1	10	Acme	100	1	-1
1	10	AcmeX	100	2	1
3	10	AcmeX	110	1	1

query I
WITH s1 AS (
    SELECT f.id,
           f.amount,
           COALESCE(c1.company_id, c2.company_id) AS company_id,
           COALESCE(c1.name, c2.name) AS company_name
    FROM cwpc_fin f
    LEFT JOIN cwpc_company c1
      ON f.cik = c1.company_id
     AND f.pts BETWEEN c1.effective_ts AND c1.end_ts
    LEFT JOIN cwpc_company c2
      ON f.company_name = c2.name
     AND f.pts BETWEEN c2.effective_ts AND c2.end_ts
)
SELECT COUNT(*) FROM (
    SELECT * FROM cwpc_mv
    EXCEPT ALL
    SELECT id,
           company_id,
           company_name,
           amount,
           ROW_NUMBER() OVER (PARTITION BY company_id ORDER BY amount DESC, id) AS rn
    FROM s1
);
----
0

query I
WITH s1 AS (
    SELECT f.id,
           f.amount,
           COALESCE(c1.company_id, c2.company_id) AS company_id,
           COALESCE(c1.name, c2.name) AS company_name
    FROM cwpc_fin f
    LEFT JOIN cwpc_company c1
      ON f.cik = c1.company_id
     AND f.pts BETWEEN c1.effective_ts AND c1.end_ts
    LEFT JOIN cwpc_company c2
      ON f.company_name = c2.name
     AND f.pts BETWEEN c2.effective_ts AND c2.end_ts
)
SELECT COUNT(*) FROM (
    SELECT id,
           company_id,
           company_name,
           amount,
           ROW_NUMBER() OVER (PARTITION BY company_id ORDER BY amount DESC, id) AS rn
    FROM s1
    EXCEPT ALL
    SELECT * FROM cwpc_mv
);
----
0
