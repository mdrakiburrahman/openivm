# ==========================================
# AVG under join (CTE pattern) — incrementally maintained as AGGREGATE_GROUP
# (group-recompute fires on the inner aggregate's affected groups; AVG output
# is treated as a non-summable column and re-evaluated from the view query).
# ==========================================

statement ok
CREATE TABLE wh (w_id INT, w_name VARCHAR, w_tax DOUBLE);

statement ok
CREATE TABLE ol (ol_w_id INT, ol_d_id INT, ol_amount DOUBLE);

statement ok
INSERT INTO wh VALUES (1, 'Alpha', 0.1), (2, 'Beta', 0.05);

statement ok
INSERT INTO ol VALUES (1, 1, 10.0), (1, 1, 20.0), (1, 2, 5.0), (2, 1, 30.0);

statement ok
CREATE MATERIALIZED VIEW avg_under_join AS
    WITH district_avg AS (
        SELECT ol_w_id, ol_d_id, AVG(ol_amount) AS avg_rev, COUNT(*) AS line_count
        FROM ol GROUP BY ol_w_id, ol_d_id
    )
    SELECT w.w_id, w.w_name, da.ol_d_id, da.avg_rev, da.line_count,
           da.avg_rev * (1 + w.w_tax) AS taxed_avg
    FROM wh w JOIN district_avg da ON w.w_id = da.ol_w_id;

query I
SELECT COUNT(*) FROM (
    SELECT w_id, w_name, ol_d_id, avg_rev, line_count, taxed_avg FROM avg_under_join
    EXCEPT ALL
    SELECT w.w_id, w.w_name, da.ol_d_id, da.avg_rev, da.line_count, da.avg_rev * (1 + w.w_tax)
    FROM wh w JOIN (
        SELECT ol_w_id, ol_d_id, AVG(ol_amount) AS avg_rev, COUNT(*) AS line_count
        FROM ol GROUP BY ol_w_id, ol_d_id
    ) da ON w.w_id = da.ol_w_id
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT w.w_id, w.w_name, da.ol_d_id, da.avg_rev, da.line_count, da.avg_rev * (1 + w.w_tax)
    FROM wh w JOIN (
        SELECT ol_w_id, ol_d_id, AVG(ol_amount) AS avg_rev, COUNT(*) AS line_count
        FROM ol GROUP BY ol_w_id, ol_d_id
    ) da ON w.w_id = da.ol_w_id
    EXCEPT ALL
    SELECT w_id, w_name, ol_d_id, avg_rev, line_count, taxed_avg FROM avg_under_join
);
----
0

statement ok
INSERT INTO ol VALUES (1, 1, 30.0), (2, 1, 50.0);

statement ok
