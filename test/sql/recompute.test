# ==========================================
# UNION ALL over aggregate branches — GROUP_RECOMPUTE keys must not be positional
# ==========================================

statement ok
CREATE TABLE ugk_f(id INTEGER, k1 INTEGER, k2 INTEGER, k3 VARCHAR, k4 VARCHAR, x INTEGER);

statement ok
INSERT INTO ugk_f VALUES
    (1, 10, 100, 'os-a', 'lic-a', 5),
    (2, 10, 100, 'os-a', 'lic-a', 7),
    (3, 10, 100, 'os-b', 'lic-a', 11),
    (4, 20, 200, 'os-a', 'lic-b', 3);

statement ok
CREATE MATERIALIZED VIEW union_group_key_reordered AS
WITH branch AS (
    SELECT k1, k2, k3, k4, COUNT(DISTINCT id) AS c, SUM(x) AS sx
    FROM ugk_f
    WHERE x <= 7
    GROUP BY k1, k2, k3, k4
    UNION ALL
    SELECT k1, k2, k3, k4, COUNT(DISTINCT id) AS c, SUM(x) AS sx
    FROM ugk_f
    WHERE x > 7
    GROUP BY k1, k2, k3, k4
)
SELECT
    CAST(k1 AS VARCHAR) || '-' || CAST(k2 AS VARCHAR) || '-' || k3 || '-' || k4 AS primary_key,
    k1,
    k2,
    CAST(c AS INTEGER) AS c,
    CAST(sx AS INTEGER) AS sx,
    k3,
    k4
FROM branch;

statement ok
CREATE VIEW union_group_key_reordered_base AS
WITH branch AS (
    SELECT k1, k2, k3, k4, COUNT(DISTINCT id) AS c, SUM(x) AS sx
    FROM ugk_f
    WHERE x <= 7
    GROUP BY k1, k2, k3, k4
    UNION ALL
    SELECT k1, k2, k3, k4, COUNT(DISTINCT id) AS c, SUM(x) AS sx
    FROM ugk_f
    WHERE x > 7
    GROUP BY k1, k2, k3, k4
)
SELECT
    CAST(k1 AS VARCHAR) || '-' || CAST(k2 AS VARCHAR) || '-' || k3 || '-' || k4 AS primary_key,
    k1,
    k2,
    CAST(c AS INTEGER) AS c,
    CAST(sx AS INTEGER) AS sx,
    k3,
    k4
FROM branch;

