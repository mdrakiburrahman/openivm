statement ok
INSERT INTO orders_b VALUES ('east', 300), ('south', 75);

statement ok
CREATE MATERIALIZED VIEW union_agg AS
    SELECT region, SUM(amount) AS total, 'A' AS src FROM orders_a GROUP BY region
    UNION ALL
    SELECT region, SUM(amount) AS total, 'B' AS src FROM orders_b GROUP BY region;

query III
SELECT region, total, src FROM union_agg ORDER BY src, region;
