statement ok
CREATE MATERIALIZED VIEW union_group_key_alias AS
WITH cust_stats AS (
    SELECT k1 AS C_W_ID, COUNT(*) AS n, AVG(x) AS avg_bal
    FROM ugk_f
    GROUP BY k1
),
w_stats AS (
    SELECT k1 AS W_ID, SUM(x) AS W_YTD
    FROM ugk_f
    GROUP BY k1
)
SELECT cs.C_W_ID AS w, cs.n AS metric_val, 'count' AS kind FROM cust_stats cs
UNION ALL
SELECT cs.C_W_ID, cs.avg_bal, 'avg_bal' FROM cust_stats cs
UNION ALL
SELECT ws.W_ID, ws.W_YTD, 'ytd' FROM w_stats ws;

statement ok
CREATE VIEW union_group_key_alias_base AS
WITH cust_stats AS (
    SELECT k1 AS C_W_ID, COUNT(*) AS n, AVG(x) AS avg_bal
    FROM ugk_f
    GROUP BY k1
),
w_stats AS (
    SELECT k1 AS W_ID, SUM(x) AS W_YTD
    FROM ugk_f
    GROUP BY k1
)
SELECT cs.C_W_ID AS w, cs.n AS metric_val, 'count' AS kind FROM cust_stats cs
UNION ALL
SELECT cs.C_W_ID, cs.avg_bal, 'avg_bal' FROM cust_stats cs
UNION ALL
SELECT ws.W_ID, ws.W_YTD, 'ytd' FROM w_stats ws;

