# Classification: avg_under_join must NOT be FULL_REFRESH (3). Join-over-aggregate
# with dimension-side pass-through columns uses affected-key group recompute.
# Type 6 = GROUP_RECOMPUTE.
query I
SELECT type FROM openivm_views WHERE view_name = 'avg_under_join';
----
6

query I
SELECT group_columns FROM openivm_views WHERE view_name = 'avg_under_join';
----
ol_d_id,w_id

# ==========================================
# STDDEV / VARIANCE under join (CTE pattern) — same shape, exercises the other
# half of RewriteDerivedAggregates' decomposition (SUM(x*x) + SUM + COUNT).
# ==========================================

statement ok
CREATE MATERIALIZED VIEW stddev_under_join AS
    WITH district_stats AS (
        SELECT ol_w_id, ol_d_id,
               STDDEV(ol_amount) AS s_rev,
               VARIANCE(ol_amount) AS v_rev,
               COUNT(*) AS line_count
        FROM ol GROUP BY ol_w_id, ol_d_id
    )
    SELECT w.w_id, w.w_name, ds.ol_d_id, ds.s_rev, ds.v_rev, ds.line_count
    FROM wh w JOIN district_stats ds ON w.w_id = ds.ol_w_id;

query I
SELECT type FROM openivm_views WHERE view_name = 'stddev_under_join';
----
6

query I
SELECT group_columns FROM openivm_views WHERE view_name = 'stddev_under_join';
----
ol_d_id,w_id

# Cross-check initial state. STDDEV/VARIANCE on DOUBLE has 1–2 ULP drift vs
# the base query (documented in docs/limitations.md), so round to 10 places.
query I
SELECT COUNT(*) FROM (
    SELECT w_id, w_name, ol_d_id,
           ROUND(s_rev, 10), ROUND(v_rev, 10), line_count
    FROM stddev_under_join
    EXCEPT ALL
    SELECT w.w_id, w.w_name, ds.ol_d_id,
           ROUND(ds.s_rev, 10), ROUND(ds.v_rev, 10), ds.line_count
    FROM wh w JOIN (
        SELECT ol_w_id, ol_d_id, STDDEV(ol_amount) AS s_rev,
               VARIANCE(ol_amount) AS v_rev, COUNT(*) AS line_count
        FROM ol GROUP BY ol_w_id, ol_d_id
    ) ds ON w.w_id = ds.ol_w_id
);
----
0

