# name: test/sql/recompute.test
# description: Test IVM RECOMPUTE type (UNION ALL over agg, ROLLUP, AVG-under-join) and COUNT DISTINCT group-recompute
# group: [sql]

require openivm

# ==========================================
# COUNT(DISTINCT) — group-recompute
# ==========================================

statement ok
CREATE TABLE items (id INT, warehouse INT, district INT, item INT, amount DOUBLE);

statement ok
INSERT INTO items VALUES
    (1, 1, 1, 10, 5.0),
    (2, 1, 1, 20, 3.0),
    (3, 1, 1, 10, 2.0),
    (4, 1, 2, 30, 8.0),
    (5, 2, 1, 40, 1.0);

statement ok
CREATE MATERIALIZED VIEW items_distinct AS
    SELECT warehouse, district,
           COUNT(DISTINCT item) AS unique_items,
           COUNT(*) AS total_lines,
           SUM(amount) AS total_amount
    FROM items
    GROUP BY warehouse, district;

query IIIRR
SELECT warehouse, district, unique_items, total_lines, total_amount FROM items_distinct ORDER BY warehouse, district;
----
1	1	2	3	10.0
1	2	1	1	8.0
2	1	1	1	1.0

# Insert a new item for an existing group (item 50 is distinct → unique_items increases)
statement ok
INSERT INTO items VALUES (6, 1, 1, 50, 4.0);

statement ok
PRAGMA refresh('items_distinct');

query I
SELECT COUNT(*) FROM (
    SELECT warehouse, district, unique_items, total_lines, total_amount FROM items_distinct
    EXCEPT ALL
    SELECT warehouse, district,
           COUNT(DISTINCT item), COUNT(*), SUM(amount)
    FROM items GROUP BY warehouse, district
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT warehouse, district,
           COUNT(DISTINCT item), COUNT(*), SUM(amount)
    FROM items GROUP BY warehouse, district
    EXCEPT ALL
    SELECT warehouse, district, unique_items, total_lines, total_amount FROM items_distinct
);
----
0

