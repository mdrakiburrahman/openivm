# ==========================================
# Group recompute with repeated source table
# ==========================================

statement ok
CREATE TABLE market (
    dm_date DATE,
    dm_s_symb VARCHAR,
    dm_close DOUBLE,
    dm_high DOUBLE,
    dm_low DOUBLE,
    dm_vol BIGINT
);

statement ok
INSERT INTO market VALUES
    (DATE '2020-01-01', 'A', 10, 11, 9, 100),
    (DATE '2020-01-02', 'A', 12, 13, 8, 200),
    (DATE '2020-01-03', 'A', 11, 14, 10, 150);

statement ok
CREATE MATERIALIZED VIEW market_rollup AS
    WITH s1 AS (
        SELECT
            a.dm_date,
            a.dm_s_symb,
            a.dm_close,
            a.dm_high,
            a.dm_low,
            a.dm_vol,
            MIN(b.dm_low) AS fifty_two_week_low,
            MAX(b.dm_high) AS fifty_two_week_high
        FROM market a
        JOIN market b
            ON a.dm_s_symb = b.dm_s_symb
            AND b.dm_date BETWEEN a.dm_date - INTERVAL '12' MONTH AND a.dm_date
        GROUP BY a.dm_date, a.dm_s_symb, a.dm_close, a.dm_high, a.dm_low, a.dm_vol
    )
    SELECT
        a.dm_date,
        a.dm_s_symb,
        a.dm_close,
        a.dm_high,
        a.dm_low,
        a.dm_vol,
        a.fifty_two_week_low,
        a.fifty_two_week_high,
        MIN(b.dm_date) AS fifty_two_week_low_date,
        MIN(c.dm_date) AS fifty_two_week_high_date
    FROM s1 a
    JOIN market b
        ON a.dm_s_symb = b.dm_s_symb
        AND a.fifty_two_week_low = b.dm_low
        AND b.dm_date BETWEEN a.dm_date - INTERVAL '12' MONTH AND a.dm_date
    JOIN market c
        ON a.dm_s_symb = c.dm_s_symb
        AND a.fifty_two_week_high = c.dm_high
        AND c.dm_date BETWEEN a.dm_date - INTERVAL '12' MONTH AND a.dm_date
    GROUP BY
        a.dm_date,
        a.dm_s_symb,
        a.dm_close,
        a.dm_high,
        a.dm_low,
        a.dm_vol,
        a.fifty_two_week_low,
        a.fifty_two_week_high;

statement ok
INSERT INTO market VALUES (DATE '2019-12-31', 'A', 9, 21, 1, 50);

statement ok
PRAGMA refresh('market_rollup');

query I
WITH expected AS (
    WITH s1 AS (
        SELECT
            a.dm_date,
            a.dm_s_symb,
            a.dm_close,
            a.dm_high,
            a.dm_low,
            a.dm_vol,
            MIN(b.dm_low) AS fifty_two_week_low,
            MAX(b.dm_high) AS fifty_two_week_high
        FROM market a
        JOIN market b
            ON a.dm_s_symb = b.dm_s_symb
            AND b.dm_date BETWEEN a.dm_date - INTERVAL '12' MONTH AND a.dm_date
        GROUP BY a.dm_date, a.dm_s_symb, a.dm_close, a.dm_high, a.dm_low, a.dm_vol
    )
    SELECT
        a.dm_date,
        a.dm_s_symb,
        a.dm_close,
        a.dm_high,
        a.dm_low,
        a.dm_vol,
        a.fifty_two_week_low,
        a.fifty_two_week_high,
        MIN(b.dm_date) AS fifty_two_week_low_date,
        MIN(c.dm_date) AS fifty_two_week_high_date
    FROM s1 a
    JOIN market b
        ON a.dm_s_symb = b.dm_s_symb
        AND a.fifty_two_week_low = b.dm_low
        AND b.dm_date BETWEEN a.dm_date - INTERVAL '12' MONTH AND a.dm_date
    JOIN market c
        ON a.dm_s_symb = c.dm_s_symb
        AND a.fifty_two_week_high = c.dm_high
        AND c.dm_date BETWEEN a.dm_date - INTERVAL '12' MONTH AND a.dm_date
    GROUP BY
        a.dm_date,
        a.dm_s_symb,
        a.dm_close,
        a.dm_high,
        a.dm_low,
        a.dm_vol,
        a.fifty_two_week_low,
        a.fifty_two_week_high
)
SELECT count(*) FROM (
    SELECT * FROM market_rollup
    EXCEPT ALL
    SELECT * FROM expected
    UNION ALL
    SELECT * FROM expected
    EXCEPT ALL
    SELECT * FROM market_rollup
);
----
0

# ==========================================
# UNION ALL over aggregates — RECOMPUTE type
# ==========================================

statement ok
CREATE TABLE orders_a (region VARCHAR, amount INT);

statement ok
CREATE TABLE orders_b (region VARCHAR, amount INT);

statement ok
