# ==========================================
# Test 9: Chained — table → window MV → aggregate MV
# ==========================================

statement ok
SET ivm_cascade_refresh = 'off';

statement ok
CREATE TABLE w_emp (id INT, dept VARCHAR, salary INT);

statement ok
INSERT INTO w_emp VALUES (1,'eng',100), (2,'eng',200), (3,'eng',150), (4,'hr',90), (5,'hr',120);

statement ok
CREATE MATERIALIZED VIEW mv_ranked AS
    SELECT id, dept, salary, RANK() OVER (PARTITION BY dept ORDER BY salary DESC) as rnk FROM w_emp;

statement ok
CREATE MATERIALIZED VIEW mv_top2 AS
    SELECT dept, count(*) as top_count FROM mv_ranked WHERE rnk <= 2 GROUP BY dept;

query II
SELECT * FROM mv_top2 ORDER BY dept;
----
eng	2
hr	2

statement ok
INSERT INTO w_emp VALUES (6,'eng',300), (7,'hr',200);

statement ok
PRAGMA ivm('mv_ranked');

statement ok
PRAGMA ivm('mv_top2');

# Window MV correct
query I
SELECT count(*) FROM (
    SELECT id, dept, salary, RANK() OVER (PARTITION BY dept ORDER BY salary DESC) FROM w_emp
    EXCEPT ALL SELECT * FROM mv_ranked
);
----
0

# Downstream aggregate MV correct
query II
SELECT * FROM mv_top2 ORDER BY dept;
----
eng	2
hr	2

query I
SELECT count(*) FROM (
    SELECT dept, count(*) FROM (SELECT dept, RANK() OVER (PARTITION BY dept ORDER BY salary DESC) as rnk FROM w_emp) WHERE rnk <= 2 GROUP BY dept
    EXCEPT ALL SELECT * FROM mv_top2
);
----
0

# ==========================================
# Test 10: Multiple window functions with DIFFERENT PARTITION BY columns
# ==========================================

statement ok
CREATE TABLE w_multi_part (id INT, dept VARCHAR, team VARCHAR, val INT);

statement ok
INSERT INTO w_multi_part VALUES (1,'eng','be',10), (2,'eng','fe',20), (3,'hr','rec',30), (4,'hr','ops',40);

statement ok
CREATE MATERIALIZED VIEW mv_multi_part AS
    SELECT id, dept, team, val,
        ROW_NUMBER() OVER (PARTITION BY dept ORDER BY val) as dept_rn,
        ROW_NUMBER() OVER (PARTITION BY team ORDER BY val) as team_rn
    FROM w_multi_part;

# Cross-check initial
query I
SELECT count(*) FROM (
    SELECT id, dept, team, val,
        ROW_NUMBER() OVER (PARTITION BY dept ORDER BY val),
        ROW_NUMBER() OVER (PARTITION BY team ORDER BY val)
    FROM w_multi_part
    EXCEPT ALL SELECT * FROM mv_multi_part
);
----
0

# Insert into dept='eng', team='be' — both partitions should recompute
statement ok
INSERT INTO w_multi_part VALUES (5,'eng','be',15);

statement ok
PRAGMA ivm('mv_multi_part');

query I
SELECT count(*) FROM (
    SELECT id, dept, team, val,
        ROW_NUMBER() OVER (PARTITION BY dept ORDER BY val),
        ROW_NUMBER() OVER (PARTITION BY team ORDER BY val)
    FROM w_multi_part
    EXCEPT ALL SELECT * FROM mv_multi_part
);
----
0

query I
SELECT count(*) FROM (
    SELECT * FROM mv_multi_part
    EXCEPT ALL SELECT id, dept, team, val,
        ROW_NUMBER() OVER (PARTITION BY dept ORDER BY val),
        ROW_NUMBER() OVER (PARTITION BY team ORDER BY val)
    FROM w_multi_part
);
----
0

# ==========================================
# Test 11: RANGE frame with INTERVAL uses original SQL and partition refresh
# ==========================================

statement ok
CREATE TABLE w_history_range (h_w_id INT, h_date TIMESTAMP, h_amount INT);

statement ok
INSERT INTO w_history_range VALUES
    (1, '2026-01-01 00:00:00', 10),
    (1, '2026-01-10 00:00:00', 20),
    (1, '2026-02-20 00:00:00', 30),
    (2, '2026-01-05 00:00:00', 40);

statement ok
CREATE MATERIALIZED VIEW mv_window_range AS
    SELECT h_w_id, h_date, h_amount,
        COUNT(*) OVER (
            PARTITION BY h_w_id
            ORDER BY h_date
            RANGE BETWEEN INTERVAL '30 days' PRECEDING AND CURRENT ROW
        ) AS rolling_30d
    FROM w_history_range
    WHERE h_date IS NOT NULL;

query I
SELECT type FROM _duckdb_ivm_views WHERE view_name = 'mv_window_range';
----
5

statement ok
INSERT INTO w_history_range VALUES (1, '2026-01-20 00:00:00', 50);

statement ok
PRAGMA ivm('mv_window_range');

query I
SELECT COUNT(*) FROM (
    SELECT h_w_id, h_date, h_amount,
        COUNT(*) OVER (
            PARTITION BY h_w_id
            ORDER BY h_date
            RANGE BETWEEN INTERVAL '30 days' PRECEDING AND CURRENT ROW
        )
    FROM w_history_range
    WHERE h_date IS NOT NULL
    EXCEPT ALL
    SELECT * FROM mv_window_range
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM mv_window_range
    EXCEPT ALL
    SELECT h_w_id, h_date, h_amount,
        COUNT(*) OVER (
            PARTITION BY h_w_id
            ORDER BY h_date
            RANGE BETWEEN INTERVAL '30 days' PRECEDING AND CURRENT ROW
        )
    FROM w_history_range
    WHERE h_date IS NOT NULL
);
----
0
