# ==========================================
# UNION ALL over aggregates — RECOMPUTE type
# ==========================================

statement ok
CREATE TABLE orders_a (region VARCHAR, amount INT);

statement ok
CREATE TABLE orders_b (region VARCHAR, amount INT);

statement ok
INSERT INTO orders_a VALUES ('east', 100), ('west', 200), ('east', 50);

statement ok
INSERT INTO orders_b VALUES ('east', 300), ('south', 75);

statement ok
CREATE MATERIALIZED VIEW union_agg AS
    SELECT region, SUM(amount) AS total, 'A' AS src FROM orders_a GROUP BY region
    UNION ALL
    SELECT region, SUM(amount) AS total, 'B' AS src FROM orders_b GROUP BY region;

query III
SELECT region, total, src FROM union_agg ORDER BY src, region;
----
east	150	A
west	200	A
east	300	B
south	75	B

statement ok
INSERT INTO orders_a VALUES ('north', 500);

statement ok
INSERT INTO orders_b VALUES ('west', 120);

statement ok
PRAGMA ivm('union_agg');

query I
SELECT COUNT(*) FROM (
    SELECT region, total, src FROM union_agg
    EXCEPT ALL
    (SELECT region, SUM(amount), 'A' FROM orders_a GROUP BY region
     UNION ALL
     SELECT region, SUM(amount), 'B' FROM orders_b GROUP BY region)
);
----
0

query I
SELECT COUNT(*) FROM (
    (SELECT region, SUM(amount), 'A' FROM orders_a GROUP BY region
     UNION ALL
     SELECT region, SUM(amount), 'B' FROM orders_b GROUP BY region)
    EXCEPT ALL
    SELECT region, total, src FROM union_agg
);
----
0

