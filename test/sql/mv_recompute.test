# ==========================================
# GROUP BY ROLLUP — RECOMPUTE type
# ==========================================

statement ok
CREATE TABLE sales (region VARCHAR, dept VARCHAR, amount INT);

statement ok
INSERT INTO sales VALUES
    ('east', 'A', 100),
    ('east', 'B', 200),
    ('west', 'A', 150),
    ('west', 'B', 50);

statement ok
CREATE MATERIALIZED VIEW sales_rollup AS
    SELECT region, dept, SUM(amount) AS total, COUNT(*) AS cnt
    FROM sales
    GROUP BY ROLLUP(region, dept);

# ROLLUP produces rows for (region, dept), (region, NULL), (NULL, NULL)
query I
SELECT COUNT(*) FROM (
    SELECT region, dept, total, cnt FROM sales_rollup
    EXCEPT ALL
    SELECT region, dept, SUM(amount), COUNT(*) FROM sales GROUP BY ROLLUP(region, dept)
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT region, dept, SUM(amount), COUNT(*) FROM sales GROUP BY ROLLUP(region, dept)
    EXCEPT ALL
    SELECT region, dept, total, cnt FROM sales_rollup
);
----
0

statement ok
INSERT INTO sales VALUES ('east', 'A', 300), ('south', 'C', 75);

statement ok
PRAGMA ivm('sales_rollup');

query I
SELECT COUNT(*) FROM (
    SELECT region, dept, total, cnt FROM sales_rollup
    EXCEPT ALL
    SELECT region, dept, SUM(amount), COUNT(*) FROM sales GROUP BY ROLLUP(region, dept)
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT region, dept, SUM(amount), COUNT(*) FROM sales GROUP BY ROLLUP(region, dept)
    EXCEPT ALL
    SELECT region, dept, total, cnt FROM sales_rollup
);
