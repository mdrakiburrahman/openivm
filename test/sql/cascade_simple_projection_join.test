# CTE-fed join
statement ok
CREATE TABLE cspj_cte_holdings (account_id INT, security_id INT, qty INT);

statement ok
CREATE TABLE cspj_cte_security (security_id INT, symbol VARCHAR);

statement ok
INSERT INTO cspj_cte_holdings VALUES (1, 10, 5), (2, 20, 8);

statement ok
INSERT INTO cspj_cte_security VALUES (10, 'AAA'), (20, 'BBB');

statement ok
CREATE MATERIALIZED VIEW cspj_cte_mv AS
    WITH active_holdings AS (
        SELECT account_id, security_id, qty
        FROM cspj_cte_holdings
        WHERE qty > 0
    )
    SELECT h.account_id, h.security_id, s.symbol, h.qty
    FROM active_holdings h
    JOIN cspj_cte_security s ON h.security_id = s.security_id;

statement ok
SELECT COUNT(*) FROM openivm_compile_with_facts(
    'cspj_cte_mv',
    '{"target_dialect":"duckdb","compile_only":true}'
);

query I
SELECT CASE
           WHEN contains(content, 'INSERT INTO openivm_delta_cspj_cte_mv') AND
                contains(content, 'openivm_delta_cspj_cte_holdings') AND
                contains(content, 'openivm_delta_cspj_cte_security') AND
                contains(content, 'UNION ALL') AND
                NOT contains(content, 'SELECT NULL::')
           THEN 1 ELSE 0
       END
FROM read_text('__TEST_DIR__/openivm_upsert_queries_cspj_cte_mv.sql');
----
1

statement ok
INSERT INTO cspj_cte_holdings VALUES (3, 30, 7);

statement ok
INSERT INTO cspj_cte_security VALUES (30, 'CCC');

statement ok
DELETE FROM cspj_cte_holdings WHERE account_id = 1;

statement ok
UPDATE cspj_cte_security SET symbol = 'BBBX' WHERE security_id = 20;

statement ok
PRAGMA refresh('cspj_cte_mv');

query I
WITH active_holdings AS (
    SELECT account_id, security_id, qty
    FROM cspj_cte_holdings
    WHERE qty > 0
)
SELECT COUNT(*) FROM (
    SELECT * FROM cspj_cte_mv
    EXCEPT ALL
    SELECT h.account_id, h.security_id, s.symbol, h.qty
    FROM active_holdings h
    JOIN cspj_cte_security s ON h.security_id = s.security_id
);
----
0

query I
WITH active_holdings AS (
    SELECT account_id, security_id, qty
    FROM cspj_cte_holdings
    WHERE qty > 0
)
SELECT COUNT(*) FROM (
    SELECT h.account_id, h.security_id, s.symbol, h.qty
    FROM active_holdings h
    JOIN cspj_cte_security s ON h.security_id = s.security_id
    EXCEPT ALL
    SELECT * FROM cspj_cte_mv
);
----
0
