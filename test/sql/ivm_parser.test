# ==========================================
# Test 41: CREATE OR REPLACE MATERIALIZED VIEW — replace existing view
# ==========================================

statement ok
CREATE TABLE t41 (id INT, grp VARCHAR, val INT);

statement ok
INSERT INTO t41 VALUES (1, 'a', 10), (2, 'b', 20), (3, 'a', 30);

statement ok
CREATE MATERIALIZED VIEW mv_t41 AS
    SELECT grp, SUM(val) AS total FROM t41 GROUP BY grp;

query II
SELECT grp, total FROM mv_t41 ORDER BY grp;
----
a	40
b	20

# Replace with a different query (add COUNT)
statement ok
CREATE OR REPLACE MATERIALIZED VIEW mv_t41 AS
    SELECT grp, SUM(val) AS total, COUNT(*) AS cnt FROM t41 GROUP BY grp;

query III
SELECT grp, total, cnt FROM mv_t41 ORDER BY grp;
----
a	40	2
b	20	1

# IVM still works on the replaced view
statement ok
INSERT INTO t41 VALUES (4, 'c', 50);

statement ok
PRAGMA ivm('mv_t41');

query III
SELECT grp, total, cnt FROM mv_t41 ORDER BY grp;
----
a	40	2
b	20	1
c	50	1

# Cross-check
query I
SELECT count(*) FROM (
    SELECT grp, total, cnt FROM mv_t41
    EXCEPT ALL
    SELECT grp, SUM(val), COUNT(*) FROM t41 GROUP BY grp
);
----
0

