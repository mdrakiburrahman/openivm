# Test 6: Extra spaces in CREATE MATERIALIZED VIEW
# ==========================================

statement ok
CREATE TABLE t6 (id INT, grp VARCHAR, val INT);

statement ok
INSERT INTO t6 VALUES (1, 'a', 5);

statement ok
CREATE  MATERIALIZED  VIEW  mv_t6  AS  SELECT  grp, sum(val) as sum_val  FROM  t6  GROUP  BY  grp;

query II
SELECT grp, sum_val FROM mv_t6 ORDER BY grp;
----
