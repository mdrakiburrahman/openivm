statement ok
INSERT INTO mem2.s.t2 VALUES (10);

# Quoted multi-part source must retain its catalog/schema when OpenIVM creates deltas.
statement ok
CREATE MATERIALIZED VIEW mem2.s.mvq_source AS
SELECT COUNT(*) AS c FROM "mem2"."s"."t2";

query I
SELECT c FROM mem2.s.mvq_source;
