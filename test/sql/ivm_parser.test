0

# ==========================================
# Test 44: Quoted multi-part MV target and source names
# ==========================================

statement ok
ATTACH ':memory:' AS mem2;

statement ok
CREATE SCHEMA mem2.s;

statement ok
CREATE TABLE mem2.s.t(i INT);

statement ok
INSERT INTO mem2.s.t VALUES (1);

# Quoted multi-part MV target must not crash or lose the AS query body.
statement ok
CREATE MATERIALIZED VIEW "mem2"."s"."mvq_target" AS
SELECT COUNT(*) AS c FROM mem2.s.t;

query I
SELECT c FROM mem2.s.mvq_target;
----
1

statement ok
INSERT INTO mem2.s.t VALUES (2), (3);

statement ok
PRAGMA ivm('mvq_target');

query I
SELECT count(*) FROM (
  SELECT * FROM mem2.s.mvq_target
  EXCEPT ALL
  SELECT COUNT(*) AS c FROM mem2.s.t
);
----
0

query I
SELECT count(*) FROM (
  SELECT COUNT(*) AS c FROM mem2.s.t
  EXCEPT ALL
  SELECT * FROM mem2.s.mvq_target
);
----
0

