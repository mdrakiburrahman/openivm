query III
SELECT region, total, lowest FROM mv_orders ORDER BY region;
----
east	100	100
west	200	200

statement ok
INSERT INTO orders VALUES (4, 'east', 25, 'paid');

statement ok
PRAGMA ivm('mv_orders');

query III
SELECT region, total, lowest FROM mv_orders ORDER BY region;
----
east	125	25
west	200	200

# ==========================================
# Test 12: Typo — "MATERIALIZD" (missing E)
# ==========================================

# Should fall through to DuckDB parser and fail
statement error
CREATE MATERIALIZD VIEW mv_typo1 AS SELECT region, sum(amount) as total FROM sales GROUP BY region;
----
Parser Error

# ==========================================
# Test 13: Typo — "MATERIALIZED VEIW"
# ==========================================

statement error
CREATE MATERIALIZED VEIW mv_typo2 AS SELECT region, sum(amount) as total FROM sales GROUP BY region;
----
Parser Error

# ==========================================
# Test 14: Missing AS keyword
# ==========================================

statement error
CREATE MATERIALIZED VIEW mv_no_as SELECT region, sum(amount) as total FROM sales GROUP BY region;
----
Parser Error

# ==========================================
# Test 15: Missing view name
# ==========================================

statement error
CREATE MATERIALIZED VIEW AS SELECT region, sum(amount) as total FROM sales GROUP BY region;
----
Parser Error

# ==========================================
# Test 16: Non-existent base table
# ==========================================

statement error
CREATE MATERIALIZED VIEW mv_ghost AS SELECT x FROM does_not_exist GROUP BY x;
----
does_not_exist

# ==========================================
# Test 17: Duplicate materialized view name — should error
# ==========================================

# mv_sales already exists from Test 1
statement error
CREATE MATERIALIZED VIEW mv_sales AS SELECT region, sum(amount) as total FROM sales GROUP BY region;
----
already exists

# Note: IF NOT EXISTS on the table itself works, but the system table insert
# (_duckdb_ivm_delta_tables) is unconditional, so it still errors on duplicate.
# TODO: use INSERT OR IGNORE for _duckdb_ivm_delta_tables when IF NOT EXISTS is used.

# Original data should be unaffected by the failed duplicate attempt
query III
SELECT region, sum_amount, count_amount FROM mv_sales ORDER BY region;
----
east	300	3
west	200	1

query I
SELECT count(*) FROM _duckdb_ivm_views WHERE view_name = 'mv_sales';
----
1

query I
SELECT count(*) FROM duckdb_tables() WHERE table_name = '_ivm_data_mv_sales';
----
1

# ==========================================
# Test 18: Empty base table — MV should be empty but valid
# ==========================================

statement ok
CREATE TABLE empty_tbl (id INT, grp VARCHAR, val INT);

statement ok
CREATE MATERIALIZED VIEW mv_empty AS SELECT grp, min(val) as min_val FROM empty_tbl GROUP BY grp;

query II
SELECT grp, min_val FROM mv_empty ORDER BY grp;
----

# Now insert and refresh
statement ok
INSERT INTO empty_tbl VALUES (1, 'a', 42);

statement ok
PRAGMA ivm('mv_empty');

query II
SELECT grp, min_val FROM mv_empty ORDER BY grp;
----
a	42

# ==========================================
# Test 19: NULL values in aggregated columns
# ==========================================

statement ok
CREATE TABLE nulls_tbl (id INT, grp VARCHAR, val INT);

statement ok
INSERT INTO nulls_tbl VALUES (1, 'a', 10), (2, 'a', NULL), (3, 'b', NULL);

statement ok
CREATE MATERIALIZED VIEW mv_nulls AS SELECT grp, min(val) as min_val, max(val) as max_val, count(val) as cnt FROM nulls_tbl GROUP BY grp;

# MIN/MAX/COUNT should ignore NULLs
query IIII
SELECT grp, min_val, max_val, cnt FROM mv_nulls ORDER BY grp;
----
a	10	10	1
b	NULL	NULL	0

# Insert a non-null into group b
statement ok
INSERT INTO nulls_tbl VALUES (4, 'b', 7);

statement ok
PRAGMA ivm('mv_nulls');

query IIII
SELECT grp, min_val, max_val, cnt FROM mv_nulls ORDER BY grp;
----
a	10	10	1
b	7	7	1

