statement ok
CREATE TABLE vals (id INT, val INT);

statement ok
INSERT INTO vals VALUES (1, 100), (2, 50), (3, 200);

statement ok
CREATE MATERIALIZED VIEW mv_vals AS SELECT min(val) as min_val, max(val) as max_val, sum(val) as sum_val FROM vals;

query III
SELECT min_val, max_val, sum_val FROM mv_vals;
----
50	200	350

statement ok
INSERT INTO vals VALUES (4, 10);

statement ok
PRAGMA ivm('mv_vals');

query III
SELECT min_val, max_val, sum_val FROM mv_vals;
----
10	200	360

# ==========================================
# Test 5: Aliases already present — parser should not double-alias
# ==========================================

statement ok
CREATE TABLE items (id INT, cat VARCHAR, price INT);

statement ok
INSERT INTO items VALUES (1, 'a', 10), (2, 'b', 20);

statement ok
CREATE MATERIALIZED VIEW mv_items AS SELECT cat, sum(price) as total, min(price) as cheapest FROM items GROUP BY cat;

query III
SELECT cat, total, cheapest FROM mv_items ORDER BY cat;
----
a	10	10
b	20	20

