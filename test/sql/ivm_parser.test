# name: test/sql/ivm_parser.test
# description: Test CREATE MATERIALIZED VIEW parser (end-to-end)
# group: [sql]

require openivm

load __TEST_DIR__/ivm_parser_test.db

statement ok
SET ivm_files_path='__TEST_DIR__';

# ==========================================
# Test 1: Basic SUM + COUNT with GROUP BY
# ==========================================

statement ok
CREATE TABLE sales (id INT, region VARCHAR, amount INT);

statement ok
INSERT INTO sales VALUES (1, 'east', 100), (2, 'west', 200), (3, 'east', 150);

statement ok
CREATE MATERIALIZED VIEW mv_sales AS SELECT region, sum(amount) as sum_amount, count(amount) as count_amount FROM sales GROUP BY region;

# MV should be populated
query III
SELECT region, sum_amount, count_amount FROM mv_sales ORDER BY region;
----
east	250	2
west	200	1

# System tables should be populated
query I
SELECT count(*) FROM _duckdb_ivm_views WHERE view_name = 'mv_sales';
----
1

query I
SELECT count(*) FROM _duckdb_ivm_delta_tables WHERE view_name = 'mv_sales';
----
1

# Delta tables should exist
query I
SELECT count(*) FROM delta_sales;
----
0

query I
SELECT count(*) FROM delta_mv_sales;
----
0

# IVM should work end-to-end
statement ok
INSERT INTO sales VALUES (4, 'east', 50);

statement ok
PRAGMA ivm('mv_sales');

query III
SELECT region, sum_amount, count_amount FROM mv_sales ORDER BY region;
----
east	300	3
west	200	1

# ==========================================
# Test 2: MIN and MAX with GROUP BY
# ==========================================

statement ok
CREATE TABLE scores (id INT, team VARCHAR, score INT);

statement ok
INSERT INTO scores VALUES (1, 'a', 10), (2, 'a', 20), (3, 'b', 30), (4, 'b', 5);

statement ok
CREATE MATERIALIZED VIEW mv_scores AS SELECT team, min(score) as min_score, max(score) as max_score FROM scores GROUP BY team;

query III
SELECT team, min_score, max_score FROM mv_scores ORDER BY team;
----
a	10	20
b	5	30

statement ok
INSERT INTO scores VALUES (5, 'a', 1);

statement ok
PRAGMA ivm('mv_scores');

query III
SELECT team, min_score, max_score FROM mv_scores ORDER BY team;
----
a	1	20
b	5	30

# Delete current min — recompute should recover next min
statement ok
DELETE FROM scores WHERE id = 5;

statement ok
PRAGMA ivm('mv_scores');

query III
SELECT team, min_score, max_score FROM mv_scores ORDER BY team;
----
a	10	20
b	5	30

# ==========================================
# Test 3: Mixed SUM + MIN + MAX
# ==========================================

statement ok
CREATE TABLE metrics (id INT, grp VARCHAR, a INT, b INT);

statement ok
INSERT INTO metrics VALUES (1, 'x', 10, 100), (2, 'x', 20, 200), (3, 'y', 30, 300);

statement ok
CREATE MATERIALIZED VIEW mv_metrics AS SELECT grp, sum(a) as sum_a, min(b) as min_b, max(b) as max_b FROM metrics GROUP BY grp;

query IIII
SELECT grp, sum_a, min_b, max_b FROM mv_metrics ORDER BY grp;
----
x	30	100	200
y	30	300	300

statement ok
INSERT INTO metrics VALUES (4, 'x', 5, 50);

statement ok
PRAGMA ivm('mv_metrics');

query IIII
SELECT grp, sum_a, min_b, max_b FROM mv_metrics ORDER BY grp;
----
x	35	50	200
y	30	300	300

