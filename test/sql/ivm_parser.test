# ==========================================
# Test 21: VARCHAR MIN/MAX (alphabetical ordering)
# ==========================================

statement ok
CREATE TABLE words (id INT, cat VARCHAR, word VARCHAR);

statement ok
INSERT INTO words VALUES (1, 'fruit', 'banana'), (2, 'fruit', 'apple'), (3, 'fruit', 'cherry');

statement ok
CREATE MATERIALIZED VIEW mv_words AS SELECT cat, min(word) as first_word, max(word) as last_word FROM words GROUP BY cat;

query III
SELECT cat, first_word, last_word FROM mv_words;
----
fruit	apple	cherry

statement ok
INSERT INTO words VALUES (4, 'fruit', 'apricot');

statement ok
PRAGMA ivm('mv_words');

query III
SELECT cat, first_word, last_word FROM mv_words;
----
fruit	apple	cherry

# Delete 'apple' — 'apricot' becomes new min
statement ok
DELETE FROM words WHERE id = 2;

statement ok
PRAGMA ivm('mv_words');

query III
SELECT cat, first_word, last_word FROM mv_words;
----
fruit	apricot	cherry

