# ==========================================
# Test 7: Mixed case keywords
# ==========================================

statement ok
CREATE TABLE t7 (id INT, grp VARCHAR, val INT);

statement ok
INSERT INTO t7 VALUES (1, 'a', 5), (2, 'a', 10);

statement ok
CREATE Materialized View mv_t7 AS Select grp, Min(val) as min_val, Max(val) as max_val, Sum(val) as sum_val From t7 Group By grp;

query IIII
SELECT grp, min_val, max_val, sum_val FROM mv_t7 ORDER BY grp;
----
a	5	10	15

# ==========================================
# Test 8: Simple projection (no aggregation)
# ==========================================

statement ok
CREATE TABLE t8 (id INT, name VARCHAR);

statement ok
INSERT INTO t8 VALUES (1, 'alice'), (2, 'bob');

statement ok
CREATE MATERIALIZED VIEW mv_t8 AS SELECT id, name FROM t8;

query II
SELECT id, name FROM mv_t8 ORDER BY id;
----
1	alice
2	bob

statement ok
INSERT INTO t8 VALUES (3, 'carol');

statement ok
PRAGMA ivm('mv_t8');

query II
SELECT id, name FROM mv_t8 ORDER BY id;
----
1	alice
2	bob
3	carol

# ==========================================
# Test 9: Projection with filter
# ==========================================

statement ok
CREATE TABLE t9 (id INT, status VARCHAR, val INT);

statement ok
INSERT INTO t9 VALUES (1, 'active', 10), (2, 'inactive', 20), (3, 'active', 30);

statement ok
CREATE MATERIALIZED VIEW mv_t9 AS SELECT id, val FROM t9 WHERE status = 'active';

query II
SELECT id, val FROM mv_t9 ORDER BY id;
