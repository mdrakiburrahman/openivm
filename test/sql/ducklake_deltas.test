# name: test/sql/ducklake_deltas.test
# description: Test DuckLake-specific delta mechanics: snapshot tracking, time travel, multi-batch, deletes
# group: [sql]

require openivm

require parquet

statement ok
INSTALL ducklake;

statement ok
LOAD ducklake;

statement ok
ATTACH '__TEST_DIR__/ducklake_deltas.db' AS dl (TYPE ducklake);

# ==========================================
# Section 1: Snapshot tracking
# Verify last_snapshot_id advances after each refresh
# ==========================================

statement ok
CREATE TABLE dl.snap_test (id INTEGER, grp VARCHAR, val INTEGER);

statement ok
INSERT INTO dl.snap_test VALUES (1, 'A', 10), (2, 'A', 20);

statement ok
CREATE MATERIALIZED VIEW dl.mv_snap AS SELECT grp, SUM(val) as total, COUNT(*) as cnt FROM dl.snap_test GROUP BY grp;

# Snapshot should be set after CREATE MV
query I
SELECT last_snapshot_id IS NOT NULL FROM openivm_delta_tables WHERE view_name = 'mv_snap';
----
true

# Record the initial snapshot (value varies, just check it's positive)
query I
SELECT last_snapshot_id > 0 FROM openivm_delta_tables WHERE view_name = 'mv_snap';
----
true

statement ok
INSERT INTO dl.snap_test VALUES (3, 'A', 30);

# Save pre-refresh snapshot for comparison
statement ok
CREATE TEMP TABLE snap_before AS SELECT last_snapshot_id AS snap FROM openivm_delta_tables WHERE view_name = 'mv_snap';

statement ok
PRAGMA refresh('mv_snap');

# Snapshot should have advanced after refresh
query I
SELECT last_snapshot_id > (SELECT snap FROM snap_before) FROM openivm_delta_tables WHERE view_name = 'mv_snap';
----
true

statement ok
DROP TABLE snap_before;

# MV should be correct
query III
SELECT grp, total, cnt FROM dl.mv_snap;
----
A	60	3

# EXCEPT ALL check
query I
SELECT count(*) FROM (SELECT grp, total, cnt FROM dl.mv_snap EXCEPT ALL SELECT grp, SUM(val), COUNT(*) FROM dl.snap_test GROUP BY grp);
----
0

query I
SELECT count(*) FROM (SELECT grp, SUM(val), COUNT(*) FROM dl.snap_test GROUP BY grp EXCEPT ALL SELECT grp, total, cnt FROM dl.mv_snap);
----
0

# ==========================================
# Section 2: Time travel
# MV definition should NOT contain AT VERSION
# ==========================================

query I
SELECT sql_string NOT LIKE '%AT (VERSION%' FROM openivm_views WHERE view_name = 'mv_snap';
----
true

# Catalog type should be ducklake
query I
SELECT catalog_type FROM openivm_delta_tables WHERE view_name = 'mv_snap';
----
ducklake

# ==========================================
# Section 3: Multi-batch deltas
# Multiple INSERTs between refreshes, single refresh picks up all
# ==========================================

statement ok
CREATE TABLE dl.multi (id INTEGER, name VARCHAR, amount INTEGER);

statement ok
INSERT INTO dl.multi VALUES (1, 'A', 100);

statement ok
CREATE MATERIALIZED VIEW dl.mv_multi AS SELECT name, SUM(amount) as total, COUNT(*) as cnt FROM dl.multi GROUP BY name;

# Batch 1
statement ok
INSERT INTO dl.multi VALUES (2, 'A', 50);

# Batch 2 (separate DuckLake snapshot)
statement ok
INSERT INTO dl.multi VALUES (3, 'B', 200);

# Batch 3
statement ok
INSERT INTO dl.multi VALUES (4, 'A', 25);

# Single refresh picks up all 3 batches
statement ok
PRAGMA refresh('mv_multi');

query III rowsort
SELECT name, total, cnt FROM dl.mv_multi ORDER BY name;
----
A	175	3
B	200	1

# EXCEPT ALL
query I
SELECT count(*) FROM (SELECT name, total, cnt FROM dl.mv_multi EXCEPT ALL SELECT name, SUM(amount), COUNT(*) FROM dl.multi GROUP BY name);
----
0

query I
SELECT count(*) FROM (SELECT name, SUM(amount), COUNT(*) FROM dl.multi GROUP BY name EXCEPT ALL SELECT name, total, cnt FROM dl.mv_multi);
----
0

# ==========================================
# Section 4: Delete propagation
# DELETE from base table, refresh, verify removal
# ==========================================

statement ok
CREATE TABLE dl.del_test (id INTEGER, category VARCHAR, price DECIMAL(10,2));

statement ok
INSERT INTO dl.del_test VALUES (1, 'X', 10.00), (2, 'X', 20.00), (3, 'Y', 30.00);

statement ok
CREATE MATERIALIZED VIEW dl.mv_del AS SELECT category, SUM(price) as total, COUNT(*) as cnt FROM dl.del_test GROUP BY category;

query III rowsort
SELECT * FROM dl.mv_del ORDER BY category;
----
X	30.00	2
Y	30.00	1

# Delete one row
statement ok
DELETE FROM dl.del_test WHERE id = 1;

statement ok
PRAGMA refresh('mv_del');

query III rowsort
SELECT * FROM dl.mv_del ORDER BY category;
----
X	20.00	1
Y	30.00	1

# EXCEPT ALL
query I
SELECT count(*) FROM (SELECT category, total, cnt FROM dl.mv_del EXCEPT ALL SELECT category, SUM(price), COUNT(*) FROM dl.del_test GROUP BY category);
----
0

query I
SELECT count(*) FROM (SELECT category, SUM(price), COUNT(*) FROM dl.del_test GROUP BY category EXCEPT ALL SELECT category, total, cnt FROM dl.mv_del);
----
0

# ==========================================
# Section 5: Snapshot start is exclusive
# DuckLake change functions include the start snapshot. Refresh must query from
# last_snapshot_id + 1 or a later delete will replay the previous insert batch.
# ==========================================

statement ok
CREATE TABLE dl.replay_sales (id INTEGER, region VARCHAR, amount INTEGER);

statement ok
INSERT INTO dl.replay_sales VALUES (1, 'east', 100), (2, 'west', 200), (3, 'east', 150);

statement ok
CREATE MATERIALIZED VIEW dl.mv_replay_sales AS
SELECT region, SUM(amount) AS total, COUNT(*) AS cnt
FROM dl.replay_sales
GROUP BY region;

statement ok
INSERT INTO dl.replay_sales VALUES (4, 'east', 50), (5, 'north', 300);

statement ok
PRAGMA refresh('mv_replay_sales');

query III rowsort
SELECT region, total, cnt FROM dl.mv_replay_sales ORDER BY region;
----
east	300	3
north	300	1
west	200	1

statement ok
CREATE TEMP TABLE replay_after_insert AS
SELECT last_snapshot_id AS snap
FROM openivm_delta_tables
WHERE view_name = 'mv_replay_sales';

statement ok
DELETE FROM dl.replay_sales WHERE id = 1;

statement ok
PRAGMA refresh('mv_replay_sales');

query III rowsort
SELECT region, total, cnt FROM dl.mv_replay_sales ORDER BY region;
----
east	200	2
north	300	1
west	200	1

query I
SELECT last_snapshot_id > (SELECT snap FROM replay_after_insert)
FROM openivm_delta_tables
WHERE view_name = 'mv_replay_sales';
----
true

statement ok
CREATE TEMP TABLE replay_after_delete AS
SELECT last_snapshot_id AS snap
FROM openivm_delta_tables
WHERE view_name = 'mv_replay_sales';

statement ok
PRAGMA refresh('mv_replay_sales');

query I
SELECT last_snapshot_id = (SELECT snap FROM replay_after_delete)
FROM openivm_delta_tables
WHERE view_name = 'mv_replay_sales';
----
true

query I
SELECT count(*) FROM (
  SELECT region, SUM(amount) AS total, COUNT(*) AS cnt FROM dl.replay_sales GROUP BY region
  EXCEPT ALL
  SELECT region, total, cnt FROM dl.mv_replay_sales
);
----
0

query I
SELECT count(*) FROM (
  SELECT region, total, cnt FROM dl.mv_replay_sales
  EXCEPT ALL
  SELECT region, SUM(amount) AS total, COUNT(*) AS cnt FROM dl.replay_sales GROUP BY region
);
----
0

statement ok
DROP TABLE replay_after_insert;

statement ok
DROP TABLE replay_after_delete;

# ==========================================
# Section 6: Failed DuckLake publish cleans up and can retry
# ==========================================

statement ok
CREATE TABLE dl.publish_src (id INTEGER, grp VARCHAR, v INTEGER);

statement ok
INSERT INTO dl.publish_src VALUES (1, 'a', 10), (2, 'b', 20);

statement ok
CREATE TABLE dl.blocked_publish_mv (x INTEGER);

statement error
CREATE MATERIALIZED VIEW dl.blocked_publish_mv AS
SELECT grp, SUM(v) AS total
FROM dl.publish_src
GROUP BY grp;
----
already exists

query I
SELECT count(*) FROM dl.blocked_publish_mv;
----
0

query I
SELECT count(*) FROM duckdb_tables()
WHERE database_name = current_database() AND table_name LIKE 'openivm_stage_blocked_publish_mv%';
----
0

query I
SELECT count(*) FROM duckdb_tables()
WHERE database_name = current_database() AND table_name IN ('openivm_data_blocked_publish_mv', 'openivm_delta_blocked_publish_mv');
----
0

query I
SELECT count(*) FROM openivm_views WHERE view_name = 'blocked_publish_mv';
----
0

query I
SELECT count(*) FROM openivm_delta_tables WHERE view_name = 'blocked_publish_mv';
----
0

statement ok
DROP TABLE dl.blocked_publish_mv;

statement ok
CREATE MATERIALIZED VIEW dl.blocked_publish_mv AS
SELECT grp, SUM(v) AS total
FROM dl.publish_src
GROUP BY grp;

query II rowsort
SELECT grp, total FROM dl.blocked_publish_mv ORDER BY grp;
----
a	10
b	20

# ==========================================
# Section 7: DuckLake table-level empty delta skipping
# Catalog snapshots advance when any table changes. A join MV should not build a
# delta term for an unchanged source table in the same catalog.
# ==========================================

statement ok
SET openivm_files_path='__TEST_DIR__';

statement ok
SET openivm_skip_empty_deltas=true;

statement ok
CREATE TABLE dl.skip_base (id INTEGER, v INTEGER);

statement ok
CREATE TABLE dl.skip_unrelated (id INTEGER);

statement ok
INSERT INTO dl.skip_base VALUES (1, 10);

statement ok
CREATE MATERIALIZED VIEW dl.mv_skip_base AS
SELECT id, v FROM dl.skip_base;

query I
SELECT source_table_id IS NOT NULL
FROM openivm_delta_tables
WHERE view_name = 'mv_skip_base';
----
true

statement ok
CREATE TEMP TABLE skip_base_snapshot AS
SELECT last_snapshot_id AS snap
FROM openivm_delta_tables
WHERE view_name = 'mv_skip_base';

statement ok
INSERT INTO dl.skip_unrelated VALUES (1);

statement ok
PRAGMA refresh('mv_skip_base');

query I
SELECT last_snapshot_id > (SELECT snap FROM skip_base_snapshot)
FROM openivm_delta_tables
WHERE view_name = 'mv_skip_base';
----
true

statement ok
DROP TABLE skip_base_snapshot;

statement ok
UPDATE openivm_delta_tables
SET source_table_id = NULL
WHERE view_name = 'mv_skip_base';

statement ok
CREATE TEMP TABLE skip_base_snapshot_backfill AS
SELECT last_snapshot_id AS snap
FROM openivm_delta_tables
WHERE view_name = 'mv_skip_base';

statement ok
INSERT INTO dl.skip_unrelated VALUES (2);

statement ok
PRAGMA refresh('mv_skip_base');

query I
SELECT source_table_id IS NOT NULL
FROM openivm_delta_tables
WHERE view_name = 'mv_skip_base';
----
true

query I
SELECT last_snapshot_id > (SELECT snap FROM skip_base_snapshot_backfill)
FROM openivm_delta_tables
WHERE view_name = 'mv_skip_base';
----
true

statement ok
DROP TABLE skip_base_snapshot_backfill;

statement ok
INSERT INTO dl.skip_base VALUES (2, 20);

statement ok
PRAGMA refresh('mv_skip_base');

query I
SELECT count(*) FROM (
  SELECT id, v FROM dl.mv_skip_base
  EXCEPT ALL
  SELECT id, v FROM dl.skip_base
);
----
0

query I
SELECT count(*) FROM (
SELECT id, v FROM dl.skip_base
  EXCEPT ALL
  SELECT id, v FROM dl.mv_skip_base
);
----
0

statement ok
CREATE SCHEMA dl.same_a;

statement ok
CREATE SCHEMA dl.same_b;

statement ok
CREATE TABLE dl.same_a.same_name (id INTEGER, v INTEGER);

statement ok
CREATE TABLE dl.same_b.same_name (id INTEGER, v INTEGER);

statement ok
INSERT INTO dl.same_a.same_name VALUES (1, 100);

statement ok
INSERT INTO dl.same_b.same_name VALUES (1, 10);

statement ok
CREATE MATERIALIZED VIEW dl.mv_same_schema AS
SELECT id, v FROM dl.same_b.same_name;

query I
SELECT source_table_id = (
  SELECT t.table_id
  FROM __ducklake_metadata_dl.ducklake_table t
  JOIN __ducklake_metadata_dl.ducklake_schema s ON t.schema_id = s.schema_id
  WHERE t.end_snapshot IS NULL
    AND s.end_snapshot IS NULL
    AND t.table_name = 'same_name'
    AND s.schema_name = 'same_b'
)
FROM openivm_delta_tables
WHERE view_name = 'mv_same_schema';
----
true

statement ok
UPDATE openivm_delta_tables
SET source_table_id = source_table_id + 100000
WHERE view_name = 'mv_same_schema';

statement ok
CREATE TEMP TABLE same_schema_snapshot AS
SELECT last_snapshot_id AS snap
FROM openivm_delta_tables
WHERE view_name = 'mv_same_schema';

statement ok
SET openivm_profile_refresh = true;

statement ok
INSERT INTO dl.same_a.same_name VALUES (2, 200);

statement ok
PRAGMA refresh('mv_same_schema');

query I
SELECT count(*)
FROM openivm_refresh_profile
WHERE view_name = 'mv_same_schema'
  AND step_name = 'generate_refresh_sql.dispatch'
  AND detail LIKE '%metadata_requires_full_refresh=true%';
----
1

statement ok
SET openivm_profile_refresh = false;

query I
SELECT last_snapshot_id > (SELECT snap FROM same_schema_snapshot)
FROM openivm_delta_tables
WHERE view_name = 'mv_same_schema';
----
true

query I
SELECT source_table_id = (
  SELECT t.table_id
  FROM __ducklake_metadata_dl.ducklake_table t
  JOIN __ducklake_metadata_dl.ducklake_schema s ON t.schema_id = s.schema_id
  WHERE t.end_snapshot IS NULL
    AND s.end_snapshot IS NULL
    AND t.table_name = 'same_name'
    AND s.schema_name = 'same_b'
)
FROM openivm_delta_tables
WHERE view_name = 'mv_same_schema';
----
true

query I
SELECT count(*) FROM (
  SELECT id, v FROM dl.mv_same_schema
  EXCEPT ALL
  SELECT id, v FROM dl.same_b.same_name
);
----
0

query I
SELECT count(*) FROM (
  SELECT id, v FROM dl.same_b.same_name
  EXCEPT ALL
  SELECT id, v FROM dl.mv_same_schema
);
----
0

statement ok
DROP TABLE same_schema_snapshot;

statement ok
CREATE TABLE dl.skip_left (id INTEGER, v INTEGER);

statement ok
CREATE TABLE dl.skip_right (id INTEGER, w INTEGER);

statement ok
INSERT INTO dl.skip_left VALUES (1, 10), (2, 20);

statement ok
INSERT INTO dl.skip_right VALUES (1, 100), (2, 200);

statement ok
CREATE MATERIALIZED VIEW dl.mv_skip_unchanged_join AS
SELECT l.id, l.v, r.w
FROM dl.skip_left l
JOIN dl.skip_right r USING (id);

statement ok
INSERT INTO dl.skip_left VALUES (3, 30);

statement ok
PRAGMA refresh('mv_skip_unchanged_join');

query I
SELECT len(regexp_extract_all(content, 'ducklake_table_insertions')) FROM read_text('__TEST_DIR__/openivm_upsert_queries_mv_skip_unchanged_join.sql');
----
0

query I
SELECT len(regexp_extract_all(content, 'ducklake_table_deletions')) FROM read_text('__TEST_DIR__/openivm_upsert_queries_mv_skip_unchanged_join.sql');
----
0

query I
SELECT contains(content, 'ducklake_table_insertions(''dl'', ''main'', ''skip_right''') FROM read_text('__TEST_DIR__/openivm_upsert_queries_mv_skip_unchanged_join.sql');
----
false

query I
SELECT count(*) FROM (
  SELECT id, v, w FROM dl.mv_skip_unchanged_join
  EXCEPT ALL
  SELECT l.id, l.v, r.w FROM dl.skip_left l JOIN dl.skip_right r USING (id)
);
----
0

query I
SELECT count(*) FROM (
  SELECT l.id, l.v, r.w FROM dl.skip_left l JOIN dl.skip_right r USING (id)
  EXCEPT ALL
  SELECT id, v, w FROM dl.mv_skip_unchanged_join
);
----
0

statement ok
