statement ok
PRAGMA ivm_options('memory', 'main', 'mv_staff');

# DELETE with subquery not yet supported — should give clean error
statement error
DELETE FROM staff WHERE dept IN (SELECT 'temp');
----
not yet fully supported

# Clean up manually since the DELETE didn't execute
statement ok
DELETE FROM staff WHERE dept = 'temp';

