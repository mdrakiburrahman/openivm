# name: test/sql/ivm_insert_rule.test
# description: Test IVM insert rule (delta table population for INSERT/DELETE/UPDATE)
# group: [sql]

require openivm

# ==========================================
# Setup: base table, MV (auto-creates system tables + delta tables)
# ==========================================

statement ok
CREATE TABLE staff (id INT, name VARCHAR, dept VARCHAR, salary INT);

statement ok
INSERT INTO staff VALUES (1, 'Alice', 'eng', 100), (2, 'Bob', 'sales', 200);

# CREATE MATERIALIZED VIEW auto-populates _duckdb_ivm_views, _duckdb_ivm_delta_tables,
# creates delta_staff, _ivm_data_mv_staff, delta_mv_staff, and the mv_staff view.
statement ok
CREATE MATERIALIZED VIEW mv_staff AS SELECT id, name, dept, salary FROM staff;

# Initial refresh so MV reflects the pre-seeded rows.
statement ok
PRAGMA ivm_options('memory', 'main', 'mv_staff');

# Source table for INSERT...SELECT tests
statement ok
CREATE TABLE temp_hires (id INT, name VARCHAR, dept VARCHAR, salary INT);

statement ok
INSERT INTO temp_hires VALUES (6, 'Frank', 'eng', 175), (7, 'Grace', 'sales', 225);

# ==========================================
# Test 1: INSERT VALUES — single row
# ==========================================

statement ok
INSERT INTO staff VALUES (3, 'Carol', 'eng', 150);

statement ok
PRAGMA ivm_options('memory', 'main', 'mv_staff');

# MV must match base table after every PRAGMA
query I
SELECT count(*) FROM (SELECT * FROM mv_staff EXCEPT ALL SELECT id, name, dept, salary FROM staff);
----
0

query I
SELECT count(*) FROM (SELECT id, name, dept, salary FROM staff EXCEPT ALL SELECT * FROM mv_staff);
----
0

# ==========================================
# Test 2: INSERT VALUES — multi-row batch
# ==========================================

statement ok
INSERT INTO staff VALUES (4, 'Dave', 'sales', 250), (5, 'Eve', 'eng', 300);

statement ok
PRAGMA ivm_options('memory', 'main', 'mv_staff');

query I
SELECT count(*) FROM (SELECT * FROM mv_staff EXCEPT ALL SELECT id, name, dept, salary FROM staff);
----
0

query I
SELECT count(*) FROM (SELECT id, name, dept, salary FROM staff EXCEPT ALL SELECT * FROM mv_staff);
----
0

