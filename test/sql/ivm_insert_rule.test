# ==========================================
# Complex 8: INSERT...SELECT with aggregation
# ==========================================

statement ok
CREATE TABLE agg_target (id INT, name VARCHAR, dept VARCHAR, salary INT);

statement ok
CREATE TABLE delta_agg_target AS SELECT *, 1::INTEGER AS _duckdb_ivm_multiplicity, now()::timestamp AS _duckdb_ivm_timestamp FROM agg_target LIMIT 0;

statement ok
INSERT INTO agg_target SELECT 999, dept, dept, SUM(salary) FROM staff WHERE dept = 'eng' GROUP BY dept;

query I
SELECT count(*) FROM delta_agg_target;
----
1

