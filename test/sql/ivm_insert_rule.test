# Test 3: INSERT...SELECT (subquery path)
# ==========================================

statement ok
INSERT INTO staff SELECT * FROM temp_hires;

statement ok
PRAGMA ivm_options('memory', 'main', 'mv_staff');

query I
SELECT count(*) FROM (SELECT * FROM mv_staff EXCEPT ALL SELECT id, name, dept, salary FROM staff);
----
0

query I
SELECT count(*) FROM (SELECT id, name, dept, salary FROM staff EXCEPT ALL SELECT * FROM mv_staff);
----
0

