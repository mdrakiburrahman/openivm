# ==========================================
# Test 12: Short table name (prefix check safety)
# ==========================================

statement ok
CREATE TABLE ab (id INT, val INT);

statement ok
CREATE TABLE delta_ab AS SELECT *, 1::INTEGER AS _duckdb_ivm_multiplicity, now()::timestamp AS _duckdb_ivm_timestamp FROM ab LIMIT 0;

statement ok
INSERT INTO ab VALUES (1, 42);

query I
SELECT count(*) FROM delta_ab;
----
1

