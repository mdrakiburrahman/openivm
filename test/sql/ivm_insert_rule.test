# ==========================================
# Complex 1: DELETE with OR condition
# ==========================================

statement ok
INSERT INTO staff VALUES (90, 'OrTest1', 'eng', 10), (91, 'OrTest2', 'sales', 20), (92, 'OrTest3', 'hr', 30);

statement ok
PRAGMA ivm_options('memory', 'main', 'mv_staff');

statement ok
