# --- CTE-wrapped AVG decomposes correctly (q0535 regression) ---
# Bug: LPTS can't serialize LOGICAL_CTE_REF, so the CTE-wrapped plan fell back to
# the original SQL at CREATE time — meaning the data table stored the raw avg()
# column with no hidden sum/count, and the delta CTE tried to SUM the averages
# during refresh, yielding wildly incorrect group averages after any delta.
# Fix: inline the CTE at plan level before IVM rewrites so LPTS sees a flat
# PROJECTION → AGGREGATE plan and RewriteDerivedAggregates can decompose AVG.

statement ok
CREATE TABLE cte_avg_t(id INT, tier VARCHAR, bal INT);

statement ok
INSERT INTO cte_avg_t VALUES
    (1, 'A', 100), (2, 'A', 200), (3, 'B', 50), (4, 'B', 150), (5, 'C', 300);

statement ok
CREATE MATERIALIZED VIEW mv_cte_avg AS
    WITH tiers AS (SELECT id, tier, bal FROM cte_avg_t)
    SELECT tier, COUNT(*) AS cnt, AVG(bal) AS avg_bal FROM tiers GROUP BY tier;

query I
SELECT count(*) FROM (
    SELECT * FROM mv_cte_avg
    EXCEPT ALL SELECT tier, COUNT(*), AVG(bal) FROM cte_avg_t GROUP BY tier
);
----
0

# Delta: update values so AVG changes.
statement ok
UPDATE cte_avg_t SET bal = bal + 1000 WHERE tier = 'A';

statement ok
INSERT INTO cte_avg_t VALUES (6, 'B', 250);

statement ok
PRAGMA refresh('mv_cte_avg');

query I
SELECT count(*) FROM (
    SELECT * FROM mv_cte_avg
    EXCEPT ALL SELECT tier, COUNT(*), AVG(bal) FROM cte_avg_t GROUP BY tier
);
----
0

query I
SELECT count(*) FROM (
    SELECT tier, COUNT(*), AVG(bal) FROM cte_avg_t GROUP BY tier
    EXCEPT ALL SELECT * FROM mv_cte_avg
);
----
0

# ============================================================
# CTE aggregate joined to dimension-side pass-through columns
# ============================================================

statement ok
CREATE TABLE cte_joinagg_customer(w INT, credit VARCHAR, bal DOUBLE);

statement ok
CREATE TABLE cte_joinagg_wh(w INT, tax DOUBLE);

statement ok
INSERT INTO cte_joinagg_customer VALUES
    (1, 'GC', 10), (1, 'GC', 20), (1, 'BC', 50),
    (2, 'GC', 100), (2, 'GC', 130);

statement ok
INSERT INTO cte_joinagg_wh VALUES (1, 0.05), (2, 0.10);

statement ok
CREATE MATERIALIZED VIEW mv_cte_joinagg AS
    WITH customer_segments AS (
        SELECT w,
               CASE WHEN credit = 'GC' THEN 'good' ELSE 'bad' END AS credit_seg,
               AVG(bal) AS avg_bal,
               STDDEV(bal) AS std_bal,
               COUNT(*) AS cnt
        FROM cte_joinagg_customer
        GROUP BY w, CASE WHEN credit = 'GC' THEN 'good' ELSE 'bad' END
    )
    SELECT cs.w, cs.credit_seg, cs.avg_bal, cs.std_bal, cs.cnt, wh.tax
    FROM customer_segments cs JOIN cte_joinagg_wh wh ON cs.w = wh.w;

query I
SELECT type FROM openivm_views WHERE view_name = 'mv_cte_joinagg';
----
6

statement ok
UPDATE cte_joinagg_customer SET bal = 100 WHERE w = 1 AND credit = 'GC' AND bal = 10;

statement ok
UPDATE cte_joinagg_wh SET tax = 0.15 WHERE w = 2;

statement ok
PRAGMA refresh('mv_cte_joinagg');

query I
SELECT COUNT(*) FROM (
    SELECT * FROM mv_cte_joinagg
    EXCEPT ALL
    SELECT * FROM (
        WITH customer_segments AS (
            SELECT w,
                   CASE WHEN credit = 'GC' THEN 'good' ELSE 'bad' END AS credit_seg,
                   AVG(bal) AS avg_bal,
                   STDDEV(bal) AS std_bal,
                   COUNT(*) AS cnt
            FROM cte_joinagg_customer
            GROUP BY w, CASE WHEN credit = 'GC' THEN 'good' ELSE 'bad' END
        )
        SELECT cs.w, cs.credit_seg, cs.avg_bal, cs.std_bal, cs.cnt, wh.tax
        FROM customer_segments cs JOIN cte_joinagg_wh wh ON cs.w = wh.w
    )
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM (
        WITH customer_segments AS (
            SELECT w,
                   CASE WHEN credit = 'GC' THEN 'good' ELSE 'bad' END AS credit_seg,
                   AVG(bal) AS avg_bal,
                   STDDEV(bal) AS std_bal,
                   COUNT(*) AS cnt
            FROM cte_joinagg_customer
            GROUP BY w, CASE WHEN credit = 'GC' THEN 'good' ELSE 'bad' END
        )
        SELECT cs.w, cs.credit_seg, cs.avg_bal, cs.std_bal, cs.cnt, wh.tax
        FROM customer_segments cs JOIN cte_joinagg_wh wh ON cs.w = wh.w
    )
    EXCEPT ALL
    SELECT * FROM mv_cte_joinagg
);
----
0

# ============================================================
# HAVING inside a CTE body.
# The outer uses the CTE in a JOIN; HAVING belongs to the CTE's own aggregate,
# not the MV's output. Two things must work:
#   1. StripHavingFilter must not strip a FILTER that sits under a MATERIALIZED_CTE
#      — otherwise it extracts the predicate with bindings that don't line up with
#      the view's top-level column names, producing a view WHERE like
#      `(I_NAME > 100)` on a VARCHAR column.
#   2. The parser must relax CTE_MATERIALIZE_ALWAYS -> CTE_MATERIALIZE_DEFAULT before
#      calling CTEInlining. DuckDB's binder defaults to ALWAYS, which makes
#      CTEInlining bail out and keep LOGICAL_MATERIALIZED_CTE in the plan — but IVM
#      has no delta-consolidation rule for LOGICAL_CTE_REF. Relaxing the flag lets
#      the CTE body fold into the outer plan. Because the stored aggregate-filter
#      query is backed by a join, GROUP_RECOMPUTE must use current-vs-stored diff
#      affected keys; source-delta affected keys can miss batched deletes on both
#      join inputs.
# ============================================================

statement ok
CREATE TABLE cte_hav_item (i_id INT, i_name VARCHAR, i_price DECIMAL(18,3));

statement ok
CREATE TABLE cte_hav_ol (ol_i_id INT, ol_amount DECIMAL(18,3));

statement ok
INSERT INTO cte_hav_item VALUES (1, 'a', 10), (2, 'b', 20), (3, 'c', 30);

statement ok
INSERT INTO cte_hav_ol VALUES (1, 50), (1, 60), (2, 30), (3, 40), (3, 60), (3, 50);

statement ok
CREATE MATERIALIZED VIEW mv_cte_having AS
    WITH item_revenue AS (
        SELECT ol_i_id, SUM(ol_amount) AS rev FROM cte_hav_ol GROUP BY ol_i_id
        HAVING SUM(ol_amount) > 100
    )
    SELECT i.i_id, i.i_name, i.i_price, ir.rev
    FROM cte_hav_item i JOIN item_revenue ir ON i.i_id = ir.ol_i_id;

query I
SELECT type FROM openivm_views WHERE view_name = 'mv_cte_having';
----
6

query T
SELECT group_recompute_affected_mode FROM openivm_views WHERE view_name = 'mv_cte_having';
----
current_diff

query I
SELECT group_recompute_source_occurrences_json IS NOT NULL FROM openivm_views WHERE view_name = 'mv_cte_having';
----
true

query I
SELECT count(*) FROM (
    SELECT * FROM mv_cte_having
    EXCEPT ALL
    (WITH item_revenue AS (SELECT ol_i_id, SUM(ol_amount) AS rev FROM cte_hav_ol GROUP BY ol_i_id HAVING SUM(ol_amount) > 100)
     SELECT i.i_id, i.i_name, i.i_price, ir.rev FROM cte_hav_item i JOIN item_revenue ir ON i.i_id = ir.ol_i_id)
);
----
0

query I
SELECT count(*) FROM (
    (WITH item_revenue AS (SELECT ol_i_id, SUM(ol_amount) AS rev FROM cte_hav_ol GROUP BY ol_i_id HAVING SUM(ol_amount) > 100)
     SELECT i.i_id, i.i_name, i.i_price, ir.rev FROM cte_hav_item i JOIN item_revenue ir ON i.i_id = ir.ol_i_id)
    EXCEPT ALL SELECT * FROM mv_cte_having
);
----
0

