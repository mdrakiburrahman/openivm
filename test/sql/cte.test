# ==========================================
# CTE re-aggregate: outer GROUP BY over inner CTE aggregate
# Regression: first-found-wins for group_index must preserve the outermost aggregate's group key
# ==========================================

statement ok
CREATE TABLE cra_customer (c_w_id INT, c_d_id INT, c_balance DOUBLE);

statement ok
INSERT INTO cra_customer VALUES (1, 1, 100.0), (1, 1, 50.0), (1, 2, 200.0), (2, 1, 75.0);

statement ok
CREATE MATERIALIZED VIEW mv_cra AS
    WITH mat AS (
        SELECT c_w_id, c_d_id, SUM(c_balance) AS tot, COUNT(*) AS n
        FROM cra_customer GROUP BY c_w_id, c_d_id
    )
    SELECT c_w_id, SUM(tot) AS w_tot, SUM(n) AS w_cnt, COUNT(*) AS dists
    FROM mat GROUP BY c_w_id;

# Verify classification is GROUP_RECOMPUTE (6): outer COUNT(*) counts inner groups (non-linear over source deltas)
query I
SELECT type FROM openivm_views WHERE view_name = 'mv_cra';
----
6

statement ok
INSERT INTO cra_customer VALUES (1, 3, 999.0), (2, 1, 25.0);

statement ok
PRAGMA refresh('mv_cra');

query I
SELECT COUNT(*) FROM (
    (SELECT c_w_id, SUM(tot) AS w_tot, SUM(n) AS w_cnt, COUNT(*) AS dists
     FROM (SELECT c_w_id, c_d_id, SUM(c_balance) AS tot, COUNT(*) AS n FROM cra_customer GROUP BY c_w_id, c_d_id) mat
     GROUP BY c_w_id)
    EXCEPT ALL SELECT * FROM mv_cra
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM mv_cra
    EXCEPT ALL
    (SELECT c_w_id, SUM(tot) AS w_tot, SUM(n) AS w_cnt, COUNT(*) AS dists
     FROM (SELECT c_w_id, c_d_id, SUM(c_balance) AS tot, COUNT(*) AS n FROM cra_customer GROUP BY c_w_id, c_d_id) mat
     GROUP BY c_w_id)
);
