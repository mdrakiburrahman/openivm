# ============================================================
# Duplicate column names in SELECT.
# `SELECT W_ID, W_ID …` and `SELECT col, col, COUNT(*) GROUP BY col, col`
# generate LPTS output with duplicate output columns; without dedup,
# `CREATE TABLE openivm_data_mv AS <view_query>` rejects duplicates.
# Both output_names AND aggregate_columns get `_N` suffixes so:
#   1. The data table has unique columns.
#   2. The unique index and MERGE ON/UPDATE SET clauses reference the deduped
#      names — otherwise the second occurrence gets treated as an aggregate
#      column and the MERGE adds values instead of matching them.
# ============================================================

statement ok
CREATE TABLE dup_t (w_id INT, w_tax DECIMAL(10,3));

statement ok
INSERT INTO dup_t VALUES (1, 0.1), (2, 0.2), (3, 0.1);

statement ok
CREATE MATERIALIZED VIEW mv_dup_distinct AS SELECT DISTINCT w_id, w_id FROM dup_t;

query II
SELECT * FROM mv_dup_distinct ORDER BY w_id;
----
1	1
2	2
3	3

statement ok
CREATE MATERIALIZED VIEW mv_dup_agg AS SELECT w_tax, w_tax, COUNT(*) FROM dup_t GROUP BY w_tax, w_tax;

query III
SELECT w_tax, w_tax_1, count_star FROM mv_dup_agg ORDER BY w_tax;
----
0.100	0.100	2
0.200	0.200	1

statement ok
INSERT INTO dup_t VALUES (4, 0.2), (1, 0.3);

statement ok
PRAGMA refresh('mv_dup_distinct');

statement ok
PRAGMA refresh('mv_dup_agg');

query II
SELECT * FROM mv_dup_distinct ORDER BY w_id;
----
1	1
2	2
3	3
4	4

query III
SELECT w_tax, w_tax_1, count_star FROM mv_dup_agg ORDER BY w_tax;
----
0.100	0.100	2
0.200	0.200	2
0.300	0.300	1

# ============================================================
# CTE self-join (regression — pre-fix the optimizer's CTE
# materialization left a single physical scan referenced from
# both join sides, so IncrementalJoinRule's inclusion-exclusion saw one
# leaf instead of two and missed the cross-term Δt × t_now /
# t_now × Δt that produces new pairs from a single delta.
# Fix: InlineCteRefs in src/core/plan_rewrite.cpp deep-copies
# the CTE definition per reference before any IVM rewrite runs.)
# ============================================================

statement ok
CREATE TABLE selfjoin_t (id INT, k INT, v INT);

statement ok
INSERT INTO selfjoin_t VALUES (1,1,10), (2,1,20), (3,2,30), (4,2,40);

statement ok
CREATE MATERIALIZED VIEW selfjoin_mv AS
    WITH c AS (SELECT id, k, v FROM selfjoin_t)
    SELECT x.id AS xid, x.v AS xv, y.id AS yid, y.v AS yv
    FROM c x JOIN c y ON x.k = y.k AND x.id < y.id;

# Initial state: 1 pair per group.
query I
SELECT COUNT(*) FROM (
    SELECT xid, xv, yid, yv FROM selfjoin_mv
    EXCEPT ALL
    SELECT x.id, x.v, y.id, y.v
    FROM selfjoin_t x JOIN selfjoin_t y ON x.k = y.k AND x.id < y.id
);
----
0

# Insert one new row: it must pair with each pre-existing row in the
# same group. For k=1 with new id=5, two new pairs (1,5) and (2,5).
statement ok
INSERT INTO selfjoin_t VALUES (5, 1, 50);

statement ok
PRAGMA refresh('selfjoin_mv');

query I
SELECT COUNT(*) FROM (
    SELECT xid, xv, yid, yv FROM selfjoin_mv
    EXCEPT ALL
    SELECT x.id, x.v, y.id, y.v
    FROM selfjoin_t x JOIN selfjoin_t y ON x.k = y.k AND x.id < y.id
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT x.id, x.v, y.id, y.v
    FROM selfjoin_t x JOIN selfjoin_t y ON x.k = y.k AND x.id < y.id
    EXCEPT ALL
    SELECT xid, xv, yid, yv FROM selfjoin_mv
);
----
0

# Mixed batch: new row in another group + delete an existing row.
statement ok
INSERT INTO selfjoin_t VALUES (6, 2, 60);

statement ok
DELETE FROM selfjoin_t WHERE id = 1;

statement ok
PRAGMA refresh('selfjoin_mv');

query I
SELECT COUNT(*) FROM (
    SELECT xid, xv, yid, yv FROM selfjoin_mv
    EXCEPT ALL
    SELECT x.id, x.v, y.id, y.v
    FROM selfjoin_t x JOIN selfjoin_t y ON x.k = y.k AND x.id < y.id
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT x.id, x.v, y.id, y.v
    FROM selfjoin_t x JOIN selfjoin_t y ON x.k = y.k AND x.id < y.id
    EXCEPT ALL
    SELECT xid, xv, yid, yv FROM selfjoin_mv
);
----
0

# Classification: SIMPLE_PROJECTION (type 2), not FULL_REFRESH.
query I
SELECT type FROM openivm_views WHERE view_name = 'selfjoin_mv';
----
2

# ==========================================
# JOIN with inner subquery aggregate (join-key-group fallback)
# Regression: must route to GROUP_RECOMPUTE with join key as group key, not SIMPLE_AGGREGATE
# ==========================================

statement ok
CREATE TABLE jia_customer (c_id INT, c_w_id INT, c_balance DOUBLE);

statement ok
CREATE TABLE jia_history (h_c_id INT, h_amount DOUBLE);

statement ok
INSERT INTO jia_customer VALUES (1, 1, 50.0), (2, 1, 100.0), (3, 2, 75.0);

statement ok
INSERT INTO jia_history VALUES (1, 10.0), (1, 20.0), (2, 5.0), (3, 30.0);

statement ok
CREATE MATERIALIZED VIEW mv_jia AS
    SELECT c.c_id, agg.avg_val
    FROM jia_customer c
    JOIN (SELECT h_c_id, AVG(h_amount) AS avg_val FROM jia_history GROUP BY h_c_id) agg
      ON c.c_id = agg.h_c_id;

# Verify classification is GROUP_RECOMPUTE (6)
query I
SELECT type FROM openivm_views WHERE view_name = 'mv_jia';
----
6

statement ok
INSERT INTO jia_history VALUES (2, 15.0);

statement ok
DELETE FROM jia_customer WHERE c_id = 3;

statement ok
PRAGMA refresh('mv_jia');

query I
SELECT COUNT(*) FROM (
    (SELECT c.c_id, agg.avg_val
     FROM jia_customer c
     JOIN (SELECT h_c_id, AVG(h_amount) AS avg_val FROM jia_history GROUP BY h_c_id) agg
       ON c.c_id = agg.h_c_id)
    EXCEPT ALL SELECT * FROM mv_jia
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT * FROM mv_jia
    EXCEPT ALL
    (SELECT c.c_id, agg.avg_val
     FROM jia_customer c
     JOIN (SELECT h_c_id, AVG(h_amount) AS avg_val FROM jia_history GROUP BY h_c_id) agg
       ON c.c_id = agg.h_c_id)
);
----
0

# Second refresh: insert into history (affects avg) + insert new customer row
statement ok
INSERT INTO jia_history VALUES (1, 30.0);

statement ok
