statement ok
CREATE MATERIALIZED VIEW mv_subq_semi AS
    SELECT l.id, l.x
    FROM sq_l l SEMI JOIN (SELECT y FROM sq_r WHERE active) r ON l.x = r.y;

statement ok
CREATE MATERIALIZED VIEW mv_subq_anti AS
    SELECT l.id, l.x
