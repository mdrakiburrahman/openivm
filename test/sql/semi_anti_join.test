# ============================================================
# EXISTS / NOT EXISTS subqueries lower to SEMI/ANTI joins. These
# should use the same aux-state path, including arbitrary correlated
# predicates and an outer filter stacked around the subquery.
# ============================================================

statement ok
CREATE TABLE exists_l (id INT, x INT, keep BOOLEAN);

statement ok
CREATE TABLE exists_r (rid INT, y INT, active BOOLEAN);

statement ok
INSERT INTO exists_l VALUES (1, 10, true), (1, 10, true), (2, 20, true), (3, 30, false), (4, 40, true);

statement ok
INSERT INTO exists_r VALUES (10, 8, true), (11, 20, false), (12, 99, true);

statement ok
CREATE MATERIALIZED VIEW mv_exists_semi AS
    SELECT l.id, l.x
    FROM exists_l l
    WHERE l.keep AND EXISTS (
        SELECT 1 FROM exists_r r
        WHERE r.active AND abs(l.x - r.y) <= 2
    );

statement ok
CREATE MATERIALIZED VIEW mv_exists_anti AS
    SELECT l.id, l.x
    FROM exists_l l
    WHERE NOT EXISTS (
        SELECT 1 FROM exists_r r
        WHERE r.active AND abs(l.x - r.y) <= 2
    ) AND l.keep;

query I
SELECT COUNT(*) FROM openivm_views
WHERE view_name IN ('mv_exists_semi', 'mv_exists_anti') AND semi_anti_aux_meta_json IS NOT NULL;
----
2

statement ok
UPDATE exists_r SET active = true WHERE rid = 11;

statement ok
INSERT INTO exists_r VALUES (13, 41, true), (14, 30, true);

statement ok
DELETE FROM exists_r WHERE rid = 10;

statement ok
UPDATE exists_l SET keep = true WHERE id = 3;

statement ok
INSERT INTO exists_l VALUES (5, 50, true), (6, 40, true);

statement ok
PRAGMA refresh('mv_exists_semi');

statement ok
PRAGMA refresh('mv_exists_anti');

query I
SELECT COUNT(*) FROM (
    SELECT l.id, l.x
    FROM exists_l l
    WHERE l.keep AND EXISTS (
        SELECT 1 FROM exists_r r
        WHERE r.active AND abs(l.x - r.y) <= 2
    )
    EXCEPT ALL SELECT id, x FROM mv_exists_semi
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT id, x FROM mv_exists_semi
    EXCEPT ALL
    SELECT l.id, l.x
    FROM exists_l l
    WHERE l.keep AND EXISTS (
        SELECT 1 FROM exists_r r
        WHERE r.active AND abs(l.x - r.y) <= 2
    )
);
----
