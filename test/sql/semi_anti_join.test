statement ok
INSERT INTO in_cast_r VALUES (1, 20), (2, 99);

statement ok
CREATE MATERIALIZED VIEW mv_not_in_cast AS
    SELECT CAST(x AS BIGINT) AS item_id
    FROM in_cast_l
    WHERE CAST(x AS BIGINT) NOT IN (SELECT CAST(y AS BIGINT) FROM in_cast_r);

statement ok
INSERT INTO in_cast_l VALUES (5, 50), (6, 20);

statement ok
DELETE FROM in_cast_r WHERE rid = 1;

statement ok
INSERT INTO in_cast_r VALUES (3, 30), (4, 50);

statement ok
