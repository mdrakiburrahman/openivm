# ============================================================
# Stacked FILTER above SEMI/ANTI. The aux state tracks all left
# tuples; refresh only materializes rows that pass the outer filter.
# ============================================================

statement ok
CREATE TABLE stack_l (id INT, x INT);

statement ok
CREATE TABLE stack_r (rid INT, y INT);

statement ok
INSERT INTO stack_l VALUES (1, 10), (2, 20), (3, 30), (4, 40), (5, 50);

statement ok
INSERT INTO stack_r VALUES (1, 10), (2, 21), (3, 70);

statement ok
CREATE MATERIALIZED VIEW mv_stack_semi AS
    SELECT l.id, l.x FROM stack_l l SEMI JOIN stack_r r ON abs(l.x - r.y) <= 1 WHERE l.id >= 2;

statement ok
CREATE MATERIALIZED VIEW mv_stack_anti AS
    SELECT l.id, l.x FROM stack_l l ANTI JOIN stack_r r ON abs(l.x - r.y) <= 1 WHERE l.id >= 2;

statement ok
INSERT INTO stack_r VALUES (4, 40), (5, 51);

statement ok
UPDATE stack_l SET id = 6 WHERE id = 1;

statement ok
DELETE FROM stack_r WHERE rid = 2;

statement ok
INSERT INTO stack_l VALUES (7, 70);

statement ok
PRAGMA refresh('mv_stack_semi');

statement ok
PRAGMA refresh('mv_stack_anti');

