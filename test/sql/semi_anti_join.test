query I
SELECT COUNT(*) FROM (
    SELECT CAST(x AS BIGINT) AS item_id
    FROM in_cast_l
    WHERE CAST(x AS BIGINT) NOT IN (SELECT CAST(y AS BIGINT) FROM in_cast_r)
    EXCEPT ALL SELECT item_id FROM mv_not_in_cast
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT item_id FROM mv_not_in_cast
    EXCEPT ALL
    SELECT CAST(x AS BIGINT) AS item_id
    FROM in_cast_l
    WHERE CAST(x AS BIGINT) NOT IN (SELECT CAST(y AS BIGINT) FROM in_cast_r)
);
