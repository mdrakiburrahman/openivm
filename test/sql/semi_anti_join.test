# ============================================================
# UPDATEs are tracked as delete+insert deltas. Exercise left-side
# identity movement, right-side match movement, and NULL-safe predicates.
# ============================================================

statement ok
CREATE TABLE upd_l (id INT, x INT);

statement ok
CREATE TABLE upd_r (rid INT, y INT);

statement ok
INSERT INTO upd_l VALUES (1, 10), (2, NULL), (3, 30), (4, 40);

statement ok
INSERT INTO upd_r VALUES (100, 10), (101, NULL), (102, 99);

statement ok
CREATE MATERIALIZED VIEW mv_upd_semi AS
    SELECT l.id, l.x FROM upd_l l SEMI JOIN upd_r r ON l.x IS NOT DISTINCT FROM r.y;

statement ok
CREATE MATERIALIZED VIEW mv_upd_anti AS
    SELECT l.id, l.x FROM upd_l l ANTI JOIN upd_r r ON l.x IS NOT DISTINCT FROM r.y;

statement ok
UPDATE upd_l SET x = 99 WHERE id = 3;

statement ok
UPDATE upd_r SET y = 40 WHERE rid = 102;

statement ok
DELETE FROM upd_r WHERE rid = 101;

statement ok
INSERT INTO upd_l VALUES (5, NULL), (5, NULL);

statement ok
PRAGMA refresh('mv_upd_semi');

statement ok
PRAGMA refresh('mv_upd_anti');

