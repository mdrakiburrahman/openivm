0

statement ok
CREATE TABLE rr_fo_a(k INT, a VARCHAR);

statement ok
CREATE TABLE rr_fo_b(k INT, b VARCHAR);

statement ok
INSERT INTO rr_fo_a VALUES (1, 'a1'), (2, 'a2');

statement ok
INSERT INTO rr_fo_b VALUES (2, 'b2'), (3, 'b3');

statement ok
CREATE MATERIALIZED VIEW rr_full_join_mv AS
	SELECT coalesce(rr_fo_a.k, rr_fo_b.k) AS k, rr_fo_a.a, rr_fo_b.b
	FROM rr_fo_a FULL OUTER JOIN rr_fo_b ON rr_fo_a.k = rr_fo_b.k;

statement ok
INSERT INTO rr_fo_a VALUES (3, 'a3');

statement ok
DELETE FROM rr_fo_b WHERE k = 2;

statement ok
PRAGMA refresh('rr_full_join_mv');

query I
WITH expected AS (
	SELECT coalesce(rr_fo_a.k, rr_fo_b.k) AS k, rr_fo_a.a, rr_fo_b.b
	FROM rr_fo_a FULL OUTER JOIN rr_fo_b ON rr_fo_a.k = rr_fo_b.k
), diff AS (
	(SELECT * FROM rr_full_join_mv EXCEPT ALL SELECT * FROM expected)
	UNION ALL
	(SELECT * FROM expected EXCEPT ALL SELECT * FROM rr_full_join_mv)
)
SELECT count(*) FROM diff;
----
0

# UNION ALL path
statement ok
CREATE TABLE rr_left(id INT, k INT);

statement ok
CREATE TABLE rr_right(id INT, k INT);

statement ok
INSERT INTO rr_left VALUES (1, 10), (2, 20);

statement ok
INSERT INTO rr_right VALUES (3, 30), (4, 40);

statement ok
CREATE MATERIALIZED VIEW rr_union_mv AS
	(SELECT id, k FROM rr_left UNION ALL SELECT id, k FROM rr_right);

statement ok
INSERT INTO rr_left VALUES (5, 50);

statement ok
DELETE FROM rr_right WHERE id = 3;

statement ok
UPDATE rr_left SET k = 25 WHERE id = 2;

statement ok
PRAGMA refresh('rr_union_mv');

query I
WITH expected AS (
	SELECT id, k FROM rr_left
	UNION ALL
	SELECT id, k FROM rr_right
), diff AS (
	(SELECT * FROM rr_union_mv EXCEPT ALL SELECT * FROM expected)
	UNION ALL
	(SELECT * FROM expected EXCEPT ALL SELECT * FROM rr_union_mv)
)
SELECT count(*) FROM diff;
----
0

