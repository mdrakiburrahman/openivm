# name: test/sql/ducklake_chained_physical.test
# description: Chained DuckLake MV refresh with physical OpenIVM metadata database
# group: [sql]

require openivm

require parquet

load __TEST_DIR__/ducklake_chained_physical_main.db

statement ok
INSTALL ducklake;

statement ok
LOAD ducklake;

statement ok
SET openivm_cascade_refresh='off';

statement ok
ATTACH '__TEST_DIR__/ducklake_chained_physical_lake.db' AS dl (TYPE ducklake);

statement ok
CREATE SCHEMA dl.bronze;

statement ok
CREATE SCHEMA dl.silver;

statement ok
CREATE TABLE dl.bronze.src (
    dm_date DATE,
    sym VARCHAR,
    low_price INT,
    high_price INT
);

statement ok
INSERT INTO dl.bronze.src VALUES
    (DATE '2026-01-01', 'A', 10, 20),
    (DATE '2026-01-02', 'A', 8, 22);

statement ok
CREATE MATERIALIZED VIEW dl.bronze.l1 AS
SELECT dm_date, sym, low_price, high_price
FROM dl.bronze.src;

statement ok
CREATE MATERIALIZED VIEW dl.silver.l2 AS
SELECT
    dm_date,
    sym,
    low_price,
    high_price,
    MIN(low_price) OVER (PARTITION BY sym ORDER BY dm_date) AS running_low,
    MAX(high_price) OVER (PARTITION BY sym ORDER BY dm_date) AS running_high
FROM dl.bronze.l1;

statement ok
CREATE MATERIALIZED VIEW dl.silver.l3 AS
SELECT dm_date, sym, running_low, running_high
FROM dl.silver.l2;

statement ok
INSERT INTO dl.bronze.src VALUES
    (DATE '2026-01-03', 'A', 7, 25);

statement ok
PRAGMA refresh_options('dl', 'bronze', 'l1');

# The upstream DuckLake MV writes its user-facing objects and OpenIVM data/delta
# state to DuckLake. Downstream MVs track changes on the upstream DuckLake
# openivm_data_* table directly, so no companion rows are needed in openivm_delta_l1.
query I
SELECT count(*) FROM dl.bronze.openivm_delta_l1;
----
0

statement ok
PRAGMA refresh_options('dl', 'silver', 'l2');

# Window-partition recompute updates l2 directly. Since l3 reads l2's DuckLake
# openivm_data_* table, downstream refresh can use DuckLake change tracking instead
# of companion rows in openivm_delta_l2.
query I
SELECT count(*) FROM dl.silver.openivm_delta_l2;
----
0

query I
SELECT count(*) FROM (
    SELECT * FROM dl.silver.l2
    EXCEPT ALL
    SELECT
        dm_date,
        sym,
        low_price,
        high_price,
        MIN(low_price) OVER (PARTITION BY sym ORDER BY dm_date) AS running_low,
        MAX(high_price) OVER (PARTITION BY sym ORDER BY dm_date) AS running_high
    FROM dl.bronze.l1
);
----
0

statement ok
PRAGMA refresh_options('dl', 'silver', 'l3');

query I
SELECT count(*) FROM (
    SELECT * FROM dl.silver.l3
    EXCEPT ALL
    SELECT dm_date, sym, running_low, running_high
    FROM dl.silver.l2
);
----
0

query I
SELECT count(*) FROM (
    SELECT dm_date, sym, running_low, running_high
    FROM dl.silver.l2
    EXCEPT ALL
    SELECT * FROM dl.silver.l3
);
----
0

query I
SELECT count(*) FROM (
    SELECT
        dm_date,
        sym,
        low_price,
        high_price,
        MIN(low_price) OVER (PARTITION BY sym ORDER BY dm_date) AS running_low,
        MAX(high_price) OVER (PARTITION BY sym ORDER BY dm_date) AS running_high
    FROM dl.bronze.l1
    EXCEPT ALL
    SELECT * FROM dl.silver.l2
);
----
0
