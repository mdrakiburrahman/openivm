# Retained ORDER BY/LIMIT fallback must use current-vs-stored affected keys.
# The unchanged second-place group has to enter the LIMIT after the old top group
# loses rows, even though that second-place group has no delta.
statement ok
CREATE TABLE list_filter_topk_items (grp INT, item INT, qty INT);

statement ok
INSERT INTO list_filter_topk_items VALUES
    (1, 10, 90), (1, 11, 80), (1, 12, 70),
    (2, 20, 85), (2, 21, 75),
    (3, 30, 95);

statement ok
CREATE MATERIALIZED VIEW mv_list_filter_topk AS
    SELECT grp,
           LIST(item ORDER BY qty DESC) FILTER (WHERE qty > 50) AS well_stocked,
           COUNT(*) AS cnt
    FROM list_filter_topk_items
    GROUP BY grp
    HAVING COUNT(*) > 0
    ORDER BY cnt DESC, grp
    LIMIT 1;

query I
SELECT type FROM openivm_views WHERE view_name = 'mv_list_filter_topk';
----
6

query T
SELECT group_recompute_affected_mode FROM openivm_views WHERE view_name = 'mv_list_filter_topk';
----
current_diff

query I
WITH expected AS (
    SELECT grp,
           LIST(item ORDER BY qty DESC) FILTER (WHERE qty > 50) AS well_stocked,
           COUNT(*) AS cnt
    FROM list_filter_topk_items
    GROUP BY grp
    HAVING COUNT(*) > 0
    ORDER BY cnt DESC, grp
    LIMIT 1
)
SELECT COUNT(*) FROM (
    SELECT * FROM mv_list_filter_topk
    EXCEPT ALL
    SELECT * FROM expected
);
----
0

query I
WITH expected AS (
    SELECT grp,
           LIST(item ORDER BY qty DESC) FILTER (WHERE qty > 50) AS well_stocked,
           COUNT(*) AS cnt
    FROM list_filter_topk_items
    GROUP BY grp
    HAVING COUNT(*) > 0
    ORDER BY cnt DESC, grp
    LIMIT 1
)
SELECT COUNT(*) FROM (
    SELECT * FROM expected
    EXCEPT ALL
    SELECT * FROM mv_list_filter_topk
);
----
0

