# name: test/sql/list.test
# description: Test IVM with LIST-typed aggregate columns
# group: [sql]

require openivm

# --- Base table with LIST<FLOAT> column ---
statement ok
CREATE TABLE items (id INT, grp INT, val FLOAT[]);

statement ok
INSERT INTO items VALUES
    (1, 1, list_transform(generate_series(1, 64), lambda x: 10.0::FLOAT)),
    (2, 1, list_transform(generate_series(1, 64), lambda x: 20.0::FLOAT)),
    (3, 2, list_transform(generate_series(1, 64), lambda x: 30.0::FLOAT));

# --- MV: element-wise list sum using pure DuckDB ---
statement ok
CREATE MATERIALIZED VIEW mv_list AS (
    SELECT grp,
        list_reduce(list(val), lambda a, b: list_transform(list_zip(a, b), lambda x: x[1] + x[2])) AS total
    FROM items GROUP BY grp
);

# Verify initial state
query I
SELECT COUNT(*) FROM (
    SELECT * FROM mv_list
    EXCEPT ALL
    SELECT grp, list_reduce(list(val), lambda a, b: list_transform(list_zip(a, b), lambda x: x[1] + x[2])) AS total
    FROM items GROUP BY grp
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT grp, list_reduce(list(val), lambda a, b: list_transform(list_zip(a, b), lambda x: x[1] + x[2])) AS total
    FROM items GROUP BY grp
    EXCEPT ALL
    SELECT * FROM mv_list
);
----
0

# ==========================================
# LIST aggregate with FILTER must not retain NULLs
# ==========================================

statement ok
CREATE TABLE list_filter_items (grp INT, item INT, qty INT);

statement ok
INSERT INTO list_filter_items VALUES
    (1, 10, 90), (1, 20, 10), (1, 30, 80),
    (2, 40, 20), (2, 50, 70);

statement ok
CREATE MATERIALIZED VIEW mv_list_filter AS
    SELECT grp, LIST(item ORDER BY qty DESC) FILTER (WHERE qty > 50) AS well_stocked
    FROM list_filter_items GROUP BY grp;

query I
SELECT type FROM openivm_views WHERE view_name = 'mv_list_filter';
----
6

statement ok
INSERT INTO list_filter_items VALUES (1, 60, 95), (2, 70, 30);

statement ok
pragma refresh('mv_list_filter');

query I
SELECT COUNT(*) FROM (
    SELECT * FROM mv_list_filter
    EXCEPT ALL
    SELECT grp, LIST(item ORDER BY qty DESC) FILTER (WHERE qty > 50) AS well_stocked
    FROM list_filter_items GROUP BY grp
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT grp, LIST(item ORDER BY qty DESC) FILTER (WHERE qty > 50) AS well_stocked
    FROM list_filter_items GROUP BY grp
    EXCEPT ALL
    SELECT * FROM mv_list_filter
);
----
0

