# Fallback top-k views store the already-limited original query in the data table,
# but the user-facing view still needs ORDER BY. This catches stale physical order
# after only the second group changes.
statement ok
CREATE TABLE list_filter_order_items (grp INT, item INT, qty INT);

statement ok
INSERT INTO list_filter_order_items VALUES
    (1, 10, 90), (1, 11, 80), (1, 12, 70),
    (2, 20, 85), (2, 21, 75),
    (3, 30, 95);

statement ok
CREATE MATERIALIZED VIEW mv_list_filter_order AS
    SELECT grp,
           LIST(item ORDER BY qty DESC) FILTER (WHERE qty > 50) AS well_stocked,
           COUNT(*) AS cnt
    FROM list_filter_order_items
    GROUP BY grp
    HAVING COUNT(*) > 0
    ORDER BY cnt DESC, grp DESC
    LIMIT 2;

query I
SELECT grp FROM mv_list_filter_order;
----
1
2

statement ok
INSERT INTO list_filter_order_items VALUES (2, 22, 65);

statement ok
UPDATE list_filter_order_items SET qty = 96 WHERE grp = 3 AND item = 30;

statement ok
DELETE FROM list_filter_order_items WHERE grp = 3 AND item = 30;

statement ok
PRAGMA refresh('mv_list_filter_order');

query I
SELECT grp FROM mv_list_filter_order;
----
2
1

query I
WITH expected AS (
    SELECT grp,
           LIST(item ORDER BY qty DESC) FILTER (WHERE qty > 50) AS well_stocked,
           COUNT(*) AS cnt
    FROM list_filter_order_items
    GROUP BY grp
    HAVING COUNT(*) > 0
    ORDER BY cnt DESC, grp DESC
    LIMIT 2
)
SELECT COUNT(*) FROM (
    SELECT * FROM mv_list_filter_order
    EXCEPT ALL
    SELECT * FROM expected
);
----
0

query I
WITH expected AS (
    SELECT grp,
           LIST(item ORDER BY qty DESC) FILTER (WHERE qty > 50) AS well_stocked,
