# name: test/sql/incremental_checker.test
# description: Test IVM compatibility checker — classifies views as incremental or full refresh
# group: [sql]

require openivm

# ==========================================
# Setup base tables
# ==========================================

statement ok
CREATE TABLE t1 (a INT, b INT);

statement ok
CREATE TABLE t2 (a INT, c INT);

statement ok
INSERT INTO t1 VALUES (1, 10), (2, 20);

statement ok
INSERT INTO t2 VALUES (1, 100), (2, 200);

# ==========================================
# Unsupported joins → auto full refresh (no error)
# ==========================================

statement ok
CREATE MATERIALIZED VIEW mv_left AS SELECT t1.a, t1.b, t2.c FROM t1 LEFT JOIN t2 ON t1.a = t2.a;

query III
SELECT a, b, c FROM mv_left ORDER BY a;
----
1	10	100
2	20	200

# RIGHT JOIN (rewritten to LEFT by DuckDB)
statement ok
CREATE MATERIALIZED VIEW mv_right AS SELECT t1.a, t1.b, t2.c FROM t1 RIGHT JOIN t2 ON t1.a = t2.a;

# ==========================================
# Unsupported aggregates → auto full refresh
# ==========================================

statement ok
CREATE MATERIALIZED VIEW mv_stddev AS SELECT a, STDDEV(b) AS sd FROM t1 GROUP BY a;

statement ok
CREATE MATERIALIZED VIEW mv_string_agg AS SELECT STRING_AGG(a::VARCHAR, ',') AS all_a FROM t1;

# ==========================================
# Non-deterministic functions → auto full refresh
# ==========================================

statement ok
CREATE TABLE t3 (x INT);

statement ok
INSERT INTO t3 VALUES (1), (2), (3);

statement ok
CREATE MATERIALIZED VIEW mv_random AS SELECT x, RANDOM() AS r FROM t3;

statement ok
CREATE MATERIALIZED VIEW mv_now AS SELECT x, NOW() AS ts FROM t3;

# ==========================================
# Supported constructs → incremental
# ==========================================

statement ok
CREATE MATERIALIZED VIEW mv_inner AS SELECT t1.a, t1.b, t2.c FROM t1 INNER JOIN t2 ON t1.a = t2.a;

statement ok
CREATE MATERIALIZED VIEW mv_sum AS SELECT a, SUM(b) AS total FROM t1 GROUP BY a;

statement ok
CREATE MATERIALIZED VIEW mv_avg AS SELECT a, AVG(b) AS avg_b FROM t1 GROUP BY a;

statement ok
CREATE MATERIALIZED VIEW mv_count AS SELECT COUNT(*) AS cnt FROM t1;

statement ok
CREATE MATERIALIZED VIEW mv_proj AS SELECT a, b FROM t1;

statement ok
CREATE MATERIALIZED VIEW mv_filter AS SELECT a, b FROM t1 WHERE b > 5;

statement ok
CREATE MATERIALIZED VIEW mv_min_model AS SELECT a, MIN(b) AS min_b FROM t1 GROUP BY a;

query TI
SELECT view_name, type FROM openivm_views
WHERE view_name IN ('mv_avg', 'mv_count', 'mv_filter', 'mv_inner', 'mv_min_model', 'mv_proj', 'mv_sum')
ORDER BY view_name;
----
mv_avg	0
mv_count	1
mv_filter	2
mv_inner	2
mv_min_model	0
mv_proj	2
mv_sum	0

query I
SELECT has_minmax::INT FROM openivm_views WHERE view_name = 'mv_min_model';
----
1

# ==========================================
# Full refresh works for unsupported MVs
# ==========================================

statement ok
INSERT INTO t1 VALUES (3, 30);

statement ok
INSERT INTO t2 VALUES (3, 300);

statement ok
INSERT INTO t3 VALUES (4);

# LEFT JOIN MV: auto full refresh via PRAGMA refresh
statement ok
PRAGMA refresh('mv_left');

query III
SELECT a, b, c FROM mv_left ORDER BY a;
----
1	10	100
2	20	200
3	30	300

# Cross-check
query III
SELECT t1.a, t1.b, t2.c FROM t1 LEFT JOIN t2 ON t1.a = t2.a ORDER BY t1.a;
----
1	10	100
2	20	200
3	30	300

# STDDEV MV: auto full refresh
statement ok
PRAGMA refresh('mv_stddev');

query I
SELECT COUNT(*) FROM (
    SELECT a, STDDEV(b) AS sd FROM t1 GROUP BY a
    EXCEPT ALL
    SELECT a, sd FROM mv_stddev
);
----
0

# RANDOM() MV: full refresh (values will differ from base query, but row count matches)
statement ok
PRAGMA refresh('mv_random');

query I
SELECT COUNT(*) FROM mv_random;
----
4

# NOW() MV: full refresh
statement ok
PRAGMA refresh('mv_now');

query I
SELECT COUNT(*) FROM mv_now;
----
4

# ==========================================
# Incremental refresh still works for supported MVs
# ==========================================

statement ok
PRAGMA refresh('mv_sum');

query II
SELECT a, total FROM mv_sum ORDER BY a;
----
1	10
2	20
3	30

# Cross-check
query I
SELECT COUNT(*) FROM (SELECT a, SUM(b) AS total FROM t1 GROUP BY a EXCEPT ALL SELECT a, total FROM mv_sum);
----
0

statement ok
PRAGMA refresh('mv_avg');

query I
SELECT COUNT(*) FROM (SELECT a, AVG(b) AS avg_b FROM t1 GROUP BY a EXCEPT ALL SELECT a, avg_b FROM mv_avg);
----
0

statement ok
PRAGMA refresh('mv_proj');

query I
SELECT COUNT(*) FROM (SELECT a, b FROM t1 EXCEPT ALL SELECT a, b FROM mv_proj);
----
0

query I
SELECT COUNT(*) FROM (SELECT a, b FROM mv_proj EXCEPT ALL SELECT a, b FROM t1);
----
0

# ==========================================
# UNION ALL — incremental support
# ==========================================

statement ok
CREATE TABLE u1 (id INT, val VARCHAR);

statement ok
CREATE TABLE u2 (id INT, val VARCHAR);

statement ok
INSERT INTO u1 VALUES (1, 'a'), (2, 'b');

statement ok
INSERT INTO u2 VALUES (3, 'c'), (4, 'd');

statement ok
CREATE MATERIALIZED VIEW mv_union AS SELECT id, val FROM u1 UNION ALL SELECT id, val FROM u2;

query II
SELECT id, val FROM mv_union ORDER BY id;
----
1	a
2	b
3	c
4	d

# Insert into both sides
statement ok
INSERT INTO u1 VALUES (5, 'e');

statement ok
INSERT INTO u2 VALUES (6, 'f');

statement ok
PRAGMA refresh('mv_union');

# Cross-check
query I
SELECT COUNT(*) FROM (
    (SELECT id, val FROM u1 UNION ALL SELECT id, val FROM u2)
    EXCEPT ALL
    SELECT id, val FROM mv_union
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT id, val FROM mv_union
    EXCEPT ALL
    (SELECT id, val FROM u1 UNION ALL SELECT id, val FROM u2)
);
----
0

# ==========================================
# DISTINCT — incremental classification
# ==========================================

statement ok
CREATE TABLE d_src(id INT, region VARCHAR);

statement ok
INSERT INTO d_src VALUES (1, 'east'), (2, 'east'), (3, 'west');

statement ok
CREATE MATERIALIZED VIEW mv_distinct_region AS SELECT DISTINCT region FROM d_src;

statement ok
INSERT INTO d_src VALUES (4, 'north'), (5, 'east');

statement ok
DELETE FROM d_src WHERE id = 3;

statement ok
PRAGMA refresh('mv_distinct_region');

query I
SELECT COUNT(*) FROM (
    SELECT region FROM mv_distinct_region
    EXCEPT ALL
    SELECT DISTINCT region FROM d_src
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT DISTINCT region FROM d_src
    EXCEPT ALL
    SELECT region FROM mv_distinct_region
);
----
0

# ==========================================
# WINDOW — partition recompute classification
# ==========================================

statement ok
CREATE TABLE w_src(id INT, dept VARCHAR, score INT);

statement ok
INSERT INTO w_src VALUES (1, 'eng', 10), (2, 'eng', 30), (3, 'sales', 20);

statement ok
CREATE MATERIALIZED VIEW mv_window_rank AS
    SELECT id, dept, score, ROW_NUMBER() OVER (PARTITION BY dept ORDER BY score, id) AS rn
    FROM w_src;

query IT
SELECT type, group_columns FROM openivm_views WHERE view_name = 'mv_window_rank';
----
5	dept=dept

statement ok
INSERT INTO w_src VALUES (4, 'eng', 25), (5, 'ops', 1);

statement ok
UPDATE w_src SET score = 5 WHERE id = 3;

statement ok
PRAGMA refresh('mv_window_rank');

query I
SELECT COUNT(*) FROM (
    SELECT id, dept, score, rn FROM mv_window_rank
    EXCEPT ALL
    SELECT id, dept, score, ROW_NUMBER() OVER (PARTITION BY dept ORDER BY score, id) AS rn FROM w_src
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT id, dept, score, ROW_NUMBER() OVER (PARTITION BY dept ORDER BY score, id) AS rn FROM w_src
    EXCEPT ALL
    SELECT id, dept, score, rn FROM mv_window_rank
);
----
0

# Delete from one side
statement ok
DELETE FROM u1 WHERE id = 1;

statement ok
PRAGMA refresh('mv_union');

query I
SELECT COUNT(*) FROM (
    (SELECT id, val FROM u1 UNION ALL SELECT id, val FROM u2)
    EXCEPT ALL
    SELECT id, val FROM mv_union
);
----
0

query I
SELECT COUNT(*) FROM (
    SELECT id, val FROM mv_union
    EXCEPT ALL
    (SELECT id, val FROM u1 UNION ALL SELECT id, val FROM u2)
);
----
0
