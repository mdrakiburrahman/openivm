query I
SELECT COUNT(*) FROM (
    SELECT id, k, d, x, MAX(x) OVER (PARTITION BY k ORDER BY d) AS running_max FROM wrai_sales
    EXCEPT ALL
    SELECT * FROM openivm_data_wrai_max_mv
);
