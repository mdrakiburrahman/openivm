{
	// OpenIVM debug profiles. Press F5 (or pick a config in the Run panel).
	// Both build the DEBUG binary first via the "build-debug" task, then launch
	// under gdb so you can step from SQL into OpenIVM's C++ internals.
	"version": "0.2.0",
	"configurations": [
		{
			"name": "Debug OpenIVM Demo",
			"type": "cppdbg",
			"request": "launch",
			"program": "${workspaceFolder}/build/debug/extension/openivm/openivm_demo",
			"args": [],
			"stopAtEntry": false,
			"cwd": "${workspaceFolder}",
			"environment": [
				{
					// The debug build links AddressSanitizer (DuckDB ENABLE_SANITIZER).
					// LeakSanitizer's end-of-run leak check aborts under a debugger
					// (it can't run while the process is ptraced), so disable just
					// the leak check — ASAN's use-after-free/overflow checks stay on.
					"name": "ASAN_OPTIONS",
					"value": "detect_leaks=0"
				}
			],
			"externalConsole": false,
			"MIMode": "gdb",
			"miDebuggerPath": "/usr/bin/gdb",
			"setupCommands": [
				{
					"description": "Enable pretty-printing for gdb",
					"text": "-enable-pretty-printing",
					"ignoreFailures": true
				}
			],
			"preLaunchTask": "build-debug"
		},
		{
			// Same as above, but pre-seeds gdb breakpoints at the Scenario 1
			// compile-only path so F5 stops there immediately — no need to know
			// where to click first. NOTE: these are debugger-side breakpoints, so
			// they do NOT show a red dot in the gutter; execution still stops and
			// the editor jumps to the source line with the call stack + locals.
			// You can add your own gutter breakpoints on top as usual.
			"name": "Debug OpenIVM Demo (auto-stop at the compile path)",
			"type": "cppdbg",
			"request": "launch",
			"program": "${workspaceFolder}/build/debug/extension/openivm/openivm_demo",
			"args": [],
			"stopAtEntry": false,
			"cwd": "${workspaceFolder}",
			"environment": [
				{
					"name": "ASAN_OPTIONS",
					"value": "detect_leaks=0"
				}
			],
			"externalConsole": false,
			"MIMode": "gdb",
			"miDebuggerPath": "/usr/bin/gdb",
			"setupCommands": [
				{
					"description": "Enable pretty-printing for gdb",
					"text": "-enable-pretty-printing",
					"ignoreFailures": true
				},
				{
					"description": "Let breakpoints resolve once symbols load",
					"text": "-gdb-set breakpoint pending on",
					"ignoreFailures": true
				},
				{
					"description": "Scenario 1: table-function entry (src/compile_facts.cpp)",
					"text": "-break-insert OpenIvmCompileWithFactsBind",
					"ignoreFailures": true
				},
				{
					"description": "Scenario 1: JSON -> CompileFacts struct (src/compile_facts.cpp)",
					"text": "-break-insert ParseFactsJson",
					"ignoreFailures": true
				},
				{
					"description": "Scenario 1: the heart of compilation (src/upsert/refresh_sql.cpp)",
					"text": "-break-insert GenerateRefreshSQL",
					"ignoreFailures": true
				}
			],
			"preLaunchTask": "build-debug"
		},
		{
			"name": "Debug a single SQL test (unittest)",
			"type": "cppdbg",
			"request": "launch",
			"program": "${workspaceFolder}/build/debug/test/unittest",
			"args": ["${input:testFile}"],
			"stopAtEntry": false,
			"cwd": "${workspaceFolder}",
			"environment": [
				{
					"name": "ASAN_OPTIONS",
					"value": "detect_leaks=0"
				}
			],
			"externalConsole": false,
			"MIMode": "gdb",
			"miDebuggerPath": "/usr/bin/gdb",
			"setupCommands": [
				{
					"description": "Enable pretty-printing for gdb",
					"text": "-enable-pretty-printing",
					"ignoreFailures": true
				}
			],
			"preLaunchTask": "build-debug"
		}
	],
	"inputs": [
		{
			"id": "testFile",
			"type": "promptString",
			"description": "Path to a .test file to debug",
			"default": "test/sql/aggregate.test"
		}
	]
}
