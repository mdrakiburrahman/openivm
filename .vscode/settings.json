{
	// IntelliSense for OpenIVM + DuckDB headers.
	//
	// Primary source: the compiler's own compile_commands.json (exact per-file
	// flags + include paths), generated by every build under build/<config>/.
	// This is what makes "Go to Definition" reach precisely into DuckDB and LPTS.
	// The includePath list below is a fallback for files not yet in the database
	// (e.g. before the first debug build completes).
	"C_Cpp.default.compileCommands": "${workspaceFolder}/build/debug/compile_commands.json",
	"C_Cpp.default.cppStandard": "c++14",
	"C_Cpp.default.includePath": [
		"${workspaceFolder}/src/include",
		"${workspaceFolder}/duckdb/src/include",
		"${workspaceFolder}/duckdb/third_party/**",
		"${workspaceFolder}/third_party/lpts/src/include",
		"${workspaceFolder}/third_party/lpts/third_party/ducklake/src/include",
		"${workspaceFolder}/benchmark",
		"${workspaceFolder}/benchmark/src"
	],
	"C_Cpp.default.intelliSenseMode": "linux-gcc-x64",
	"files.associations": {
		"*.hpp": "cpp",
		"*.ipp": "cpp",
		"duckdb.hpp": "cpp"
	},
	"cmake.ignoreCMakeListsMissing": true,
	"cmake.configureOnOpen": false
}
